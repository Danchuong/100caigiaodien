      "components": [
        {
          "html": "<style>\n  :root {\n    --color-midnight-ink: #1b1b1b;\n    --color-canvas-white: #ffffff;\n    --color-cloud-gray: #eaeaea;\n    --color-slate-text: #60646c;\n    --color-cloud-border: #e0e1e6;\n    --color-plasma-teal-gradient: linear-gradient(89.97deg, rgb(25, 160, 95) 0.02%, rgb(13, 127, 140) 123.85%);\n    --font-inter: 'Inter', system-ui, sans-serif;\n    --shadow-lg: rgba(0, 0, 0, 0.15) 0px 4px 20px 0px;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n</style>\n<div style=\"font-family: var(--font-inter); background: var(--color-canvas-white); padding: 48px 40px; width: 100%; box-sizing: border-box; max-width: 600px; margin: 0 auto;\">\n  <p style=\"font-family: var(--font-inter); font-size: 13px; font-weight: 500; color: var(--color-slate-text); letter-spacing: 0.05em; text-transform: uppercase; margin: 0 0 16px 0;\">Get started today</p>\n  <h2 style=\"font-family: var(--font-inter); font-size: 40px; font-weight: 700; color: var(--color-midnight-ink); line-height: 1.1; letter-spacing: -1px; margin: 0 0 12px 0;\">Get Started</h2>\n  <p style=\"font-family: var(--font-inter); font-size: 16px; font-weight: 400; color: var(--color-slate-text); line-height: 1.5; margin: 0 0 32px 0;\">Improve security with flexible deployment options.<br>Enterprise-grade governance for your APIs and AI stack.</p>\n  <div style=\"display: flex; align-items: center; gap: 16px; flex-wrap: wrap;\">\n    <button style=\"font-family: var(--font-inter); font-size: 16px; font-weight: 600; color: var(--color-canvas-white); background: var(--color-plasma-teal-gradient); border: none; border-radius: 6px; padding: 14px 28px; cursor: pointer; line-height: 1.5; transition: box-shadow 0.2s ease;\">Try it for free</button>\n    <button style=\"font-family: var(--font-inter); font-size: 16px; font-weight: 600; color: var(--color-midnight-ink); background: var(--color-cloud-gray); border: 1px solid var(--color-cloud-border); border-radius: 6px; padding: 14px 28px; cursor: pointer; line-height: 1.5;\">Contact Sales</button>\n  </div>\n  <p style=\"font-family: var(--font-inter); font-size: 14px; font-weight: 400; color: var(--color-slate-text); line-height: 1.5; margin: 16px 0 0 0;\">Try for free for 60 days, no credit card required.</p>\n  <div style=\"display: flex; align-items: center; gap: 10px; margin-top: 20px; cursor: pointer;\">\n    <div style=\"width: 32px; height: 32px; border-radius: 50%; background: var(--color-cloud-gray); border: 1px solid var(--color-cloud-border); display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\n      <svg width=\"10\" height=\"12\" viewBox=\"0 0 10 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M1 1L9 6L1 11V1Z\" fill=\"var(--color-midnight-ink)\"/></svg>\n    </div>\n    <span style=\"font-family: var(--font-inter); font-size: 14px; font-weight: 500; color: var(--color-midnight-ink); line-height: 1.5;\">See how our platform works</span>\n  </div>\n</div>",
          "name": "CTA Button Group",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-midnight-ink: #1b1b1b;\n    --color-canvas-white: #ffffff;\n    --color-plasma-teal-gradient: linear-gradient(89.97deg, rgb(25, 160, 95) 0.02%, rgb(13, 127, 140) 123.85%);\n    --font-inter: 'Inter', system-ui, sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n</style>\n<div style=\"width: 100%; max-width: 600px; margin: 0 auto; box-sizing: border-box; font-family: var(--font-inter);\">\n  <div style=\"width: 100%; background: var(--color-plasma-teal-gradient); padding: 10px 24px; box-sizing: border-box; display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap;\">\n    <span style=\"font-family: var(--font-inter); font-size: 14px; font-weight: 400; color: var(--color-canvas-white); line-height: 1.5; text-align: center;\">\n      Grafbase has been acquired by The Guild!\n    </span>\n    <a href=\"#\" style=\"font-family: var(--font-inter); font-size: 14px; font-weight: 600; color: var(--color-canvas-white); line-height: 1.5; text-decoration: underline; white-space: nowrap;\">Read the announcement →</a>\n  </div>\n  <div style=\"background: var(--color-canvas-white); padding: 32px 40px; box-sizing: border-box;\">\n    <p style=\"font-family: var(--font-inter); font-size: 14px; color: #60646c; line-height: 1.5; margin: 0 0 8px 0;\">Example of the site-wide announcement banner used across Grafbase pages. The teal gradient draws immediate attention to critical news and updates.</p>\n    <div style=\"display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px;\">\n      <div style=\"background: #f0faf5; border: 1px solid #c2e8d6; border-radius: 6px; padding: 8px 14px;\">\n        <span style=\"font-family: var(--font-inter); font-size: 13px; font-weight: 500; color: rgb(25,160,95);\">Acquisition News</span>\n      </div>\n      <div style=\"background: #f0faf5; border: 1px solid #c2e8d6; border-radius: 6px; padding: 8px 14px;\">\n        <span style=\"font-family: var(--font-inter); font-size: 13px; font-weight: 500; color: rgb(13,127,140);\">The Guild Partnership</span>\n      </div>\n      <div style=\"background: #f0faf5; border: 1px solid #c2e8d6; border-radius: 6px; padding: 8px 14px;\">\n        <span style=\"font-family: var(--font-inter); font-size: 13px; font-weight: 500; color: rgb(25,160,95);\">Platform Update</span>\n      </div>\n    </div>\n  </div>\n</div>",
