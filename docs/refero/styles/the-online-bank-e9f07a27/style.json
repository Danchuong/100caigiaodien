        {
          "html": "<div style=\"--color-arctic-white:#ffffff;--color-deep-teal:#088177;--color-ink-black:#1b1b1b;--color-horizon-gray:#e9e9e9;--color-slate-gray:#6d6d6d;--color-accent-teal:#06736a;--font-n26:'Open Sans',sans-serif;--font-n26-extended:'Montserrat',sans-serif;box-sizing:border-box;background:var(--color-deep-teal);padding:80px 40px;font-family:var(--font-n26);width:100%;text-align:center;\">\n  <h1 style=\"font-family:var(--font-n26-extended);font-size:58px;font-weight:400;color:var(--color-arctic-white);line-height:1.10;margin:0 0 24px 0;letter-spacing:normal;\">The first bank<br>you'll love</h1>\n  <p style=\"font-family:var(--font-n26);font-size:18px;font-weight:400;color:var(--color-arctic-white);line-height:1.50;letter-spacing:-0.34px;margin:0 0 40px 0;opacity:0.92;\">Bank, save, and invest in one beautifully simple app trusted by millions.</p>\n  <a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-arctic-white);border:1.5px solid var(--color-arctic-white);border-radius:6px;padding:12px 24px;font-family:var(--font-n26);font-size:16px;font-weight:400;letter-spacing:-0.25px;text-decoration:none;line-height:1.43;cursor:pointer;\">Open free bank account</a>\n</div>",
