      "components": [
        {
          "html": "<div style=\"--color-arctic-white:#ffffff;--color-deep-teal:#088177;--color-ink-black:#1b1b1b;--color-horizon-gray:#e9e9e9;--color-slate-gray:#6d6d6d;--color-accent-teal:#06736a;--font-n26:'Open Sans',sans-serif;--font-n26-extended:'Montserrat',sans-serif;box-sizing:border-box;background:var(--color-arctic-white);padding:24px;font-family:var(--font-n26);width:100%;\">\n  <div style=\"display:flex;gap:16px;width:100%;\">\n    <!-- Card 1 -->\n    <div style=\"flex:1;border:1px solid var(--color-horizon-gray);border-radius:4px;padding:16px;background:var(--color-arctic-white);\">\n      <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-ink-black);letter-spacing:-0.18px;margin-bottom:16px;line-height:1.43;\">Risk indicator for all N26 accounts.</div>\n      <div style=\"display:flex;gap:0;\">\n        <div style=\"flex:1;padding-right:16px;border-right:1px solid var(--color-horizon-gray);\">\n          <div style=\"font-family:var(--font-n26-extended);font-size:44px;font-weight:400;color:var(--color-ink-black);line-height:1.10;margin-bottom:12px;\">1<span style=\"font-size:24px;color:var(--color-slate-gray);font-family:var(--font-n26-extended);\">/6</span></div>\n          <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-slate-gray);line-height:1.43;letter-spacing:-0.18px;\">This number is indicative of the risk of the product, 1/6 being indicative of lower risk and 6/6 of higher risk.</div>\n        </div>\n        <div style=\"flex:1;padding-left:16px;\">\n          <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-slate-gray);line-height:1.43;letter-spacing:-0.18px;\">N26 is a member of the German Deposit Guarantee Fund. The fund guarantees deposits up to 100,000 euros per account holder and entity.</div>\n        </div>\n      </div>\n    </div>\n    <!-- Card 2 -->\n    <div style=\"flex:1;border:1px solid var(--color-horizon-gray);border-radius:4px;padding:16px;background:var(--color-arctic-white);\">\n      <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-ink-black);letter-spacing:-0.18px;margin-bottom:16px;line-height:1.43;\">RISK INDICATOR corresponding to the securities product offered by Upvest Securities GmbH</div>\n      <div style=\"display:flex;gap:0;\">\n        <div style=\"flex:1;padding-right:16px;border-right:1px solid var(--color-horizon-gray);\">\n          <div style=\"font-family:var(--font-n26-extended);font-size:44px;font-weight:400;color:var(--color-deep-teal);line-height:1.10;margin-bottom:12px;\">6<span style=\"font-size:24px;color:var(--color-slate-gray);font-family:var(--font-n26-extended);\">/6</span></div>\n          <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-slate-gray);line-height:1.43;letter-spacing:-0.18px;\">This number is indicative of the risk of the product, with 1/6 indicating lower risk and 6/6 indicating higher risk.</div>\n        </div>\n        <div style=\"flex:1;padding-left:16px;\">\n          <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-slate-gray);line-height:1.43;letter-spacing:-0.18px;\">The execution, administration and custody product of Equities and ETFs offered by Upvest in free provision of community services has the following Risk Indicator in accordance with the provisions of Order ECC/2316/2015: 6/6</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
