        {
          "html": "<div style=\"--color-arctic-white:#ffffff;--color-deep-teal:#088177;--color-ink-black:#1b1b1b;--color-horizon-gray:#e9e9e9;--color-slate-gray:#6d6d6d;--color-accent-teal:#06736a;--font-n26:'Open Sans',sans-serif;--font-n26-extended:'Montserrat',sans-serif;box-sizing:border-box;background:var(--color-arctic-white);padding:40px;font-family:var(--font-n26);width:100%;\">\n  <div style=\"font-family:var(--font-n26-extended);font-size:18px;font-weight:500;color:var(--color-ink-black);margin-bottom:8px;letter-spacing:normal;\">Get started with N26</div>\n  <div style=\"font-family:var(--font-n26);font-size:14px;color:var(--color-slate-gray);margin-bottom:32px;line-height:1.43;letter-spacing:-0.14px;\">Choose the option that works best for you.</div>\n  <div style=\"display:flex;flex-wrap:wrap;gap:12px;align-items:center;\">\n    <!-- Primary CTA -->\n    <a href=\"#\" style=\"display:inline-block;background:var(--color-deep-teal);color:var(--color-arctic-white);border:1.5px solid var(--color-deep-teal);border-radius:6px;padding:12px 24px;font-family:var(--font-n26);font-size:16px;font-weight:400;letter-spacing:-0.25px;text-decoration:none;line-height:1.43;cursor:pointer;\">Open free bank account</a>\n    <!-- Secondary Outlined -->\n    <a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-deep-teal);border:1.5px solid var(--color-deep-teal);border-radius:6px;padding:12px 24px;font-family:var(--font-n26);font-size:16px;font-weight:400;letter-spacing:-0.25px;text-decoration:none;line-height:1.43;cursor:pointer;\">Log in</a>\n    <!-- Ghost / Nav link -->\n    <a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-ink-black);border:none;border-radius:8px;padding:4px 8px;font-family:var(--font-n26);font-size:16px;font-weight:400;letter-spacing:-0.25px;text-decoration:none;line-height:1.43;cursor:pointer;\">Learn more</a>\n  </div>\n  <div style=\"margin-top:32px;padding-top:24px;border-top:1px solid var(--color-horizon-gray);\">\n    <div style=\"font-family:var(--font-n26);font-size:11px;color:var(--color-slate-gray);letter-spacing:-0.18px;line-height:1.43;\">By continuing, you agree to N26's <a href=\"#\" style=\"color:var(--color-deep-teal);text-decoration:underline;\">Terms &amp; Conditions</a> and <a href=\"#\" style=\"color:var(--color-deep-teal);text-decoration:underline;\">Privacy Policy</a>.</div>\n  </div>\n</div>",
