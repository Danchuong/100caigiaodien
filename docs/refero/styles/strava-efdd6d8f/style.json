          "html": "<style>\n  :root {\n    --color-midnight-ink: #000000;\n    --color-cloudburst-gray: #43423f;\n    --color-ash-charcoal: #21211f;\n    --color-whisper-white: #ffffff;\n    --color-summit-cream: #f9f8f5;\n    --color-pebble-gray: #e0e0de;\n    --color-strava-orange: #fc5200;\n    --color-link-blue: #0060d0;\n    --font-boathouse: 'Inter', sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n</style>\n<div style=\"width:600px;background:var(--color-whisper-white);font-family:var(--font-boathouse);padding:48px 40px;box-sizing:border-box;\">\n  <h1 style=\"font-family:var(--font-boathouse);font-size:32px;font-weight:600;line-height:1.2;color:var(--color-midnight-ink);text-align:center;margin:0 0 16px 0;\">Community-Powered<br>Motivation</h1>\n  <p style=\"font-family:var(--font-boathouse);font-size:15px;font-weight:400;line-height:1.5;color:var(--color-cloudburst-gray);text-align:center;margin:0 0 24px 0;\">Track your progress and cheer each other on. Join over 100 million active people on Strava for free.</p>\n  <p style=\"font-family:var(--font-boathouse);font-size:15px;font-weight:400;line-height:1.5;color:var(--color-cloudburst-gray);text-align:center;margin:0 0 20px 0;\">Already a Member? <a href=\"#\" style=\"color:var(--color-strava-orange);font-weight:600;text-decoration:none;\">Log In</a></p>\n\n  <!-- Sign Up With Google -->\n  <button style=\"display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:12px 50px;background:var(--color-whisper-white);border:1.5px solid var(--color-pebble-gray);border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-ash-charcoal);cursor:pointer;margin-bottom:12px;box-sizing:border-box;\">\n    <svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z\" fill=\"#4285F4\"/>\n      <path d=\"M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z\" fill=\"#34A853\"/>\n      <path d=\"M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z\" fill=\"#FBBC05\"/>\n      <path d=\"M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z\" fill=\"#EA4335\"/>\n    </svg>\n    Sign Up With Google\n  </button>\n\n  <!-- Sign Up With Apple -->\n  <button style=\"display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:12px 50px;background:var(--color-whisper-white);border:1.5px solid var(--color-pebble-gray);border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-ash-charcoal);cursor:pointer;margin-bottom:16px;box-sizing:border-box;\">\n    <svg width=\"16\" height=\"20\" viewBox=\"0 0 16 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M13.173 10.625c-.022-2.56 2.09-3.796 2.187-3.858-1.19-1.743-3.045-1.981-3.704-2.006-1.572-.16-3.073.928-3.872.928-.798 0-2.025-.907-3.33-.882-1.712.025-3.294 1.001-4.174 2.535C.428 10.22 1.683 15.28 3.408 18.032c.857 1.353 1.877 2.87 3.216 2.818 1.295-.052 1.782-.833 3.345-.833 1.563 0 2.006.833 3.373.807 1.394-.025 2.271-1.376 3.117-2.734.985-1.565 1.39-3.082 1.41-3.16-.03-.013-2.72-1.044-2.696-4.305zM10.693 3.053C11.39 2.197 11.866.994 11.73 0c-.986.041-2.18.657-2.89 1.496-.635.736-1.19 1.912-1.04 3.04 1.1.085 2.225-.558 2.893-1.483z\" fill=\"#000000\"/>\n    </svg>\n    Sign Up With Apple\n  </button>\n\n  <!-- Sign Up With Email -->\n  <button style=\"display:flex;align-items:center;justify-content:center;width:100%;padding:14px 50px;background:var(--color-strava-orange);border:none;border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-whisper-white);cursor:pointer;margin-bottom:20px;box-sizing:border-box;\">Sign Up With Email</button>\n\n  <p style=\"font-family:var(--font-boathouse);font-size:12px;font-weight:400;line-height:1.5;color:var(--color-cloudburst-gray);text-align:center;margin:0;\">By continuing, you are agreeing to our <a href=\"#\" style=\"color:var(--color-link-blue);text-decoration:none;\">Terms of Service</a> and <a href=\"#\" style=\"color:var(--color-link-blue);text-decoration:none;\">Privacy Policy</a>.</p>\n</div>",
