          "html": "<style>\n  :root {\n    --color-midnight-ink: #000000;\n    --color-cloudburst-gray: #43423f;\n    --color-ash-charcoal: #21211f;\n    --color-whisper-white: #ffffff;\n    --color-summit-cream: #f9f8f5;\n    --color-pebble-gray: #e0e0de;\n    --color-strava-orange: #fc5200;\n    --color-link-blue: #0060d0;\n    --font-boathouse: 'Inter', sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n</style>\n<div style=\"width:600px;background:var(--color-summit-cream);font-family:var(--font-boathouse);padding:40px;box-sizing:border-box;\">\n  <p style=\"font-family:var(--font-boathouse);font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-cloudburst-gray);margin:0 0 24px 0;\">Button Styles</p>\n\n  <!-- Primary CTA -->\n  <div style=\"margin-bottom:20px;\">\n    <p style=\"font-family:var(--font-boathouse);font-size:12px;color:var(--color-cloudburst-gray);margin:0 0 8px 0;\">Primary CTA</p>\n    <button style=\"display:inline-flex;align-items:center;justify-content:center;padding:12px 40px;background:var(--color-strava-orange);border:none;border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-whisper-white);cursor:pointer;\">Get Started for Free</button>\n  </div>\n\n  <!-- Social Outline Button -->\n  <div style=\"margin-bottom:20px;\">\n    <p style=\"font-family:var(--font-boathouse);font-size:12px;color:var(--color-cloudburst-gray);margin:0 0 8px 0;\">Social / Outline</p>\n    <button style=\"display:inline-flex;align-items:center;justify-content:center;gap:10px;padding:12px 32px;background:var(--color-whisper-white);border:1.5px solid var(--color-pebble-gray);border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-ash-charcoal);cursor:pointer;\">\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\">\n        <path d=\"M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908C16.618 14.075 17.64 11.775 17.64 9.2z\" fill=\"#4285F4\"/>\n        <path d=\"M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z\" fill=\"#34A853\"/>\n        <path d=\"M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z\" fill=\"#FBBC05\"/>\n        <path d=\"M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z\" fill=\"#EA4335\"/>\n      </svg>\n      Sign Up With Google\n    </button>\n  </div>\n\n  <!-- Ghost / Nav Button -->\n  <div style=\"margin-bottom:20px;\">\n    <p style=\"font-family:var(--font-boathouse);font-size:12px;color:var(--color-cloudburst-gray);margin:0 0 8px 0;\">Ghost / Navigation</p>\n    <button style=\"display:inline-flex;align-items:center;gap:6px;padding:10px 16px;background:transparent;border:1.5px solid var(--color-midnight-ink);border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-midnight-ink);cursor:pointer;\">Log In</button>\n  </div>\n\n  <!-- Orange Text Link -->\n  <div>\n    <p style=\"font-family:var(--font-boathouse);font-size:12px;color:var(--color-cloudburst-gray);margin:0 0 8px 0;\">Link / Inline</p>\n    <a href=\"#\" style=\"font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-strava-orange);text-decoration:none;\">Log In →</a>\n  </div>\n</div>",
