        {
          "html": "<style>\n  :root {\n    --color-midnight-ink: #000000;\n    --color-cloudburst-gray: #43423f;\n    --color-ash-charcoal: #21211f;\n    --color-whisper-white: #ffffff;\n    --color-summit-cream: #f9f8f5;\n    --color-pebble-gray: #e0e0de;\n    --color-strava-orange: #fc5200;\n    --color-link-blue: #0060d0;\n    --font-boathouse: 'Inter', sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n</style>\n<div style=\"width:600px;background:var(--color-whisper-white);font-family:var(--font-boathouse);padding:40px;box-sizing:border-box;\">\n  <p style=\"font-family:var(--font-boathouse);font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-strava-orange);margin:0 0 8px 0;\">Why Strava</p>\n  <h2 style=\"font-family:var(--font-boathouse);font-size:32px;font-weight:600;line-height:1.2;color:var(--color-midnight-ink);margin:0 0 32px 0;\">Track every move.<br>Celebrate every win.</h2>\n\n  <div style=\"display:flex;gap:0;border-top:1.5px solid var(--color-pebble-gray);\">\n    <!-- Stat 1 -->\n    <div style=\"flex:1;padding:24px 24px 24px 0;border-right:1.5px solid var(--color-pebble-gray);\">\n      <div style=\"font-family:var(--font-boathouse);font-size:32px;font-weight:600;color:var(--color-strava-orange);line-height:1.2;margin-bottom:6px;\">100M+</div>\n      <div style=\"font-family:var(--font-boathouse);font-size:14px;font-weight:400;line-height:1.33;color:var(--color-cloudburst-gray);\">Active athletes worldwide</div>\n    </div>\n    <!-- Stat 2 -->\n    <div style=\"flex:1;padding:24px 24px 24px 24px;border-right:1.5px solid var(--color-pebble-gray);\">\n      <div style=\"font-family:var(--font-boathouse);font-size:32px;font-weight:600;color:var(--color-strava-orange);line-height:1.2;margin-bottom:6px;\">2B+</div>\n      <div style=\"font-family:var(--font-boathouse);font-size:14px;font-weight:400;line-height:1.33;color:var(--color-cloudburst-gray);\">Activities uploaded per year</div>\n    </div>\n    <!-- Stat 3 -->\n    <div style=\"flex:1;padding:24px 0 24px 24px;\">\n      <div style=\"font-family:var(--font-boathouse);font-size:32px;font-weight:600;color:var(--color-strava-orange);line-height:1.2;margin-bottom:6px;\">195+</div>\n      <div style=\"font-family:var(--font-boathouse);font-size:14px;font-weight:400;line-height:1.33;color:var(--color-cloudburst-gray);\">Countries represented</div>\n    </div>\n  </div>\n\n  <div style=\"margin-top:32px;padding:24px;background:var(--color-summit-cream);border-radius:4px;\">\n    <div style=\"display:flex;align-items:flex-start;gap:16px;\">\n      <div style=\"width:40px;height:40px;border-radius:4px;background:var(--color-strava-orange);flex-shrink:0;display:flex;align-items:center;justify-content:center;\">\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\">\n          <path d=\"M10 2L12.5 7.5L18 8.3L14 12.2L15 17.7L10 15L5 17.7L6 12.2L2 8.3L7.5 7.5L10 2Z\" fill=\"white\"/>\n        </svg>\n      </div>\n      <div>\n        <div style=\"font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-midnight-ink);margin-bottom:4px;\">Segments & Leaderboards</div>\n        <div style=\"font-family:var(--font-boathouse);font-size:14px;font-weight:400;line-height:1.5;color:var(--color-cloudburst-gray);\">Compete on iconic routes and see how you stack up against athletes around the world. Push your limits every ride, run, or hike.</div>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"margin-top:24px;display:flex;align-items:center;gap:16px;\">\n    <button style=\"padding:12px 32px;background:var(--color-strava-orange);border:none;border-radius:4px;font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-whisper-white);cursor:pointer;\">Join for Free</button>\n    <a href=\"#\" style=\"font-family:var(--font-boathouse);font-size:15px;font-weight:600;color:var(--color-midnight-ink);text-decoration:none;display:flex;align-items:center;gap:4px;\">Learn More <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12M8 3l5 4-5 4\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></a>\n  </div>\n</div>",
