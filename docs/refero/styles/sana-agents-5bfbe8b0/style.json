          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap');\n\n  :root {\n    --color-tarmac: #0a1217;\n    --color-canvas-white: #ffffff;\n    --color-cloud-gray: #85898b;\n    --color-steel-gray: #6c7174;\n    --color-jet-black: #000000;\n    --font-sana-sans: 'Inter', sans-serif;\n  }\n\n  .signup-form-wrapper {\n    background: var(--color-tarmac);\n    border-radius: 24px;\n    padding: 40px 32px;\n    max-width: 560px;\n    box-sizing: border-box;\n    font-family: var(--font-sana-sans);\n    margin: 0 auto;\n  }\n\n  .signup-title {\n    font-family: var(--font-sana-sans);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-canvas-white);\n    text-align: center;\n    margin: 0 0 24px 0;\n    line-height: 1.5;\n  }\n\n  .google-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    width: 100%;\n    background: var(--color-canvas-white);\n    color: var(--color-jet-black);\n    border: none;\n    border-radius: 9999px;\n    padding: 12px 18px;\n    font-family: var(--font-sana-sans);\n    font-size: 14px;\n    font-weight: 500;\n    cursor: pointer;\n    box-sizing: border-box;\n    text-decoration: none;\n    line-height: 1.4;\n  }\n\n  .google-icon {\n    flex-shrink: 0;\n  }\n\n  .divider {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin: 16px 0;\n  }\n\n  .divider-line {\n    flex: 1;\n    height: 1px;\n    background: rgba(255,255,255,0.12);\n  }\n\n  .divider-text {\n    font-family: var(--font-sana-sans);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-cloud-gray);\n  }\n\n  .email-input {\n    width: 100%;\n    background: var(--color-canvas-white);\n    color: var(--color-jet-black);\n    border: 1px solid rgba(10,18,23,0.15);\n    border-radius: 24px;\n    padding: 12px 18px;\n    font-family: var(--font-sana-sans);\n    font-size: 14px;\n    font-weight: 400;\n    box-sizing: border-box;\n    outline: none;\n    margin-bottom: 10px;\n    line-height: 1.4;\n  }\n\n  .email-input::placeholder {\n    color: var(--color-cloud-gray);\n  }\n\n  .submit-btn {\n    width: 100%;\n    background: rgba(255,255,255,0.12);\n    color: rgba(255,255,255,0.45);\n    border: none;\n    border-radius: 9999px;\n    padding: 12px 18px;\n    font-family: var(--font-sana-sans);\n    font-size: 14px;\n    font-weight: 500;\n    cursor: pointer;\n    box-sizing: border-box;\n    line-height: 1.4;\n    margin-bottom: 20px;\n  }\n\n  .legal-text {\n    font-family: var(--font-sana-sans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-cloud-gray);\n    text-align: center;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .legal-text a {\n    color: var(--color-cloud-gray);\n    text-decoration: underline;\n  }\n</style>\n\n<div style='background:#f5f5f5;padding:32px;font-family:Inter,sans-serif;'>\n  <div class='signup-form-wrapper'>\n    <p class='signup-title'>Try for free with your work email</p>\n\n    <a href='#' class='google-btn'>\n      <svg class='google-icon' width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'>\n        <path d='M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z' fill='#4285F4'/>\n        <path d='M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z' fill='#34A853'/>\n        <path d='M3.964 10.706A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.038l3.007-2.332z' fill='#FBBC05'/>\n        <path d='M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z' fill='#EA4335'/>\n      </svg>\n      Continue with Google\n    </a>\n\n    <div class='divider'>\n      <div class='divider-line'></div>\n      <span class='divider-text'>or</span>\n      <div class='divider-line'></div>\n    </div>\n\n    <input class='email-input' type='email' placeholder='name@work-email.com' />\n    <button class='submit-btn'>Enter your work email</button>\n\n    <p class='legal-text'>\n      By signing up to a free account or Team workspace, you agree to the\n      <a href='#'>MSA</a>, <a href='#'>Product Terms</a>, <a href='#'>Policies</a>, <a href='#'>Privacy Notice</a>, and <a href='#'>Cookie Notice</a>.\n      By signing up to an Enterprise workspace, you agree to the <a href='#'>Policies</a>,\n      <a href='#'>Privacy Notice</a>, and <a href='#'>Cookie Notice</a>.\n    </p>\n  </div>\n</div>",
