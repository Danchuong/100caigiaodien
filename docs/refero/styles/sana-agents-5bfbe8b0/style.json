          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');\n\n  :root {\n    --color-tarmac: #0a1217;\n    --color-canvas-white: #ffffff;\n    --color-limestone: #e4eff7;\n    --color-bio-luminescent-green: #cdfe00;\n    --color-cloud-gray: #85898b;\n    --font-sana-sans: 'Inter', sans-serif;\n  }\n\n  .button-showcase {\n    background: var(--color-canvas-white);\n    padding: 40px 32px;\n    font-family: var(--font-sana-sans);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n\n  .showcase-label {\n    font-family: var(--font-sana-sans);\n    font-size: 11px;\n    font-weight: 500;\n    color: var(--color-cloud-gray);\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin: 0 0 14px 0;\n  }\n\n  .btn-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    margin-bottom: 32px;\n    align-items: center;\n  }\n\n  .btn-row:last-child {\n    margin-bottom: 0;\n  }\n\n  .btn-base {\n    font-family: var(--font-sana-sans);\n    font-size: 14px;\n    font-weight: 500;\n    border-radius: 9999px;\n    padding: 10px 20px;\n    cursor: pointer;\n    text-decoration: none;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    line-height: 1.2;\n    box-sizing: border-box;\n    transition: opacity 0.15s;\n  }\n\n  .btn-cta {\n    background: var(--color-bio-luminescent-green);\n    color: var(--color-tarmac);\n    border: none;\n    font-weight: 600;\n  }\n\n  .btn-primary {\n    background: var(--color-tarmac);\n    color: var(--color-canvas-white);\n    border: none;\n  }\n\n  .btn-secondary {\n    background: var(--color-canvas-white);\n    color: var(--color-tarmac);\n    border: 1px solid rgba(10,18,23,0.2);\n  }\n\n  .btn-ghost {\n    background: transparent;\n    color: var(--color-tarmac);\n    border: 1px solid rgba(10,18,23,0.2);\n  }\n\n  .btn-ghost-white {\n    background: transparent;\n    color: var(--color-canvas-white);\n    border: 1px solid rgba(255,255,255,0.35);\n  }\n\n  .btn-sm {\n    font-size: 13px;\n    padding: 7px 14px;\n  }\n\n  .dark-row-bg {\n    background: var(--color-tarmac);\n    border-radius: 16px;\n    padding: 20px 24px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    align-items: center;\n    margin-bottom: 0;\n  }\n\n  .divider-section {\n    width: 100%;\n    height: 1px;\n    background: rgba(10,18,23,0.08);\n    margin: 4px 0 28px 0;\n  }\n\n  .chevron {\n    display: inline-block;\n    width: 14px;\n    height: 14px;\n    flex-shrink: 0;\n  }\n</style>\n\n<div class='button-showcase'>\n  <p class='showcase-label'>Call to action</p>\n  <div class='btn-row'>\n    <a href='#' class='btn-base btn-cta'>\n      Book an intro\n      <svg class='chevron' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M5 3l4 4-4 4' stroke='#0a1217' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>\n    </a>\n    <a href='#' class='btn-base btn-primary'>Get started free</a>\n    <a href='#' class='btn-base btn-secondary'>Explore</a>\n  </div>\n\n  <div class='divider-section'></div>\n\n  <p class='showcase-label'>Secondary actions</p>\n  <div class='btn-row'>\n    <a href='#' class='btn-base btn-ghost'>Learn more</a>\n    <a href='#' class='btn-base btn-ghost btn-sm'>View all</a>\n    <a href='#' class='btn-base btn-secondary btn-sm'>\n      <svg viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg' style='width:14px;height:14px;flex-shrink:0;'><path d='M7 2v10M2 7h10' stroke='#0a1217' stroke-width='1.5' stroke-linecap='round'/></svg>\n      Add new\n    </a>\n    <a href='#' class='btn-base btn-ghost btn-sm'>See case studies</a>\n  </div>\n\n  <div class='divider-section'></div>\n\n  <p class='showcase-label'>Dark surface</p>\n  <div class='dark-row-bg'>\n    <a href='#' class='btn-base btn-cta'>Book an intro</a>\n    <a href='#' class='btn-base btn-ghost-white'>Explore Sana Learn</a>\n    <a href='#' class='btn-base btn-ghost-white btn-sm'>Sign in</a>\n  </div>\n</div>",
