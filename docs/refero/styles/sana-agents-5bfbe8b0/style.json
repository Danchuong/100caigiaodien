      "components": [
        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400&family=Inter:wght@400;500&display=swap');\n\n  :root {\n    --color-tarmac: #0a1217;\n    --color-canvas-white: #ffffff;\n    --color-limestone: #e4eff7;\n    --color-jet-black: #000000;\n    --color-cloud-gray: #85898b;\n    --color-steel-gray: #6c7174;\n    --color-bio-luminescent-green: #cdfe00;\n    --font-sana-serif: 'Playfair Display', serif;\n    --font-sana-sans: 'Inter', sans-serif;\n    --spacing-8: 8px;\n    --spacing-12: 12px;\n    --spacing-16: 16px;\n    --spacing-20: 20px;\n    --spacing-24: 24px;\n    --spacing-32: 32px;\n  }\n\n  .product-cards-wrapper {\n    background: var(--color-canvas-white);\n    padding: 32px 24px;\n    font-family: var(--font-sana-sans);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n\n  .section-label {\n    font-family: var(--font-sana-sans);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-tarmac);\n    margin-bottom: 16px;\n    letter-spacing: normal;\n  }\n\n  .cards-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n  }\n\n  .product-card {\n    border-radius: 24px;\n    overflow: hidden;\n    position: relative;\n    min-height: 260px;\n    display: flex;\n    flex-direction: column;\n    padding: 24px;\n    box-sizing: border-box;\n  }\n\n  .product-card--dark {\n    background: var(--color-tarmac);\n    color: var(--color-canvas-white);\n  }\n\n  .product-card--light {\n    background: var(--color-limestone);\n    color: var(--color-tarmac);\n  }\n\n  .card-title {\n    font-family: var(--font-sana-sans);\n    font-size: 16px;\n    font-weight: 500;\n    margin: 0 0 4px 0;\n    line-height: 1.2;\n  }\n\n  .card-title--dark { color: var(--color-canvas-white); }\n  .card-title--light { color: var(--color-tarmac); }\n\n  .card-subtitle {\n    font-family: var(--font-sana-sans);\n    font-size: 13px;\n    font-weight: 400;\n    margin: 0 0 20px 0;\n    line-height: 1.4;\n  }\n\n  .card-subtitle--dark { color: var(--color-cloud-gray); }\n  .card-subtitle--light { color: var(--color-steel-gray); }\n\n  .card-actions {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n\n  .btn {\n    font-family: var(--font-sana-sans);\n    font-size: 13px;\n    font-weight: 500;\n    border-radius: 9999px;\n    padding: 8px 16px;\n    cursor: pointer;\n    border: none;\n    text-decoration: none;\n    display: inline-block;\n    line-height: 1.2;\n    box-sizing: border-box;\n  }\n\n  .btn-outline-light {\n    background: transparent;\n    color: var(--color-canvas-white);\n    border: 1px solid rgba(255,255,255,0.4);\n  }\n\n  .btn-green {\n    background: var(--color-bio-luminescent-green);\n    color: var(--color-tarmac);\n    border: none;\n    font-weight: 600;\n  }\n\n  .btn-dark {\n    background: var(--color-tarmac);\n    color: var(--color-canvas-white);\n    border: none;\n  }\n\n  .btn-outline-dark {\n    background: transparent;\n    color: var(--color-tarmac);\n    border: 1px solid rgba(10,18,23,0.25);\n  }\n\n  .card-image-placeholder {\n    margin-top: auto;\n    border-radius: 12px;\n    width: 100%;\n    height: 80px;\n    background: rgba(255,255,255,0.08);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 16px;\n    overflow: hidden;\n  }\n\n  .card-image-placeholder--light {\n    background: rgba(10,18,23,0.07);\n  }\n\n  .chat-bubble {\n    background: var(--color-bio-luminescent-green);\n    color: var(--color-tarmac);\n    font-size: 10px;\n    font-family: var(--font-sana-sans);\n    padding: 6px 10px;\n    border-radius: 12px;\n    font-weight: 500;\n    max-width: 90%;\n    text-align: center;\n    line-height: 1.3;\n  }\n\n  .learn-bubble {\n    background: #4a3fd4;\n    color: #fff;\n    font-size: 10px;\n    font-family: var(--font-sana-sans);\n    padding: 6px 10px;\n    border-radius: 12px;\n    font-weight: 500;\n    max-width: 90%;\n    text-align: center;\n    line-height: 1.3;\n  }\n</style>\n\n<div class='product-cards-wrapper'>\n  <p class='section-label'>Our products</p>\n  <div class='cards-grid'>\n    <div class='product-card product-card--dark'>\n      <div>\n        <p class='card-title card-title--dark'>Sana Agents</p>\n        <p class='card-subtitle card-subtitle--dark'>AI agents for every team</p>\n        <div class='card-actions'>\n          <a href='#' class='btn btn-outline-light'>Explore</a>\n          <a href='#' class='btn btn-green'>Book an intro</a>\n        </div>\n      </div>\n      <div class='card-image-placeholder'>\n        <div class='chat-bubble'>Analyze today's sales activity and update our CRM with key insights</div>\n      </div>\n    </div>\n    <div class='product-card product-card--light'>\n      <div>\n        <p class='card-title card-title--light'>Sana Learn</p>\n        <p class='card-subtitle card-subtitle--light'>AI-native learning platform</p>\n        <div class='card-actions'>\n          <a href='#' class='btn btn-dark'>Explore</a>\n          <a href='#' class='btn btn-outline-dark'>Book an intro</a>\n        </div>\n      </div>\n      <div class='card-image-placeholder card-image-placeholder--light'>\n        <div class='learn-bubble'>String theory is a theoretical framework proposing that...</div>\n      </div>\n    </div>\n  </div>\n</div>",
