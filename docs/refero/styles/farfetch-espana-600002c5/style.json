          "description": ""
        },
        {
          "html": "<div style=\"--color-raven-black:#222222;--color-polar-white:#ffffff;--color-cloud-gray:#e6e6e6;--color-ash-gray:#b6b6b6;--color-ghost-white:#f5f5f5;--color-steel-gray:#727272;--font-farfetch-basis:system-ui,sans-serif;width:600px;box-sizing:border-box;background:var(--color-polar-white);padding:40px 0 48px;font-family:var(--font-farfetch-basis);\">\n  <h2 style=\"font-family:var(--font-farfetch-basis);font-size:22px;font-weight:400;color:var(--color-raven-black);text-align:center;margin:0 0 28px;line-height:1.27;\">Elige una sección</h2>\n  <div style=\"display:flex;gap:4px;padding:0 16px;\">\n    <!-- MUJER -->\n    <div style=\"flex:1;position:relative;overflow:hidden;cursor:pointer;\">\n      <div style=\"width:100%;height:220px;background:linear-gradient(160deg,#8a8070 0%,#6b6055 40%,#4a4038 100%);\"></div>\n      <div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:15px;font-weight:700;color:var(--color-polar-white);letter-spacing:0.08em;text-transform:uppercase;\">MUJER</span>\n      </div>\n    </div>\n    <!-- HOMBRE -->\n    <div style=\"flex:1;position:relative;overflow:hidden;cursor:pointer;\">\n      <div style=\"width:100%;height:220px;background:linear-gradient(160deg,#3a3a3a 0%,#1e1e1e 60%,#111 100%);\"></div>\n      <div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:15px;font-weight:700;color:var(--color-polar-white);letter-spacing:0.08em;text-transform:uppercase;\">HOMBRE</span>\n      </div>\n    </div>\n    <!-- INFANTIL -->\n    <div style=\"flex:1;position:relative;overflow:hidden;cursor:pointer;\">\n      <div style=\"width:100%;height:220px;background:linear-gradient(160deg,#b0bec5 0%,#90a4ae 40%,#607d8b 100%);\"></div>\n      <div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:15px;font-weight:700;color:var(--color-polar-white);letter-spacing:0.08em;text-transform:uppercase;\">INFANTIL</span>\n      </div>\n    </div>\n  </div>\n</div>",
