      "components": [
        {
          "html": "<div style=\"--color-raven-black:#222222;--color-polar-white:#ffffff;--color-cloud-gray:#e6e6e6;--color-ash-gray:#b6b6b6;--color-ghost-white:#f5f5f5;--color-steel-gray:#727272;--font-farfetch-basis:system-ui,sans-serif;width:600px;box-sizing:border-box;font-family:var(--font-farfetch-basis);\">\n  <!-- Announcement Banner -->\n  <div style=\"background-color:var(--color-cloud-gray);padding:10px 16px;text-align:center;\">\n    <span style=\"font-family:var(--font-farfetch-basis);font-size:13px;font-weight:400;color:var(--color-raven-black);line-height:1.33;\">Free shipping on orders over €300 | Plus free returns for 30 days</span>\n  </div>\n  <!-- Search Bar -->\n  <div style=\"background-color:var(--color-polar-white);padding:16px 24px;display:flex;align-items:center;border-bottom:1px solid var(--color-cloud-gray);\">\n    <div style=\"display:flex;align-items:center;width:100%;border-bottom:1px solid var(--color-raven-black);padding-bottom:6px;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#222222\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"margin-right:10px;flex-shrink:0;\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><line x1=\"16.5\" y1=\"16.5\" x2=\"22\" y2=\"22\"/></svg>\n      <input type=\"text\" placeholder=\"Buscar piezas y marcas\" style=\"font-family:var(--font-farfetch-basis);font-size:15px;font-weight:400;color:var(--color-raven-black);background:transparent;border:none;outline:none;width:100%;line-height:1.31;\" />\n    </div>\n  </div>\n</div>",
          "name": "Announcement Banner + Search Bar",
