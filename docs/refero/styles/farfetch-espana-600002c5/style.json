        {
          "html": "<div style=\"--color-raven-black:#222222;--color-polar-white:#ffffff;--color-cloud-gray:#e6e6e6;--color-ash-gray:#b6b6b6;--color-ghost-white:#f5f5f5;--color-steel-gray:#727272;--font-farfetch-basis:system-ui,sans-serif;width:600px;box-sizing:border-box;background:var(--color-polar-white);padding:48px 16px;font-family:var(--font-farfetch-basis);\">\n  <h2 style=\"font-family:var(--font-farfetch-basis);font-size:22px;font-weight:400;color:var(--color-raven-black);text-align:center;margin:0 0 28px;line-height:1.27;\">Moda para mujer</h2>\n  <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:4px;\">\n    <!-- NOVEDADES -->\n    <div style=\"display:flex;flex-direction:column;gap:0;cursor:pointer;\">\n      <div style=\"width:100%;height:180px;background:linear-gradient(180deg,#9e9287 0%,#7b6f63 100%);\"></div>\n      <div style=\"padding:10px 0 0;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:13px;font-weight:700;color:var(--color-raven-black);line-height:1.33;text-transform:uppercase;display:block;\">NOVEDADES</span>\n      </div>\n    </div>\n    <!-- ROPA -->\n    <div style=\"display:flex;flex-direction:column;gap:0;cursor:pointer;\">\n      <div style=\"width:100%;height:180px;background:linear-gradient(180deg,#7a3030 0%,#5a2020 100%);\"></div>\n      <div style=\"padding:10px 0 0;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:13px;font-weight:700;color:var(--color-raven-black);line-height:1.33;text-transform:uppercase;display:block;\">ROPA</span>\n      </div>\n    </div>\n    <!-- BOLSOS -->\n    <div style=\"display:flex;flex-direction:column;gap:0;cursor:pointer;\">\n      <div style=\"width:100%;height:180px;background:linear-gradient(180deg,#c4b5a0 0%,#a89680 100%);\"></div>\n      <div style=\"padding:10px 0 0;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:13px;font-weight:700;color:var(--color-raven-black);line-height:1.33;text-transform:uppercase;display:block;\">BOLSOS</span>\n      </div>\n    </div>\n    <!-- ZAPATOS -->\n    <div style=\"display:flex;flex-direction:column;gap:0;cursor:pointer;\">\n      <div style=\"width:100%;height:180px;background:linear-gradient(180deg,#b0a898 0%,#8a8070 100%);\"></div>\n      <div style=\"padding:10px 0 0;\">\n        <span style=\"font-family:var(--font-farfetch-basis);font-size:13px;font-weight:700;color:var(--color-raven-black);line-height:1.33;text-transform:uppercase;display:block;\">ZAPATOS</span>\n      </div>\n    </div>\n  </div>\n</div>",
