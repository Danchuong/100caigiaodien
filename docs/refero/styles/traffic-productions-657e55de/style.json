      "components": [
        {
          "html": "<div style=\"--color-midnight-ink:#151515;--color-canvas-white:#f3f3f3;--color-highlight-yellow:#fff824;--color-pure-black:#000000;--color-faded-gray:#e5e5e5;--font-suisse:'Arial Narrow',Arial,sans-serif;width:600px;box-sizing:border-box;font-family:var(--font-suisse);\">\n  <div style=\"background:var(--color-highlight-yellow);display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border:1px solid var(--color-midnight-ink);box-sizing:border-box;\">\n    <span style=\"font-family:var(--font-suisse);font-size:18px;font-weight:700;color:var(--color-midnight-ink);letter-spacing:-0.01em;text-transform:uppercase;\">COOKIES</span>\n    <button style=\"background:none;border:none;cursor:pointer;padding:4px 8px;font-family:var(--font-suisse);font-size:18px;font-weight:700;color:var(--color-midnight-ink);line-height:1;\">✕</button>\n  </div>\n  <div style=\"background:var(--color-canvas-white);border:1px solid var(--color-midnight-ink);border-top:none;padding:18px 12px;box-sizing:border-box;\">\n    <p style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.01em;line-height:1.17;margin:0 0 18px 0;\">We use cookies to ensure you get the best experience on our website. By continuing to use this site you accept our use of cookies.</p>\n    <div style=\"display:flex;gap:12px;align-items:center;\">\n      <a href=\"#\" style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);text-decoration:underline;letter-spacing:-0.01em;\">PRIVACY POLICY</a>\n      <button style=\"background:var(--color-midnight-ink);color:var(--color-canvas-white);font-family:var(--font-suisse);font-size:18px;font-weight:700;letter-spacing:-0.01em;border:none;border-radius:9999px;padding:8px 24px;cursor:pointer;\">ACCEPT</button>\n    </div>\n  </div>\n</div>",
          "name": "Cookie Bar",
          "role": "",
          "description": ""
        },
        {
          "html": "<div style=\"--color-midnight-ink:#151515;--color-canvas-white:#f3f3f3;--color-highlight-yellow:#fff824;--color-pure-black:#000000;--color-faded-gray:#e5e5e5;--font-suisse:'Arial Narrow',Arial,sans-serif;width:600px;box-sizing:border-box;background:var(--color-canvas-white);font-family:var(--font-suisse);padding:40px 24px 48px 24px;border-top:2px solid var(--color-midnight-ink);\">\n  <div style=\"margin-bottom:4px;\">\n    <div style=\"width:100%;height:3px;background:var(--color-highlight-yellow);margin-bottom:2px;\"></div>\n    <div style=\"width:100%;height:1px;background:var(--color-midnight-ink);\"></div>\n  </div>\n  <h2 style=\"font-family:var(--font-suisse);font-size:54px;font-weight:700;color:var(--color-midnight-ink);letter-spacing:-0.03em;line-height:0.93;margin:28px 0 32px 0;text-transform:none;\">A non-agency offer for Brands, Agencies, Marketers, Creatives and Procurement focusing on delivering performance at scale.</h2>\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px;\">\n    <p style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.01em;line-height:1.17;margin:0;\">Independent in thinking, but seamlessly integrated in our clients' ecosystem to deliver sustainable growth.</p>\n    <p style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.01em;line-height:1.17;margin:0;\">Radically service-oriented and without ego, but always with a clear vision.</p>\n  </div>\n  <a href=\"#\" style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);text-decoration:underline;letter-spacing:-0.01em;\">MORE ABOUT US</a>\n</div>",
          "name": "About Section — Non-Agency Offer",
          "role": "",
          "description": ""
        },
        {
          "html": "<div style=\"--color-midnight-ink:#151515;--color-canvas-white:#f3f3f3;--color-highlight-yellow:#fff824;--color-pure-black:#000000;--color-faded-gray:#e5e5e5;--font-suisse:'Arial Narrow',Arial,sans-serif;width:600px;box-sizing:border-box;background:var(--color-canvas-white);font-family:var(--font-suisse);border:1px solid var(--color-midnight-ink);\">\n  <div style=\"display:flex;align-items:stretch;border-bottom:1px solid var(--color-midnight-ink);\">\n    <div style=\"padding:9px 12px;border-right:1px solid var(--color-midnight-ink);min-width:60px;\">\n      <span style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.01em;\">A)</span>\n    </div>\n    <div style=\"padding:9px 12px;flex:1;\">\n      <span style=\"font-family:var(--font-suisse);font-size:18px;font-weight:700;color:var(--color-midnight-ink);letter-spacing:-0.01em;text-decoration:underline;\">HOUSE OF SCHWARZKOPF</span>\n    </div>\n  </div>\n  <div style=\"display:flex;flex-direction:row;\">\n    <div style=\"flex:1;padding:20px 12px;border-right:1px solid var(--color-midnight-ink);display:flex;flex-direction:column;justify-content:space-between;\">\n      <div>\n        <p style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.01em;line-height:1.17;margin:0 0 20px 0;\">Brand activation campaign spanning physical events and digital content strategy across Europe.</p>\n        <div style=\"display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px;\">\n          <span style=\"font-family:var(--font-suisse);font-size:12px;font-weight:700;color:var(--color-midnight-ink);border:1px solid var(--color-midnight-ink);padding:4px 9px;letter-spacing:0;text-transform:uppercase;\">BRAND</span>\n          <span style=\"font-family:var(--font-suisse);font-size:12px;font-weight:700;color:var(--color-midnight-ink);border:1px solid var(--color-midnight-ink);padding:4px 9px;letter-spacing:0;text-transform:uppercase;\">EVENTS</span>\n          <span style=\"font-family:var(--font-suisse);font-size:12px;font-weight:700;color:var(--color-midnight-ink);border:1px solid var(--color-midnight-ink);padding:4px 9px;letter-spacing:0;text-transform:uppercase;\">DIGITAL</span>\n        </div>\n      </div>\n      <a href=\"#\" style=\"font-family:var(--font-suisse);font-size:18px;font-weight:400;color:var(--color-midnight-ink);text-decoration:underline;letter-spacing:-0.01em;align-self:flex-start;\">VIEW PROJECT</a>\n    </div>\n    <div style=\"width:220px;flex-shrink:0;\">\n      <div style=\"width:100%;height:200px;background:#c8c8c8;display:flex;align-items:center;justify-content:center;\">\n        <div style=\"width:100%;height:100%;background:linear-gradient(135deg,#b0b0b0 0%,#d8d8d8 100%);\"></div>\n      </div>\n    </div>\n  </div>\n  <div style=\"border-top:1px solid var(--color-midnight-ink);background:var(--color-highlight-yellow);height:4px;\"></div>\n</div>",
