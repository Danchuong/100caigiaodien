      "components": [
        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');\n  :root {\n    --color-notebook-paper: #fffef6;\n    --color-ink-black: #000000;\n    --color-pure-white: #ffffff;\n    --color-pale-gray: #c6c6c6;\n    --color-sunrise-yellow: #fdcf85;\n    --color-blush-pink: #f8c8d8;\n    --font-margo-pro: 'Bebas Neue', sans-serif;\n    --shadow-subtle: rgb(0,0,0) 2px 2px 0px 0px;\n  }\n  .cards-wrapper {\n    background: var(--color-notebook-paper);\n    padding: 32px;\n    font-family: var(--font-margo-pro);\n  }\n  .cards-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n  }\n  .card {\n    background: transparent;\n    border: 1px solid var(--color-ink-black);\n    box-shadow: var(--shadow-subtle);\n    border-radius: 0px;\n    overflow: hidden;\n    cursor: pointer;\n  }\n  .card-image {\n    width: 100%;\n    height: 180px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    overflow: hidden;\n  }\n  .card-image.chai-bg {\n    background: #d4b99a;\n  }\n  .card-image.report-bg {\n    background: #c8a96e;\n  }\n  .card-image.oat-bg {\n    background: #b8c4b0;\n  }\n  .card-image.barista-bg {\n    background: #e8d5b0;\n  }\n  .card-image-text {\n    font-family: var(--font-margo-pro);\n    font-size: 32px;\n    color: var(--color-pure-white);\n    text-align: center;\n    line-height: 1.0;\n    text-transform: uppercase;\n    padding: 16px;\n  }\n  .card-footer {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 8px 11px;\n    border-top: 1px solid var(--color-ink-black);\n    background: var(--color-notebook-paper);\n  }\n  .card-title {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    color: var(--color-ink-black);\n    text-transform: uppercase;\n    letter-spacing: normal;\n    line-height: 1.2;\n  }\n  .badge {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    font-weight: 400;\n    text-transform: uppercase;\n    padding: 1.6px 8px;\n    border-radius: 0px;\n    color: var(--color-ink-black);\n    line-height: 1.2;\n    white-space: nowrap;\n  }\n  .badge-news {\n    background: var(--color-sunrise-yellow);\n  }\n  .badge-tastebuds {\n    background: var(--color-blush-pink);\n  }\n  .badge-health {\n    background: var(--color-pale-gray);\n  }\n  .badge-sustainability {\n    background: #b8d8b0;\n  }\n</style>\n<div class='cards-wrapper'>\n  <div class='cards-grid'>\n    <div class='card'>\n      <div class='card-image chai-bg'>\n        <div style='width:80px;height:80px;border-radius:50%;background:rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;'>\n          <div style='width:40px;height:60px;background:rgba(0,0,0,0.3);border-radius:4px 4px 8px 8px;'></div>\n        </div>\n      </div>\n      <div class='card-footer'>\n        <span class='card-title'>Ginger Nut Chai</span>\n        <span class='badge badge-tastebuds'>Tastebuds</span>\n      </div>\n    </div>\n    <div class='card'>\n      <div class='card-image report-bg'>\n        <div class='card-image-text'>The Future<br>of Taste<br>Report</div>\n      </div>\n      <div class='card-footer'>\n        <span class='card-title'>The Future of Taste</span>\n        <span class='badge badge-news'>News</span>\n      </div>\n    </div>\n    <div class='card'>\n      <div class='card-image oat-bg'>\n        <div style='width:100px;height:40px;background:rgba(0,0,0,0.2);border-radius:0px;display:flex;align-items:center;justify-content:center;'>\n          <span style='font-family:var(--font-margo-pro);font-size:18px;color:#fff;text-transform:uppercase;'>Oat Drink</span>\n        </div>\n      </div>\n      <div class='card-footer'>\n        <span class='card-title'>Oat Drink Original</span>\n        <span class='badge badge-health'>Health</span>\n      </div>\n    </div>\n    <div class='card'>\n      <div class='card-image barista-bg'>\n        <div style='text-align:center;padding:16px;'>\n          <div style='font-family:var(--font-margo-pro);font-size:24px;color:#3a2a1a;text-transform:uppercase;line-height:1.1;'>Barista<br>Edition</div>\n        </div>\n      </div>\n      <div class='card-footer'>\n        <span class='card-title'>Barista Edition</span>\n        <span class='badge badge-sustainability' style='background:#c8e6c0;'>Sustainability</span>\n      </div>\n    </div>\n  </div>\n</div>",
          "name": "Content Cards with Badges",
          "role": "",
          "description": ""
