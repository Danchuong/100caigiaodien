        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');\n  :root {\n    --color-notebook-paper: #fffef6;\n    --color-ink-black: #000000;\n    --color-pure-white: #ffffff;\n    --color-blush-pink: #f8c8d8;\n    --font-margo-pro: 'Bebas Neue', sans-serif;\n  }\n  .btn-group-wrapper {\n    background: var(--color-notebook-paper);\n    padding: 40px 32px;\n    font-family: var(--font-margo-pro);\n  }\n  .btn-group-label {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    color: var(--color-ink-black);\n    text-transform: uppercase;\n    margin-bottom: 24px;\n    letter-spacing: normal;\n    border-bottom: 1px solid var(--color-ink-black);\n    padding-bottom: 8px;\n  }\n  .btn-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 16px;\n    margin-bottom: 24px;\n    align-items: center;\n  }\n  .btn-row-label {\n    font-family: var(--font-margo-pro);\n    font-size: 12px;\n    color: var(--color-ink-black);\n    text-transform: uppercase;\n    opacity: 0.5;\n    width: 100%;\n    margin-bottom: -8px;\n  }\n  .btn-outline {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-ink-black);\n    background: transparent;\n    border: 1px solid var(--color-ink-black);\n    border-radius: 0px;\n    padding: 16px;\n    text-transform: uppercase;\n    cursor: pointer;\n    letter-spacing: normal;\n    line-height: 1.0;\n    display: inline-block;\n    text-decoration: none;\n  }\n  .btn-filled {\n    font-family: var(--font-margo-pro);\n    font-size: 20px;\n    font-weight: 400;\n    color: var(--color-pure-white);\n    background: var(--color-ink-black);\n    border: 1px solid var(--color-ink-black);\n    border-radius: 0px;\n    padding: 16px 24px;\n    text-transform: uppercase;\n    cursor: pointer;\n    letter-spacing: normal;\n    line-height: 1.0;\n    display: inline-block;\n    text-decoration: none;\n  }\n  .btn-pill {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-pure-white);\n    background: var(--color-ink-black);\n    border: 1px solid var(--color-ink-black);\n    border-radius: 9999px;\n    padding: 10px 24px;\n    text-transform: uppercase;\n    cursor: pointer;\n    letter-spacing: normal;\n    line-height: 1.2;\n    display: inline-block;\n    text-decoration: none;\n  }\n  .btn-pill-outline {\n    font-family: var(--font-margo-pro);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-ink-black);\n    background: transparent;\n    border: 1px solid var(--color-ink-black);\n    border-radius: 9999px;\n    padding: 10px 24px;\n    text-transform: uppercase;\n    cursor: pointer;\n    letter-spacing: normal;\n    line-height: 1.2;\n    display: inline-block;\n    text-decoration: none;\n  }\n  .read-more-link {\n    font-family: var(--font-margo-pro);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-ink-black);\n    text-decoration: none;\n    text-transform: uppercase;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    border-bottom: 2px solid var(--color-blush-pink);\n    padding-bottom: 2px;\n    letter-spacing: normal;\n  }\n</style>\n<div class='btn-group-wrapper'>\n  <div class='btn-group-label'>Button Variants</div>\n  <div class='btn-row'>\n    <span class='btn-row-label'>Outline</span>\n    <a href='#' class='btn-outline'>Read More</a>\n    <a href='#' class='btn-outline'>Learn More</a>\n    <a href='#' class='btn-outline'>Find a Store</a>\n  </div>\n  <div class='btn-row'>\n    <span class='btn-row-label'>Filled</span>\n    <a href='#' class='btn-filled'>Shop Now</a>\n    <a href='#' class='btn-filled'>View All Products</a>\n  </div>\n  <div class='btn-row'>\n    <span class='btn-row-label'>Pill</span>\n    <a href='#' class='btn-pill'>Subscribe</a>\n    <a href='#' class='btn-pill-outline'>Explore</a>\n    <a href='#' class='btn-pill'>Get Started</a>\n  </div>\n  <div class='btn-row'>\n    <span class='btn-row-label'>Text Link</span>\n    <a href='#' class='read-more-link'>Read More <svg width='16' height='10' viewBox='0 0 16 10' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M1 5H15M15 5L11 1M15 5L11 9' stroke='#000' stroke-width='1.5'/></svg></a>\n  </div>\n</div>",
