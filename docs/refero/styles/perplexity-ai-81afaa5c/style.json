      "components": [
        {
          "html": "<style>\n  :root {\n    --color-inkwell: #000000;\n    --color-paper-white: #FFFFFF;\n    --color-parchment: #FAF8F5;\n    --color-graphite: #27251E;\n    --color-faded-stone: #92918B;\n    --color-dusk-gray: #72706B;\n    --font-pplxsans: 'Inter', sans-serif;\n  }\n\n  .pplx-search-wrapper {\n    background: var(--color-paper-white);\n    padding: 24px 16px;\n    font-family: var(--font-pplxsans);\n    box-sizing: border-box;\n    width: 100%;\n    max-width: 600px;\n    margin: 0 auto;\n  }\n\n  .pplx-search-box {\n    background: var(--color-parchment);\n    border-radius: 8px;\n    padding: 16px 16px 12px 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    border: 1px solid rgba(39,37,30,0.08);\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .pplx-search-input {\n    background: transparent;\n    border: none;\n    outline: none;\n    font-family: var(--font-pplxsans);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-graphite);\n    line-height: 1.5;\n    width: 100%;\n    resize: none;\n    min-height: 48px;\n    caret-color: var(--color-inkwell);\n  }\n\n  .pplx-search-input::placeholder {\n    color: var(--color-dusk-gray);\n  }\n\n  .pplx-search-toolbar {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .pplx-toolbar-left {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n\n  .pplx-add-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    border-radius: 9999px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    color: var(--color-faded-stone);\n    padding: 0;\n    flex-shrink: 0;\n  }\n\n  .pplx-add-btn:hover {\n    background: rgba(39,37,30,0.06);\n  }\n\n  .pplx-pill-accent {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    background: var(--color-graphite);\n    color: #FDFBFA;\n    border-radius: 9999px;\n    padding: 4px 10px;\n    font-family: var(--font-pplxsans);\n    font-size: 14px;\n    font-weight: 400;\n    cursor: pointer;\n    border: none;\n    line-height: 1.43;\n    flex-shrink: 0;\n  }\n\n  .pplx-pill-accent svg {\n    opacity: 0.7;\n  }\n\n  .pplx-toolbar-right {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    flex-shrink: 0;\n  }\n\n  .pplx-model-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 4px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    font-family: var(--font-pplxsans);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-faded-stone);\n    padding: 0;\n    border-radius: 9999px;\n    line-height: 1.43;\n  }\n\n  .pplx-icon-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    border-radius: 9999px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    color: var(--color-faded-stone);\n    padding: 0;\n  }\n\n  .pplx-submit-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    border-radius: 9999px;\n    background: var(--color-inkwell);\n    border: none;\n    cursor: pointer;\n    padding: 0;\n    flex-shrink: 0;\n  }\n</style>\n\n<div class=\"pplx-search-wrapper\">\n  <div class=\"pplx-search-box\">\n    <textarea class=\"pplx-search-input\" placeholder=\"Type @ for connectors and sources\" rows=\"2\"></textarea>\n    <div class=\"pplx-search-toolbar\">\n      <div class=\"pplx-toolbar-left\">\n        <button class=\"pplx-add-btn\" aria-label=\"Add\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n            <path d=\"M8 3v10M3 8h10\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n          </svg>\n        </button>\n        <button class=\"pplx-pill-accent\">\n          <svg width=\"12\" height=\"12\" viewBox=\"0 0 16 16\" fill=\"none\">\n            <rect x=\"2\" y=\"2\" width=\"12\" height=\"12\" rx=\"2\" stroke=\"#FDFBFA\" stroke-width=\"1.5\"/>\n            <path d=\"M5 8h6M5 5.5h6M5 10.5h4\" stroke=\"#FDFBFA\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n          </svg>\n          Computer\n          <svg width=\"10\" height=\"10\" viewBox=\"0 0 12 12\" fill=\"none\">\n            <path d=\"M3 5l3 3 3-3\" stroke=\"#FDFBFA\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </button>\n      </div>\n      <div class=\"pplx-toolbar-right\">\n        <button class=\"pplx-model-btn\">\n          Model\n          <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\">\n            <path d=\"M2.5 4.5l3.5 3.5 3.5-3.5\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </button>\n        <button class=\"pplx-icon-btn\" aria-label=\"Microphone\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n            <rect x=\"5.5\" y=\"1.5\" width=\"5\" height=\"8\" rx=\"2.5\" stroke=\"currentColor\" stroke-width=\"1.3\"/>\n            <path d=\"M3 8.5a5 5 0 0010 0\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n            <path d=\"M8 13.5v2\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n          </svg>\n        </button>\n        <button class=\"pplx-submit-btn\" aria-label=\"Submit\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n            <path d=\"M3 8h10M9 4l4 4-4 4\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </button>\n      </div>\n    </div>\n  </div>\n</div>",
          "name": "Search Input Field",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-inkwell: #000000;\n    --color-paper-white: #FFFFFF;\n    --color-parchment: #FAF8F5;\n    --color-graphite: #27251E;\n    --color-faded-stone: #92918B;\n    --color-dusk-gray: #72706B;\n    --font-pplxsans: 'Inter', sans-serif;\n  }\n\n  .pplx-nav-wrapper {\n    background: var(--color-paper-white);\n    padding: 12px 8px;\n    font-family: var(--font-pplxsans);\n    width: 100%;\n    max-width: 220px;\n    box-sizing: border-box;\n    margin: 0 auto;\n  }\n\n  .pplx-nav-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 4px 12px;\n    border-radius: 8px;\n    font-size: 16px;\n    font-weight: 400;\n    line-height: 1.5;\n    cursor: pointer;\n    text-decoration: none;\n    border: none;\n    width: 100%;\n    box-sizing: border-box;\n    text-align: left;\n    transition: background 0.1s;\n    margin-bottom: 2px;\n  }\n\n  .pplx-nav-item.active {\n    background: var(--color-parchment);\n    color: var(--color-inkwell);\n  }\n\n  .pplx-nav-item.inactive {\n    background: transparent;\n    color: var(--color-graphite);\n  }\n\n  .pplx-nav-item.inactive:hover {\n    background: var(--color-parchment);\n  }\n\n  .pplx-nav-icon {\n    width: 18px;\n    height: 18px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .pplx-nav-divider {\n    height: 1px;\n    background: rgba(39,37,30,0.08);\n    margin: 8px 12px;\n  }\n\n  .pplx-nav-section-label {\n    font-family: var(--font-pplxsans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-faded-stone);\n    padding: 8px 12px 4px;\n    line-height: 1.5;\n  }\n\n  .pplx-nav-history-note {\n    font-family: var(--font-pplxsans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-faded-stone);\n    padding: 4px 12px;\n    line-height: 1.5;\n  }\n</style>\n\n<div class=\"pplx-nav-wrapper\">\n  <a class=\"pplx-nav-item active\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <circle cx=\"7\" cy=\"7\" r=\"4.5\" stroke=\"#000\" stroke-width=\"1.4\"/>\n        <path d=\"M10.5 10.5l2.5 2.5\" stroke=\"#000\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n        <path d=\"M5 7a2 2 0 012-2\" stroke=\"#000\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n      </svg>\n    </span>\n    Search\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <rect x=\"2\" y=\"3\" width=\"12\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <path d=\"M5 7h6M5 10h4\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n      </svg>\n    </span>\n    Computer\n  </a>\n\n  <div class=\"pplx-nav-divider\"></div>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M3 4h10M3 8h10M3 12h6\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n        <circle cx=\"12\" cy=\"12\" r=\"2.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <path d=\"M2 4l1-2\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n      </svg>\n    </span>\n    New thread\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M3 13V5l5-3 5 3v8\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linejoin=\"round\"/>\n        <rect x=\"6\" y=\"9\" width=\"4\" height=\"4\" rx=\"0.5\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n      </svg>\n    </span>\n    History\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <circle cx=\"8\" cy=\"8\" r=\"5.5\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <path d=\"M8 5v3l2 2\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </span>\n    Discover\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <rect x=\"2\" y=\"2\" width=\"5\" height=\"5\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.3\"/>\n        <rect x=\"9\" y=\"2\" width=\"5\" height=\"5\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.3\"/>\n        <rect x=\"2\" y=\"9\" width=\"5\" height=\"5\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.3\"/>\n        <rect x=\"9\" y=\"9\" width=\"5\" height=\"5\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.3\"/>\n      </svg>\n    </span>\n    Spaces\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <polyline points=\"2,12 6,7 9,10 13,4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n      </svg>\n    </span>\n    Finance\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M8 14s-5.5-3.5-5.5-7.5A5.5 5.5 0 0113.5 6.5C13.5 10.5 8 14 8 14z\" stroke=\"currentColor\" stroke-width=\"1.4\" fill=\"none\"/>\n      </svg>\n    </span>\n    Health\n  </a>\n\n  <a class=\"pplx-nav-item inactive\">\n    <span class=\"pplx-nav-icon\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <circle cx=\"4\" cy=\"8\" r=\"1.2\" fill=\"currentColor\"/>\n        <circle cx=\"8\" cy=\"8\" r=\"1.2\" fill=\"currentColor\"/>\n        <circle cx=\"12\" cy=\"8\" r=\"1.2\" fill=\"currentColor\"/>\n      </svg>\n    </span>\n    More\n  </a>\n\n  <div class=\"pplx-nav-divider\"></div>\n\n  <div class=\"pplx-nav-section-label\">History</div>\n  <div class=\"pplx-nav-history-note\">Recent and active threads will appear here.</div>\n</div>",
