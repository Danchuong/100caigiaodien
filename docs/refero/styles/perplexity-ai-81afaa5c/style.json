          "html": "<style>\n  :root {\n    --color-inkwell: #000000;\n    --color-paper-white: #FFFFFF;\n    --color-parchment: #FAF8F5;\n    --color-graphite: #27251E;\n    --color-faded-stone: #92918B;\n    --color-dusk-gray: #72706B;\n    --font-pplxsans: 'Inter', sans-serif;\n  }\n\n  .pplx-try-wrapper {\n    background: var(--color-paper-white);\n    padding: 16px;\n    font-family: var(--font-pplxsans);\n    width: 100%;\n    max-width: 600px;\n    box-sizing: border-box;\n    margin: 0 auto;\n  }\n\n  .pplx-try-container {\n    background: var(--color-parchment);\n    border-radius: 16px;\n    overflow: hidden;\n    border: 1px solid rgba(39,37,30,0.07);\n  }\n\n  .pplx-try-header {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 12px 16px 10px;\n    border-bottom: 1px solid rgba(39,37,30,0.07);\n  }\n\n  .pplx-try-header-icon {\n    display: flex;\n    align-items: center;\n    color: var(--color-graphite);\n  }\n\n  .pplx-try-header-label {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--color-graphite);\n    font-family: var(--font-pplxsans);\n    line-height: 1.43;\n  }\n\n  .pplx-try-cards {\n    display: flex;\n    gap: 8px;\n    padding: 12px 16px 14px;\n    flex-wrap: wrap;\n  }\n\n  .pplx-suggestion-card {\n    background: var(--color-paper-white);\n    border-radius: 12px;\n    padding: 10px 14px;\n    flex: 1 1 120px;\n    min-width: 100px;\n    max-width: 160px;\n    box-sizing: border-box;\n    cursor: pointer;\n    border: 1px solid rgba(39,37,30,0.07);\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    transition: background 0.1s;\n  }\n\n  .pplx-suggestion-card:hover {\n    background: rgba(39,37,30,0.04);\n  }\n\n  .pplx-card-label {\n    font-family: var(--font-pplxsans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-graphite);\n    line-height: 1.5;\n  }\n\n  .pplx-card-sub {\n    font-family: var(--font-pplxsans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-faded-stone);\n    line-height: 1.5;\n  }\n\n  .pplx-card-bar {\n    height: 4px;\n    border-radius: 9999px;\n    background: rgba(39,37,30,0.1);\n    margin-top: 6px;\n    width: 60%;\n  }\n\n  .pplx-card-bar-short {\n    height: 4px;\n    border-radius: 9999px;\n    background: rgba(39,37,30,0.07);\n    margin-top: 4px;\n    width: 40%;\n  }\n</style>\n\n<div class=\"pplx-try-wrapper\">\n  <div class=\"pplx-try-container\">\n    <div class=\"pplx-try-header\">\n      <span class=\"pplx-try-header-icon\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <rect x=\"2\" y=\"3\" width=\"12\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n          <path d=\"M5 8h6M5 10.5h3.5\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n        </svg>\n      </span>\n      <span class=\"pplx-try-header-label\">Try Computer</span>\n    </div>\n    <div class=\"pplx-try-cards\">\n      <div class=\"pplx-suggestion-card\">\n        <span class=\"pplx-card-label\">Write code</span>\n        <span class=\"pplx-card-sub\">in Python</span>\n        <div class=\"pplx-card-bar\"></div>\n        <div class=\"pplx-card-bar-short\"></div>\n      </div>\n      <div class=\"pplx-suggestion-card\">\n        <span class=\"pplx-card-label\">Browse the web</span>\n        <span class=\"pplx-card-sub\">for research</span>\n        <div class=\"pplx-card-bar\"></div>\n        <div class=\"pplx-card-bar-short\"></div>\n      </div>\n      <div class=\"pplx-suggestion-card\">\n        <span class=\"pplx-card-label\">Analyze a file</span>\n        <span class=\"pplx-card-sub\">PDF or CSV</span>\n        <div class=\"pplx-card-bar\"></div>\n        <div class=\"pplx-card-bar-short\"></div>\n      </div>\n      <div class=\"pplx-suggestion-card\">\n        <span class=\"pplx-card-label\">Summarize</span>\n        <span class=\"pplx-card-sub\">a document</span>\n        <div class=\"pplx-card-bar\"></div>\n        <div class=\"pplx-card-bar-short\"></div>\n      </div>\n    </div>\n  </div>\n</div>",
