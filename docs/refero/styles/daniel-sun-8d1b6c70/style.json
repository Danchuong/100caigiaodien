          "html": "<style>\n  :root {\n    --color-sunbeam-yellow: #ffd500;\n    --color-pitch-black: #000000;\n    --color-canvas-white: #ffffff;\n    --color-pale-gray: #f5f5f5;\n    --color-ash-gray: #808080;\n    --color-silver-mist: #a6a6a6;\n    --shadow-subtle: rgba(0, 0, 0, 0.12) -2px 3px 3px 0px;\n    --font-reddit-sans-condensed: 'Bebas Neue', 'Arial Narrow', sans-serif;\n    --font-inter-display: 'Inter', system-ui, sans-serif;\n    --font-inter: 'Inter', system-ui, sans-serif;\n    --font-caveat: 'Dancing Script', cursive;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Dancing+Script:wght@700&family=Bebas+Neue&display=swap');\n\n  .cta-strip-wrapper {\n    background: var(--color-pitch-black);\n    border-radius: 14px;\n    padding: 40px 32px;\n    margin: 24px;\n    box-sizing: border-box;\n    text-align: center;\n    font-family: var(--font-inter-display);\n  }\n\n  .cta-eyebrow {\n    font-family: var(--font-caveat);\n    font-size: 20px;\n    font-weight: 700;\n    color: var(--color-sunbeam-yellow);\n    letter-spacing: -0.036em;\n    line-height: 1.2;\n    margin: 0 0 10px 0;\n    display: block;\n  }\n\n  .cta-headline {\n    font-family: var(--font-reddit-sans-condensed);\n    font-size: 52px;\n    font-weight: 900;\n    color: var(--color-canvas-white);\n    line-height: 0.9;\n    letter-spacing: -2.628px;\n    text-transform: uppercase;\n    margin: 0 0 16px 0;\n  }\n\n  .cta-headline span {\n    color: var(--color-sunbeam-yellow);\n  }\n\n  .cta-body {\n    font-family: var(--font-inter-display);\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--color-silver-mist);\n    line-height: 1.35;\n    margin: 0 0 32px 0;\n    max-width: 340px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n\n  .btn-group {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    flex-wrap: wrap;\n  }\n\n  .btn-primary {\n    font-family: var(--font-inter-display);\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--color-pitch-black);\n    background: var(--color-sunbeam-yellow);\n    border: none;\n    border-radius: 32px;\n    padding: 12px 28px;\n    cursor: pointer;\n    text-decoration: none;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    letter-spacing: -0.01em;\n    box-shadow: var(--shadow-subtle);\n    transition: opacity 0.2s;\n  }\n\n  .btn-primary:hover {\n    opacity: 0.9;\n  }\n\n  .btn-primary svg {\n    flex-shrink: 0;\n  }\n\n  .btn-ghost {\n    font-family: var(--font-inter-display);\n    font-size: 15px;\n    font-weight: 500;\n    color: rgba(255,255,255,0.75);\n    background: rgba(255,255,255,0.08);\n    border: 1.5px solid rgba(255,255,255,0.15);\n    border-radius: 32px;\n    padding: 11px 24px;\n    cursor: pointer;\n    text-decoration: none;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    letter-spacing: -0.01em;\n    transition: background 0.2s;\n  }\n\n  .btn-ghost:hover {\n    background: rgba(255,255,255,0.13);\n    color: var(--color-canvas-white);\n  }\n\n  .cta-note {\n    font-family: var(--font-inter);\n    font-size: 12px;\n    font-weight: 500;\n    color: var(--color-ash-gray);\n    margin: 20px 0 0 0;\n    letter-spacing: -0.036em;\n  }\n\n  .dot {\n    display: inline-block;\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n    background: #3ecf72;\n    margin-right: 6px;\n    vertical-align: middle;\n    position: relative;\n    top: -1px;\n  }\n</style>\n\n<div style=\"background: #1a1a1a; padding: 0; border-radius: 20px; overflow: hidden;\">\n  <div class=\"cta-strip-wrapper\">\n    <span class=\"cta-eyebrow\">Ready to build something great?</span>\n    <h2 class=\"cta-headline\">Start your <span>project</span><br>with Daniel</h2>\n    <p class=\"cta-body\">Crafting strong brands for SaaS and Web3 companies. Let's shape your vision into a compelling identity.</p>\n    <div class=\"btn-group\">\n      <a href=\"#\" class=\"btn-primary\">\n        Start project\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M3 8h10M9 4l4 4-4 4\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </a>\n      <a href=\"#\" class=\"btn-ghost\">\n        View my work\n      </a>\n    </div>\n    <p class=\"cta-note\"><span class=\"dot\"></span>Available for new projects in 2024</p>\n  </div>\n</div>",
