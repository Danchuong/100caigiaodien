          "html": "<style>\n  :root {\n    --color-sunbeam-yellow: #ffd500;\n    --color-pitch-black: #000000;\n    --color-canvas-white: #ffffff;\n    --color-pale-gray: #f5f5f5;\n    --color-ash-gray: #808080;\n    --color-silver-mist: #a6a6a6;\n    --font-reddit-sans-condensed: 'Bebas Neue', 'Arial Narrow', sans-serif;\n    --font-inter-display: 'Inter', system-ui, sans-serif;\n    --font-inter: 'Inter', system-ui, sans-serif;\n    --font-caveat: 'Dancing Script', cursive;\n    --font-sans-serif: system-ui, sans-serif;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Dancing+Script:wght@700&display=swap');\n\n  .nav-wrapper {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 24px 0;\n    background: transparent;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .nav-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 4px;\n    background-color: #2e2e2e;\n    border-radius: 32px;\n    padding: 8px 10px;\n    box-shadow: rgba(0,0,0,0.25) 0px 4px 16px;\n  }\n\n  .nav-icon {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    margin-right: 4px;\n  }\n\n  .nav-link {\n    font-family: var(--font-inter-display);\n    font-size: 15px;\n    font-weight: 500;\n    color: rgba(255,255,255,0.85);\n    text-decoration: none;\n    padding: 6px 14px;\n    border-radius: 32px;\n    letter-spacing: -0.01em;\n    transition: color 0.2s;\n    white-space: nowrap;\n  }\n\n  .nav-link:hover {\n    color: var(--color-canvas-white);\n  }\n\n  .nav-link.active {\n    color: var(--color-canvas-white);\n    text-decoration: underline;\n    text-underline-offset: 3px;\n  }\n\n  .nav-cta {\n    font-family: var(--font-inter-display);\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--color-sunbeam-yellow);\n    text-decoration: none;\n    padding: 6px 18px;\n    border-radius: 32px;\n    background-color: rgba(255, 213, 0, 0.15);\n    border: 1.5px solid rgba(255, 213, 0, 0.5);\n    letter-spacing: -0.01em;\n    white-space: nowrap;\n    display: inline-block;\n  }\n\n  .nav-cta:hover {\n    background-color: rgba(255, 213, 0, 0.22);\n  }\n</style>\n\n<div class=\"nav-wrapper\">\n  <nav class=\"nav-pill\">\n    <div class=\"nav-icon\">\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"#ffd500\"/>\n        <line x1=\"12\" y1=\"2\" x2=\"12\" y2=\"5\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"12\" y1=\"19\" x2=\"12\" y2=\"22\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"2\" y1=\"12\" x2=\"5\" y2=\"12\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"19\" y1=\"12\" x2=\"22\" y2=\"12\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"4.93\" y1=\"4.93\" x2=\"7.05\" y2=\"7.05\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"16.95\" y1=\"16.95\" x2=\"19.07\" y2=\"19.07\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"4.93\" y1=\"19.07\" x2=\"7.05\" y2=\"16.95\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <line x1=\"16.95\" y1=\"7.05\" x2=\"19.07\" y2=\"4.93\" stroke=\"#ffd500\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n      </svg>\n    </div>\n    <a href=\"#\" class=\"nav-link active\">Work</a>\n    <a href=\"#\" class=\"nav-link\">Story</a>\n    <a href=\"#\" class=\"nav-link\">Process</a>\n    <a href=\"#\" class=\"nav-link\">Connect</a>\n    <a href=\"#\" class=\"nav-cta\">Start project</a>\n  </nav>\n</div>",
