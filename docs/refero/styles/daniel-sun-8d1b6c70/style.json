          "html": "<style>\n  :root {\n    --color-sunbeam-yellow: #ffd500;\n    --color-pitch-black: #000000;\n    --color-canvas-white: #ffffff;\n    --color-pale-gray: #f5f5f5;\n    --color-ash-gray: #808080;\n    --color-silver-mist: #a6a6a6;\n    --shadow-subtle: rgba(0, 0, 0, 0.12) -2px 3px 3px 0px;\n    --font-reddit-sans-condensed: 'Bebas Neue', 'Arial Narrow', sans-serif;\n    --font-inter-display: 'Inter', system-ui, sans-serif;\n    --font-caveat: 'Dancing Script', cursive;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500&family=Dancing+Script:wght@700&family=Bebas+Neue&display=swap');\n\n  .showcase-wrapper {\n    padding: 32px 24px;\n    background: var(--color-canvas-white);\n    font-family: var(--font-inter-display);\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .showcase-header {\n    text-align: center;\n    margin-bottom: 32px;\n  }\n\n  .showcase-eyebrow {\n    font-family: var(--font-caveat);\n    font-size: 22px;\n    font-weight: 700;\n    color: var(--color-silver-mist);\n    line-height: 1.2;\n    letter-spacing: -0.036em;\n    display: block;\n    margin-bottom: 6px;\n  }\n\n  .showcase-title {\n    font-family: var(--font-reddit-sans-condensed);\n    font-size: 52px;\n    font-weight: 900;\n    color: var(--color-pitch-black);\n    line-height: 0.9;\n    letter-spacing: -2.628px;\n    text-transform: uppercase;\n    margin: 0;\n  }\n\n  .showcase-card {\n    background: var(--color-pale-gray);\n    border-radius: 14px;\n    box-shadow: var(--shadow-subtle);\n    overflow: hidden;\n    padding: 16px;\n    box-sizing: border-box;\n  }\n\n  .card-image-area {\n    width: 100%;\n    height: 240px;\n    background: linear-gradient(135deg, #1a3a35 0%, #0d2420 100%);\n    border-radius: 14px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    position: relative;\n    margin-bottom: 16px;\n  }\n\n  .card-screen-mock {\n    width: 85%;\n    height: 88%;\n    background: var(--color-canvas-white);\n    border-radius: 10px;\n    padding: 12px;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  .mock-nav {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding-bottom: 8px;\n    border-bottom: 1px solid #eee;\n  }\n\n  .mock-logo {\n    width: 48px;\n    height: 10px;\n    background: #1a3a35;\n    border-radius: 4px;\n  }\n\n  .mock-nav-links {\n    display: flex;\n    gap: 6px;\n  }\n\n  .mock-nav-link {\n    width: 28px;\n    height: 8px;\n    background: #ccc;\n    border-radius: 3px;\n  }\n\n  .mock-cta-btn {\n    width: 54px;\n    height: 16px;\n    background: #1a3a35;\n    border-radius: 6px;\n  }\n\n  .mock-hero-text {\n    font-family: var(--font-inter-display);\n    font-size: 11px;\n    font-weight: 500;\n    color: #111;\n    text-align: center;\n    line-height: 1.3;\n    padding: 4px 0 2px;\n  }\n\n  .mock-body-line {\n    height: 6px;\n    background: #e8e8e8;\n    border-radius: 3px;\n    margin: 0 auto;\n  }\n\n  .mock-input-row {\n    display: flex;\n    gap: 6px;\n    align-items: center;\n    margin-top: 4px;\n  }\n\n  .mock-input {\n    flex: 1;\n    height: 18px;\n    background: #f5f5f5;\n    border: 1px solid #ddd;\n    border-radius: 5px;\n  }\n\n  .mock-submit {\n    width: 54px;\n    height: 18px;\n    background: #c8860a;\n    border-radius: 5px;\n  }\n\n  .card-meta {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 12px;\n  }\n\n  .card-project-name {\n    font-family: var(--font-reddit-sans-condensed);\n    font-size: 28px;\n    font-weight: 900;\n    color: var(--color-pitch-black);\n    line-height: 0.96;\n    letter-spacing: -1px;\n    text-transform: uppercase;\n    margin: 0 0 4px 0;\n  }\n\n  .card-project-desc {\n    font-family: var(--font-inter-display);\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--color-ash-gray);\n    line-height: 1.35;\n    margin: 0;\n  }\n\n  .card-tag {\n    font-family: var(--font-sans-serif);\n    font-size: 11px;\n    font-weight: 400;\n    color: var(--color-ash-gray);\n    background: rgba(0,0,0,0.07);\n    border-radius: 32px;\n    padding: 4px 10px;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n</style>\n\n<div class=\"showcase-wrapper\">\n  <div class=\"showcase-header\">\n    <span class=\"showcase-eyebrow\">from 2020 'til today</span>\n    <h2 class=\"showcase-title\">My Latest Work</h2>\n  </div>\n\n  <div class=\"showcase-card\">\n    <div class=\"card-image-area\">\n      <div class=\"card-screen-mock\">\n        <div class=\"mock-nav\">\n          <div class=\"mock-logo\"></div>\n          <div class=\"mock-nav-links\">\n            <div class=\"mock-nav-link\"></div>\n            <div class=\"mock-nav-link\"></div>\n          </div>\n          <div class=\"mock-cta-btn\"></div>\n        </div>\n        <div class=\"mock-hero-text\">Innovative banking¹ for<br>modern businesses</div>\n        <div class=\"mock-body-line\" style=\"width:90%\"></div>\n        <div class=\"mock-body-line\" style=\"width:75%\"></div>\n        <div class=\"mock-input-row\">\n          <div class=\"mock-input\"></div>\n          <div class=\"mock-submit\"></div>\n        </div>\n      </div>\n    </div>\n    <div class=\"card-meta\">\n      <div>\n        <h3 class=\"card-project-name\">Ruby</h3>\n        <p class=\"card-project-desc\">Brand identity & web design for<br>an innovative fintech platform.</p>\n      </div>\n      <span class=\"card-tag\">Branding · Web</span>\n    </div>\n  </div>\n</div>",
