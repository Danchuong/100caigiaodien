      "components": [
        {
          "html": "<style>\n  :root {\n    --color-deep-space-black: #110e08;\n    --color-void-black: #000000;\n    --color-ghost-white: #ffffff;\n    --color-shadow-graphite: #35322d;\n    --color-rocket-lime: #ccff00;\n    --font-capsule-sans-text: 'Inter', sans-serif;\n    --font-martina-plantijn: 'Playfair Display', serif;\n    --font-phonic: 'Georgia', serif;\n  }\n\n  .rh-btn-group-wrapper {\n    background: var(--color-deep-space-black);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 52px 24px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: var(--font-capsule-sans-text);\n    gap: 16px;\n  }\n\n  .rh-btn-group-label {\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 13px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    opacity: 0.5;\n    margin-bottom: 8px;\n  }\n\n  .rh-btn-row {\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    gap: 12px;\n    flex-wrap: wrap;\n    justify-content: center;\n  }\n\n  .rh-btn-primary {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: var(--color-rocket-lime);\n    color: var(--color-void-black);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n    padding: 14px 32px;\n    border-radius: 36px;\n    border: none;\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n    transition: opacity 0.15s ease;\n  }\n\n  .rh-btn-primary:hover {\n    opacity: 0.88;\n  }\n\n  .rh-btn-secondary {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: transparent;\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n    padding: 13px 32px;\n    border-radius: 36px;\n    border: 1.5px solid var(--color-ghost-white);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n    transition: border-color 0.15s ease, color 0.15s ease;\n  }\n\n  .rh-btn-secondary:hover {\n    border-color: var(--color-rocket-lime);\n    color: var(--color-rocket-lime);\n  }\n\n  .rh-btn-ghost {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: transparent;\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n    padding: 13px 32px;\n    border-radius: 36px;\n    border: 1.5px solid var(--color-shadow-graphite);\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n    opacity: 0.7;\n  }\n\n  .rh-btn-divider {\n    width: 100%;\n    max-width: 340px;\n    height: 1px;\n    background: var(--color-shadow-graphite);\n    margin: 4px 0;\n  }\n\n  .rh-btn-desc {\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 13px;\n    letter-spacing: -0.077px;\n    line-height: 1.26;\n    opacity: 0.45;\n    text-align: center;\n    max-width: 320px;\n  }\n</style>\n\n<div class=\"rh-btn-group-wrapper\">\n  <div class=\"rh-btn-group-label\">Acciones disponibles</div>\n  <div class=\"rh-btn-row\">\n    <a href=\"#\" class=\"rh-btn-primary\">Regístrate</a>\n    <a href=\"#\" class=\"rh-btn-secondary\">Acceder</a>\n  </div>\n  <div class=\"rh-btn-divider\"></div>\n  <div class=\"rh-btn-row\">\n    <a href=\"#\" class=\"rh-btn-ghost\">Más información</a>\n  </div>\n  <div class=\"rh-btn-desc\">Sin comisiones de custodia · Sin mínimo de depósito</div>\n</div>",
