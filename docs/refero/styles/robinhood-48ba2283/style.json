        {
          "html": "<style>\n  :root {\n    --color-deep-space-black: #110e08;\n    --color-void-black: #000000;\n    --color-ghost-white: #ffffff;\n    --color-shadow-graphite: #35322d;\n    --color-rocket-lime: #ccff00;\n    --font-capsule-sans-text: 'Inter', sans-serif;\n    --font-martina-plantijn: 'Playfair Display', serif;\n    --font-phonic: 'Georgia', serif;\n  }\n\n  .rh-search-panel {\n    background: var(--color-deep-space-black);\n    width: 100%;\n    box-sizing: border-box;\n    padding: 36px 24px 0 24px;\n    font-family: var(--font-capsule-sans-text);\n    border-radius: 20px;\n    overflow: hidden;\n  }\n\n  .rh-search-title {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 22px;\n    font-weight: 400;\n    letter-spacing: -0.011px;\n    line-height: 1.09;\n    color: var(--color-ghost-white);\n    margin: 0 0 20px 0;\n    text-align: center;\n  }\n\n  .rh-search-bar {\n    display: flex;\n    align-items: center;\n    background: #1e1b14;\n    border: 1.5px solid var(--color-shadow-graphite);\n    border-radius: 36px;\n    padding: 0 16px;\n    gap: 10px;\n    height: 46px;\n    margin-bottom: 20px;\n  }\n\n  .rh-search-icon {\n    flex-shrink: 0;\n    opacity: 0.45;\n  }\n\n  .rh-search-input {\n    background: transparent;\n    border: none;\n    outline: none;\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.5;\n    width: 100%;\n    opacity: 0.5;\n  }\n\n  .rh-search-input::placeholder {\n    color: var(--color-ghost-white);\n    opacity: 0.45;\n  }\n\n  .rh-tabs {\n    display: flex;\n    flex-direction: row;\n    border-bottom: 1px solid var(--color-shadow-graphite);\n    margin-bottom: 0;\n    gap: 0;\n  }\n\n  .rh-tab {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 12px 8px;\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    color: var(--color-ghost-white);\n    opacity: 0.45;\n    cursor: pointer;\n    position: relative;\n    text-align: center;\n  }\n\n  .rh-tab.active {\n    opacity: 1;\n    color: var(--color-ghost-white);\n  }\n\n  .rh-tab.active::after {\n    content: '';\n    position: absolute;\n    bottom: -1px;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: var(--color-ghost-white);\n    border-radius: 2px 2px 0 0;\n  }\n\n  .rh-asset-list {\n    padding: 20px 0 0 0;\n  }\n\n  .rh-asset-note {\n    font-family: var(--font-phonic);\n    font-size: 13px;\n    font-weight: 400;\n    letter-spacing: -0.077px;\n    line-height: 1.26;\n    color: var(--color-ghost-white);\n    opacity: 0.45;\n    margin-bottom: 20px;\n  }\n\n  .rh-asset-note a {\n    color: var(--color-ghost-white);\n    text-decoration: underline;\n    opacity: 1;\n  }\n\n  .rh-section-label {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-ghost-white);\n    margin-bottom: 12px;\n  }\n\n  .rh-section-info {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 16px;\n    height: 16px;\n    border-radius: 50%;\n    border: 1.5px solid rgba(255,255,255,0.4);\n    font-size: 11px;\n    color: rgba(255,255,255,0.5);\n    flex-shrink: 0;\n    font-style: italic;\n  }\n\n  .rh-asset-row {\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    justify-content: space-between;\n    padding: 14px 0;\n    border-top: 1px solid var(--color-shadow-graphite);\n  }\n\n  .rh-asset-row:last-child {\n    border-bottom: 1px solid var(--color-shadow-graphite);\n    margin-bottom: 24px;\n  }\n\n  .rh-asset-left {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .rh-asset-name {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-ghost-white);\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n  }\n\n  .rh-asset-ticker {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-ghost-white);\n    opacity: 0.45;\n    letter-spacing: -0.077px;\n    line-height: 1.26;\n  }\n\n  .rh-asset-right {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 3px;\n  }\n\n  .rh-asset-chart {\n    width: 60px;\n    height: 28px;\n    margin-bottom: 2px;\n  }\n\n  .rh-asset-price {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    color: var(--color-ghost-white);\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n  }\n\n  .rh-asset-change {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 13px;\n    font-weight: 400;\n    letter-spacing: -0.077px;\n    line-height: 1.26;\n    color: #4ade80;\n  }\n</style>\n\n<div class=\"rh-search-panel\">\n  <p class=\"rh-search-title\">Explorar</p>\n\n  <div class=\"rh-search-bar\">\n    <svg class=\"rh-search-icon\" width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <circle cx=\"8\" cy=\"8\" r=\"5.5\" stroke=\"#ffffff\" stroke-width=\"1.5\"/>\n      <line x1=\"12.5\" y1=\"12.5\" x2=\"16\" y2=\"16\" stroke=\"#ffffff\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n    </svg>\n    <input class=\"rh-search-input\" type=\"text\" placeholder=\"Buscar por nombre o símbolo\" />\n  </div>\n\n  <div class=\"rh-tabs\">\n    <div class=\"rh-tab active\">Acciones</div>\n    <div class=\"rh-tab\">ETF</div>\n    <div class=\"rh-tab\">Cripto</div>\n  </div>\n\n  <div class=\"rh-asset-list\">\n    <div class=\"rh-asset-note\">Robinhood Stock Tokens son derivados que siguen los precios mostrados. <a href=\"#\">Más información</a></div>\n\n    <div class=\"rh-section-label\">\n      Por capitalización bursátil\n      <span class=\"rh-section-info\">i</span>\n    </div>\n\n    <div class=\"rh-asset-row\">\n      <div class=\"rh-asset-left\">\n        <span class=\"rh-asset-name\">NVIDIA</span>\n        <span class=\"rh-asset-ticker\">NVDA</span>\n      </div>\n      <div class=\"rh-asset-right\">\n        <svg class=\"rh-asset-chart\" viewBox=\"0 0 60 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <polyline points=\"2,22 10,18 18,20 26,14 34,12 42,8 50,10 58,4\" stroke=\"#4ade80\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n        </svg>\n        <span class=\"rh-asset-price\">154,31 $</span>\n        <span class=\"rh-asset-change\">▲ 4,33%</span>\n      </div>\n    </div>\n\n    <div class=\"rh-asset-row\">\n      <div class=\"rh-asset-left\">\n        <span class=\"rh-asset-name\">Microsoft</span>\n        <span class=\"rh-asset-ticker\">MSFT</span>\n      </div>\n      <div class=\"rh-asset-right\">\n        <svg class=\"rh-asset-chart\" viewBox=\"0 0 60 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <polyline points=\"2,18 10,16 18,19 26,15 34,14 42,11 50,13 58,10\" stroke=\"#4ade80\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n        </svg>\n        <span class=\"rh-asset-price\">492,27 $</span>\n        <span class=\"rh-asset-change\">▲ 0,44%</span>\n      </div>\n    </div>\n\n    <div class=\"rh-asset-row\">\n      <div class=\"rh-asset-left\">\n        <span class=\"rh-asset-name\">Apple</span>\n        <span class=\"rh-asset-ticker\">AAPL</span>\n      </div>\n      <div class=\"rh-asset-right\">\n        <svg class=\"rh-asset-chart\" viewBox=\"0 0 60 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <polyline points=\"2,14 10,16 18,13 26,15 34,11 42,14 50,10 58,12\" stroke=\"#4ade80\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n        </svg>\n        <span class=\"rh-asset-price\">207,54 $</span>\n        <span class=\"rh-asset-change\">▲ 1,18%</span>\n      </div>\n    </div>\n  </div>\n</div>",
