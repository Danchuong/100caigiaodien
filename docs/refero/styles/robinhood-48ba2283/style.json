          "html": "<style>\n  :root {\n    --color-deep-space-black: #110e08;\n    --color-void-black: #000000;\n    --color-ghost-white: #ffffff;\n    --color-shadow-graphite: #35322d;\n    --color-rocket-lime: #ccff00;\n    --font-capsule-sans-text: 'Inter', sans-serif;\n    --font-martina-plantijn: 'Playfair Display', serif;\n    --font-phonic: 'Georgia', serif;\n  }\n\n  .rh-feature-card {\n    background: var(--color-rocket-lime);\n    width: 100%;\n    box-sizing: border-box;\n    padding: 48px 36px 40px 36px;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n    font-family: var(--font-capsule-sans-text);\n  }\n\n  .rh-feature-eyebrow {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.5;\n    color: #4a4a00;\n    opacity: 0.7;\n    margin: 0;\n  }\n\n  .rh-feature-headline {\n    font-family: var(--font-martina-plantijn);\n    font-size: 48px;\n    font-weight: 400;\n    letter-spacing: -0.014px;\n    line-height: 1.08;\n    color: var(--color-void-black);\n    margin: 0;\n  }\n\n  .rh-feature-body {\n    font-family: var(--font-phonic);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.5;\n    color: var(--color-void-black);\n    margin: 0;\n    max-width: 440px;\n  }\n\n  .rh-feature-cta {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: var(--color-deep-space-black);\n    color: var(--color-ghost-white);\n    font-family: var(--font-capsule-sans-text);\n    font-size: 16px;\n    font-weight: 400;\n    letter-spacing: -0.008px;\n    line-height: 1.2;\n    padding: 14px 32px;\n    border-radius: 36px;\n    border: none;\n    cursor: pointer;\n    text-decoration: none;\n    white-space: nowrap;\n    align-self: flex-start;\n    margin-top: 4px;\n  }\n\n  .rh-feature-stats {\n    display: flex;\n    flex-direction: row;\n    gap: 32px;\n    margin-top: 8px;\n    flex-wrap: wrap;\n  }\n\n  .rh-stat-item {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .rh-stat-value {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 31px;\n    font-weight: 400;\n    letter-spacing: -0.019px;\n    line-height: 1.2;\n    color: var(--color-void-black);\n  }\n\n  .rh-stat-label {\n    font-family: var(--font-capsule-sans-text);\n    font-size: 13px;\n    font-weight: 400;\n    letter-spacing: -0.077px;\n    line-height: 1.26;\n    color: var(--color-void-black);\n    opacity: 0.6;\n  }\n\n  .rh-feature-divider {\n    width: 100%;\n    height: 1px;\n    background: rgba(0,0,0,0.15);\n  }\n</style>\n\n<div class=\"rh-feature-card\">\n  <p class=\"rh-feature-eyebrow\">Invierte</p>\n  <h2 class=\"rh-feature-headline\">Empieza con<br>Tokens de Acciones</h2>\n  <p class=\"rh-feature-body\">Explora más de 2.000 Tokens de Acciones (Stock Tokens) vinculados a NVIDIA, Microsoft, Apple, Vanguard S&P 500 ETF y muchas otras acciones y ETF.</p>\n  <a href=\"#\" class=\"rh-feature-cta\">Más información</a>\n  <div class=\"rh-feature-divider\"></div>\n  <div class=\"rh-feature-stats\">\n    <div class=\"rh-stat-item\">\n      <span class=\"rh-stat-value\">2.000+</span>\n      <span class=\"rh-stat-label\">Stock Tokens disponibles</span>\n    </div>\n    <div class=\"rh-stat-item\">\n      <span class=\"rh-stat-value\">0%</span>\n      <span class=\"rh-stat-label\">Comisión de custodia</span>\n    </div>\n    <div class=\"rh-stat-item\">\n      <span class=\"rh-stat-value\">24/7</span>\n      <span class=\"rh-stat-label\">Mercado disponible</span>\n    </div>\n  </div>\n</div>",
          "name": "Stock Token Feature Card",
