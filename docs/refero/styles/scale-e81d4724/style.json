      "northStar": "Midnight Command Center: An expanse of polished dark surfaces, illuminated by precise white text and the occasional shimmer of an iridescent, almost holographic, light.",
      "components": [
        {
          "html": "<style>\n  :root {\n    --color-deep-space: #000000;\n    --color-ghost-white: #ffffff;\n    --color-iron-slate: #a1a1a1;\n    --color-halo-pale: #f4f0ff;\n    --font-inter: system-ui, sans-serif;\n    --font-aeonik: Montserrat, sans-serif;\n    --font-geist: 'Source Code Pro', monospace;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-deep-space);font-family:var(--font-inter);\">\n  <div style=\"background:#111111;padding:12px 24px;display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;\">\n    <span style=\"color:var(--color-ghost-white);font-family:var(--font-inter);font-size:14px;font-weight:400;line-height:1.5;text-align:center;\">\n      Introducing Dialect: Your institutional judgment is your competitive advantage. Now your AI can use it too.\n    </span>\n    <a href=\"#\" style=\"color:var(--color-ghost-white);font-family:var(--font-inter);font-size:14px;font-weight:500;text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:4px;\">\n      Learn more\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M3 8H13M13 8L9 4M13 8L9 12\" stroke=\"#ffffff\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </a>\n  </div>\n</div>",
          "name": "Announcement Banner",
