          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-deep-space: #000000;\n    --color-ghost-white: #ffffff;\n    --color-iron-slate: #a1a1a1;\n    --color-halo-pale: #f4f0ff;\n    --color-shadow-tint: #020202;\n    --shadow-subtle: rgba(255,255,255,0.1) 0px 1px 1px 0px inset;\n    --font-inter: system-ui, sans-serif;\n    --font-aeonik: Montserrat, sans-serif;\n    --spacing-8: 8px;\n    --spacing-16: 16px;\n    --spacing-24: 24px;\n    --spacing-32: 32px;\n    --spacing-48: 48px;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-deep-space);padding:var(--spacing-48) var(--spacing-32);box-sizing:border-box;display:flex;flex-direction:column;align-items:flex-start;gap:var(--spacing-32);font-family:var(--font-aeonik);\">\n  <div style=\"display:flex;flex-direction:column;gap:var(--spacing-16);\">\n    <p style=\"margin:0;font-family:var(--font-inter);font-size:14px;color:var(--color-iron-slate);letter-spacing:0.286em;text-transform:uppercase;font-weight:400;\">AI for the Enterprise</p>\n    <h2 style=\"margin:0;font-family:var(--font-aeonik);font-size:48px;font-weight:300;color:var(--color-ghost-white);line-height:1.11;letter-spacing:-0.01em;\">Full-Stack AI Solutions</h2>\n    <p style=\"margin:0;font-family:var(--font-inter);font-size:18px;font-weight:400;color:var(--color-iron-slate);line-height:1.56;max-width:480px;\">Outcomes delivered with world-class data, models, agents, and deployment.</p>\n  </div>\n  <div style=\"display:flex;align-items:center;gap:var(--spacing-24);flex-wrap:wrap;\">\n    <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:var(--color-deep-space);color:var(--color-ghost-white);font-family:var(--font-inter);font-size:16px;font-weight:400;text-decoration:none;border:1.5px solid rgba(255,255,255,0.4);border-radius:100px;box-shadow:var(--shadow-subtle);transition:border-color 0.2s;\">\n      Book a Demo\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M3 8H13M13 8L9 4M13 8L9 12\" stroke=\"#ffffff\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </a>\n    <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:6px;padding:12px 0;color:var(--color-ghost-white);font-family:var(--font-inter);font-size:16px;font-weight:400;text-decoration:none;background:transparent;border:none;\">\n      Build AI\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M3 8H13M13 8L9 4M13 8L9 12\" stroke=\"#ffffff\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </a>\n  </div>\n</div>",
          "name": "Button Group (Primary + Secondary CTA)",
