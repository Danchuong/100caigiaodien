          "html": "<div style=\"--color-midnight-ink:#000000;--color-onyx-canvas:#212121;--color-frost-canvas:#f5f6f5;--color-gallery-white:#ffffff;--color-tangerine-flash:#d9462b;--color-rose-bloom:#e296bb;--font-trjn-davinci:Georgia,'Georgia Pro',serif;--font-helveticaneue-light:'Helvetica Neue',Helvetica,Arial,sans-serif;--font-neue-montreal:Inter,system-ui,sans-serif; background:var(--color-rose-bloom); width:600px; min-height:400px; padding:32px 0 0 0; box-sizing:border-box; overflow:hidden; position:relative; font-family:var(--font-neue-montreal);\">\n  <!-- Top metadata cluster -->\n  <div style=\"position:absolute; top:20px; right:32px; text-align:right;\">\n    <div style=\"font-family:var(--font-neue-montreal); font-size:12px; line-height:1.17; color:var(--color-tangerine-flash); margin-bottom:2px;\">Paris, France — 18:34</div>\n    <div style=\"font-family:var(--font-helveticaneue-light); font-size:16px; line-height:1.19; color:var(--color-tangerine-flash); letter-spacing:-0.02em;\">Studio, Contact, Blog</div>\n    <div style=\"width:4px; height:4px; background:var(--color-tangerine-flash); border-radius:50%; margin:4px 0 0 auto;\"></div>\n  </div>\n  <!-- Chapter metadata -->\n  <div style=\"position:absolute; top:130px; right:32px; text-align:center;\">\n    <div style=\"font-family:var(--font-neue-montreal); font-size:12px; line-height:1.17; color:var(--color-tangerine-flash); letter-spacing:0.05em; margin-bottom:6px;\">CONCRETE CLUB</div>\n    <div style=\"font-family:var(--font-neue-montreal); font-size:12px; line-height:1.4; color:var(--color-tangerine-flash); letter-spacing:0.05em;\">PARIS, WORLDWIDE<br>CHAPTER 2</div>\n  </div>\n  <!-- Giant display heading -->\n  <div style=\"padding-top:160px; padding-left:0; line-height:1.0; overflow:hidden;\">\n    <div style=\"font-family:var(--font-trjn-davinci); font-size:clamp(80px, 22vw, 150px); font-weight:400; line-height:1.0; letter-spacing:-0.03em; color:var(--color-tangerine-flash); white-space:nowrap; padding-left:8px;\">Concrete</div>\n    <div style=\"font-family:var(--font-trjn-davinci); font-size:clamp(80px, 22vw, 150px); font-weight:400; line-height:1.0; letter-spacing:-0.03em; color:var(--color-tangerine-flash); white-space:nowrap; padding-left:8px;\">Club</div>\n  </div>\n</div>",
