        {
          "html": "<style>\n  :root {\n    --color-lumi-green: #107c10;\n    --color-snowfield-white: #ffffff;\n    --color-absolute-zero: #000000;\n    --font-segoe-ui: 'Segoe UI', system-ui, sans-serif;\n  }\n  .xbox-nav-item:hover .xbox-nav-icon svg {\n    color: var(--color-lumi-green);\n  }\n</style>\n<div style=\"width:600px;background:var(--color-snowfield-white);font-family:var(--font-segoe-ui);padding:24px 16px 20px 16px;box-sizing:border-box;border-bottom:1px solid #e0e0e0;\">\n  <div style=\"display:flex;justify-content:space-around;align-items:flex-start;\">\n    <!-- Game Pass -->\n    <a href=\"#\" style=\"display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;min-width:72px;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"8\" y=\"10\" width=\"14\" height=\"18\" rx=\"0\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n        <rect x=\"18\" y=\"10\" width=\"14\" height=\"18\" rx=\"0\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n      </svg>\n      <span style=\"color:var(--color-lumi-green);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;text-align:center;\">GAME PASS</span>\n    </a>\n    <!-- Juegos -->\n    <a href=\"#\" style=\"display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;min-width:72px;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M8 20c0-6.627 5.373-12 12-12s12 5.373 12 12-5.373 12-12 12S8 26.627 8 20z\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n        <path d=\"M15 20h10M20 15v10\" stroke=\"#107c10\" stroke-width=\"2\" stroke-linecap=\"square\"/>\n      </svg>\n      <span style=\"color:var(--color-lumi-green);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;text-align:center;\">JUEGOS</span>\n    </a>\n    <!-- Dispositivos -->\n    <a href=\"#\" style=\"display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;min-width:72px;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"6\" y=\"14\" width=\"18\" height=\"12\" rx=\"0\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n        <rect x=\"20\" y=\"10\" width=\"14\" height=\"18\" rx=\"0\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n        <path d=\"M6 26h18\" stroke=\"#107c10\" stroke-width=\"2\"/>\n      </svg>\n      <span style=\"color:var(--color-lumi-green);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;text-align:center;\">DISPOSITIVOS</span>\n    </a>\n    <!-- Accesorios -->\n    <a href=\"#\" style=\"display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;min-width:72px;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M14 20c0-3.314 2.686-6 6-6s6 2.686 6 6-2.686 6-6 6-6-2.686-6-6z\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\"/>\n        <path d=\"M8 28c2-4 5-6 12-6s10 2 12 6\" stroke=\"#107c10\" stroke-width=\"2\" stroke-linecap=\"square\" fill=\"none\"/>\n      </svg>\n      <span style=\"color:var(--color-lumi-green);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;text-align:center;\">ACCESORIOS</span>\n    </a>\n    <!-- Juega -->\n    <a href=\"#\" style=\"display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;min-width:72px;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M14 12l16 8-16 8V12z\" stroke=\"#107c10\" stroke-width=\"2\" fill=\"none\" stroke-linejoin=\"miter\"/>\n      </svg>\n      <span style=\"color:var(--color-lumi-green);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;text-align:center;\">JUEGA</span>\n    </a>\n  </div>\n</div>",
