        {
          "html": "<style>\n  :root {\n    --color-lumi-green: #107c10;\n    --color-rich-meadow: #054b16;\n    --color-electric-lime: #9bf00b;\n    --color-cyber-yellow: #ffd800;\n    --color-absolute-zero: #000000;\n    --color-snowfield-white: #ffffff;\n    --color-charcoal-depth: #333333;\n    --font-segoe-ui: 'Segoe UI', system-ui, sans-serif;\n  }\n</style>\n<div style=\"width:600px;box-sizing:border-box;font-family:var(--font-segoe-ui);\">\n  <div style=\"background:var(--color-lumi-green);position:relative;overflow:hidden;padding:40px 36px 40px 36px;box-sizing:border-box;min-height:260px;display:flex;flex-direction:column;justify-content:flex-end;\">\n    <!-- decorative game covers strip -->\n    <div style=\"display:flex;gap:8px;position:absolute;top:16px;right:20px;opacity:0.22;\">\n      <div style=\"width:52px;height:72px;background:var(--color-rich-meadow);\"></div>\n      <div style=\"width:52px;height:72px;background:var(--color-rich-meadow);margin-top:10px;\"></div>\n      <div style=\"width:52px;height:72px;background:var(--color-rich-meadow);\"></div>\n      <div style=\"width:52px;height:72px;background:var(--color-rich-meadow);margin-top:14px;\"></div>\n      <div style=\"width:52px;height:72px;background:var(--color-rich-meadow);\"></div>\n    </div>\n    <div style=\"max-width:400px;\">\n      <h2 style=\"color:var(--color-snowfield-white);font-size:32px;font-weight:700;line-height:1.22;margin:0 0 12px 0;\">Ofertas de Primavera</h2>\n      <p style=\"color:var(--color-snowfield-white);font-size:15px;font-weight:400;line-height:1.5;margin:0 0 28px 0;\">Ahorra hasta un 50% en una selección de juegos Xbox</p>\n      <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:6px;color:var(--color-snowfield-white);font-family:var(--font-segoe-ui);font-size:14px;font-weight:700;text-decoration:none;letter-spacing:0.5px;text-transform:uppercase;border-bottom:2px solid var(--color-snowfield-white);padding-bottom:2px;\">\n        COMPRAR AHORA\n        <svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M2 5h6M5 2l3 3-3 3\" stroke=\"#ffffff\" stroke-width=\"1.5\" stroke-linecap=\"square\"/></svg>\n      </a>\n    </div>\n  </div>\n  <!-- Game cards row -->\n  <div style=\"background:var(--color-snowfield-white);padding:20px;display:flex;gap:10px;\">\n    <div style=\"flex:1;background:#1a3a1a;height:90px;display:flex;align-items:flex-end;padding:6px;position:relative;\">\n      <span style=\"background:var(--color-cyber-yellow);color:var(--color-absolute-zero);font-size:11px;font-weight:700;padding:2px 5px;position:absolute;top:6px;left:6px;\">-50%</span>\n      <span style=\"color:var(--color-snowfield-white);font-size:11px;font-weight:600;\">Forza Horizon 5</span>\n    </div>\n    <div style=\"flex:1;background:#1a1a2e;height:90px;display:flex;align-items:flex-end;padding:6px;position:relative;\">\n      <span style=\"background:var(--color-cyber-yellow);color:var(--color-absolute-zero);font-size:11px;font-weight:700;padding:2px 5px;position:absolute;top:6px;left:6px;\">-40%</span>\n      <span style=\"color:var(--color-snowfield-white);font-size:11px;font-weight:600;\">Helldivers II</span>\n    </div>\n    <div style=\"flex:1;background:#2d1b00;height:90px;display:flex;align-items:flex-end;padding:6px;position:relative;\">\n      <span style=\"background:var(--color-cyber-yellow);color:var(--color-absolute-zero);font-size:11px;font-weight:700;padding:2px 5px;position:absolute;top:6px;left:6px;\">-30%</span>\n      <span style=\"color:var(--color-snowfield-white);font-size:11px;font-weight:600;\">Elder Scrolls Online</span>\n    </div>\n    <div style=\"flex:1;background:#0d2b0d;height:90px;display:flex;align-items:flex-end;padding:6px;position:relative;\">\n      <span style=\"background:var(--color-cyber-yellow);color:var(--color-absolute-zero);font-size:11px;font-weight:700;padding:2px 5px;position:absolute;top:6px;left:6px;\">-25%</span>\n      <span style=\"color:var(--color-snowfield-white);font-size:11px;font-weight:600;\">ARC Raiders</span>\n    </div>\n  </div>\n</div>",
