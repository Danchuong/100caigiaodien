        {
          "html": "<div style=\"--color-midnight-ink:#1c2024;--color-ghost-white:#ffffff;--color-cool-gray:#60646c;--color-whisper-gray:#f0f0f3;--color-parchment-gray:#d9d9e0;--color-expo-blue:#0090ff;--font-inter:'Inter',sans-serif;background:var(--color-ghost-white);padding:40px 32px;max-width:600px;box-sizing:border-box;font-family:var(--font-inter);\"><h3 style=\"font-family:var(--font-inter);font-size:18px;font-weight:600;color:var(--color-midnight-ink);letter-spacing:-0.72px;line-height:1.4;margin:0 0 12px 0;\">Site Access and Safety</h3><p style=\"font-family:var(--font-inter);font-size:16px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.64px;line-height:1.6;margin:0 0 16px 0;\">You may not access or use, or attempt to access or use, the Website and Services to take any action that could harm Expo, its providers, or any other third party, or to interfere with the operation of the Website and Services.</p><p style=\"font-family:var(--font-inter);font-size:16px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.64px;line-height:1.6;margin:0 0 12px 0;\">For example, and without limitation, you may not</p><ul style=\"margin:0 0 28px 0;padding-left:24px;display:flex;flex-direction:column;gap:8px;\"><li style=\"font-family:var(--font-inter);font-size:16px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.64px;line-height:1.6;\">allow any other person to use the Service under your account, or otherwise transfer your access to the Services to any third party</li><li style=\"font-family:var(--font-inter);font-size:16px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.64px;line-height:1.6;\">use the Services as the basis for developing a competitive solution (or contract with a third party to do so)</li><li style=\"font-family:var(--font-inter);font-size:16px;font-weight:400;color:var(--color-midnight-ink);letter-spacing:-0.64px;line-height:1.6;\">attempt to decipher, decompile, disassemble, or reverse-engineer any of the software comprising or in any way making up a part of the Services</li></ul><div style=\"border-top:1px solid var(--color-parchment-gray);padding-top:24px;\"><p style=\"font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-cool-gray);letter-spacing:-0.48px;line-height:1.6;margin:0 0 12px 0;text-transform:uppercase;\">Policy Categories</p><div style=\"display:flex;flex-wrap:wrap;gap:8px;\"><span style=\"display:inline-flex;align-items:center;font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-midnight-ink);background:var(--color-whisper-gray);border-radius:9999px;padding:4px 12px;letter-spacing:-0.48px;line-height:1.6;\">User Safety</span><span style=\"display:inline-flex;align-items:center;font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-midnight-ink);background:var(--color-whisper-gray);border-radius:9999px;padding:4px 12px;letter-spacing:-0.48px;line-height:1.6;\">Site Access</span><span style=\"display:inline-flex;align-items:center;font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-midnight-ink);background:var(--color-whisper-gray);border-radius:9999px;padding:4px 12px;letter-spacing:-0.48px;line-height:1.6;\">Information Usage</span><span style=\"display:inline-flex;align-items:center;font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-midnight-ink);background:var(--color-whisper-gray);border-radius:9999px;padding:4px 12px;letter-spacing:-0.48px;line-height:1.6;\">Privacy</span><span style=\"display:inline-flex;align-items:center;font-family:var(--font-inter);font-size:12px;font-weight:500;color:var(--color-ghost-white);background:var(--color-expo-blue);border-radius:9999px;padding:4px 12px;letter-spacing:-0.48px;line-height:1.6;\">Compliance</span></div></div></div>",
