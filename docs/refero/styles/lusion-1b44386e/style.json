        {
          "html": "<div style=\"--color-absolute-black:#000000;--color-canvas-white:#ffffff;--color-whisper-off-white:#f0f1fa;--color-storm-gray:#2b2e3a;--color-button-white:#e4e6ef;--color-dark-surface:#121416;--color-deep-space-blue:#1a2ffb;--color-electric-lime:#c1ff00;--font-aeonik:system-ui,sans-serif;font-family:var(--font-aeonik);background:var(--color-whisper-off-white);padding:40px;min-width:320px;\">\n  <div style=\"background:var(--color-canvas-white);border-radius:15px;padding:32px;box-shadow:rgba(0,0,0,0.04) 0px 6px 10px 0px,rgba(0,0,0,0.04) 0px 2px 4px 0px;\">\n    <p style=\"font-family:var(--font-aeonik);font-size:11px;font-weight:500;color:rgba(0,0,0,0.4);letter-spacing:0.1em;text-transform:uppercase;margin:0 0 20px 0;\">Start a project</p>\n    <h3 style=\"font-family:var(--font-aeonik);font-size:26px;font-weight:500;color:var(--color-absolute-black);letter-spacing:-0.02em;line-height:1.15;margin:0 0 28px 0;\">Let's build something<br>extraordinary together.</h3>\n    <div style=\"display:flex;flex-direction:column;gap:13px;\">\n      <div style=\"position:relative;\">\n        <label style=\"font-family:var(--font-aeonik);font-size:12px;font-weight:500;color:rgba(0,0,0,0.45);letter-spacing:-0.02em;display:block;margin-bottom:6px;\">Your name</label>\n        <div style=\"background:var(--color-whisper-off-white);border-radius:18px;padding:18px 25px;font-family:var(--font-aeonik);font-size:14px;color:var(--color-absolute-black);letter-spacing:-0.02em;\">Alex Johnson</div>\n      </div>\n      <div>\n        <label style=\"font-family:var(--font-aeonik);font-size:12px;font-weight:500;color:rgba(0,0,0,0.45);letter-spacing:-0.02em;display:block;margin-bottom:6px;\">Email address</label>\n        <div style=\"background:var(--color-whisper-off-white);border-radius:18px;padding:18px 25px;font-family:var(--font-aeonik);font-size:14px;color:rgba(0,0,0,0.35);letter-spacing:-0.02em;\">hello@yourbrand.com</div>\n      </div>\n      <div>\n        <label style=\"font-family:var(--font-aeonik);font-size:12px;font-weight:500;color:rgba(0,0,0,0.45);letter-spacing:-0.02em;display:block;margin-bottom:6px;\">Project type</label>\n        <div style=\"background:var(--color-whisper-off-white);border-radius:18px;padding:18px 25px;font-family:var(--font-aeonik);font-size:14px;color:rgba(0,0,0,0.35);letter-spacing:-0.02em;display:flex;justify-content:space-between;align-items:center;\">3D Web Experience <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4l4 4 4-4\" stroke=\"#000\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>\n      </div>\n      <div style=\"border:1.5px solid var(--color-deep-space-blue);border-radius:18px;padding:18px 25px;background:var(--color-whisper-off-white);\">\n        <label style=\"font-family:var(--font-aeonik);font-size:12px;font-weight:500;color:var(--color-deep-space-blue);letter-spacing:-0.02em;display:block;margin-bottom:6px;\">Tell us about your vision</label>\n        <div style=\"font-family:var(--font-aeonik);font-size:14px;color:var(--color-absolute-black);letter-spacing:-0.02em;line-height:1.5;\">We want to create an immersive brand world...</div>\n      </div>\n    </div>\n    <div style=\"margin-top:24px;display:flex;justify-content:flex-end;\">\n      <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:10px;background:var(--color-storm-gray);color:var(--color-canvas-white);font-family:var(--font-aeonik);font-size:14px;font-weight:500;letter-spacing:-0.02em;border-radius:87.5px;padding:14px 16px 14px 23px;text-decoration:none;\">SEND MESSAGE <span style=\"display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;background:rgba(255,255,255,0.1);border-radius:50;\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M1 9L9 1M9 1H3M9 1V7\" stroke=\"#fff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span></a>\n    </div>\n  </div>\n</div>",
