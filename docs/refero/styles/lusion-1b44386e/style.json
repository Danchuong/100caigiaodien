      "components": [
        {
          "html": "<div style=\"--color-absolute-black:#000000;--color-canvas-white:#ffffff;--color-whisper-off-white:#f0f1fa;--color-storm-gray:#2b2e3a;--color-button-white:#e4e6ef;--color-dark-surface:#121416;--color-deep-space-blue:#1a2ffb;--color-electric-lime:#c1ff00;--font-aeonik:system-ui,sans-serif;background:var(--color-whisper-off-white);padding:48px 40px;display:flex;flex-direction:column;align-items:center;gap:24px;font-family:var(--font-aeonik);min-width:320px;\">\n  <p style=\"font-family:var(--font-aeonik);font-size:13px;font-weight:500;color:var(--color-absolute-black);letter-spacing:0.08em;text-transform:uppercase;margin:0 0 8px 0;opacity:0.5;\">Get in touch</p>\n  <h2 style=\"font-family:var(--font-aeonik);font-size:36px;font-weight:500;color:var(--color-absolute-black);letter-spacing:-0.02em;line-height:1.1;margin:0 0 16px 0;text-align:center;\">Ready to stand out?</h2>\n  <div style=\"display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:center;\">\n    <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:10px;background:var(--color-storm-gray);color:var(--color-canvas-white);font-family:var(--font-aeonik);font-size:14px;font-weight:500;letter-spacing:-0.02em;border-radius:87.5px;padding:14px 16px 14px 23px;text-decoration:none;box-shadow:rgba(0,0,0,0.04) 0px 6px 10px 0px,rgba(0,0,0,0.04) 0px 2px 4px 0px;white-space:nowrap;\">LET'S TALK <span style=\"display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;background:rgba(255,255,255,0.12);border-radius:50;\">&#x2022;</span></a>\n    <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:10px;background:var(--color-button-white);color:var(--color-absolute-black);font-family:var(--font-aeonik);font-size:14px;font-weight:500;letter-spacing:-0.02em;border-radius:87.5px;padding:14px 16px 14px 23px;text-decoration:none;white-space:nowrap;\">VIEW WORK <span style=\"display:inline-flex;align-items:center;justify-content:center;width:26p