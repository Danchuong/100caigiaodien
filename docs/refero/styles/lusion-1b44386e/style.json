        {
          "html": "<div style=\"--color-absolute-black:#000000;--color-canvas-white:#ffffff;--color-whisper-off-white:#f0f1fa;--color-storm-gray:#2b2e3a;--color-button-white:#e4e6ef;--color-dark-surface:#121416;--color-deep-space-blue:#1a2ffb;--color-electric-lime:#c1ff00;--font-aeonik:system-ui,sans-serif;font-family:var(--font-aeonik);background:var(--color-whisper-off-white);padding:40px 40px 0 40px;min-width:320px;\">\n  <div style=\"margin-bottom:32px;\">\n    <p style=\"font-family:var(--font-aeonik);font-size:38px;font-weight:500;color:var(--color-absolute-black);letter-spacing:-0.02em;line-height:1.15;margin:0;\">We create 3D visual storytelling and interactive web experiences that help brands stand out</p>\n  </div>\n  <div style=\"border-radius:15px;overflow:hidden;background:var(--color-dark-surface);height:200px;position:relative;margin-bottom:0;\">\n    <div style=\"position:absolute;inset:0;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 40%,#0f3460 70%,#1a2ffb22 100%);border-radius:15px;\"></div>\n    <div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\">\n      <div style=\"display:flex;gap:18px;\">\n        <div style=\"width:52px;height:52px;background:var(--color-deep-space-blue);border-radius:50%;opacity:0.85;\"></div>\n        <div style=\"width:52px;height:52px;background:#3a3a3a;border-radius:50%;opacity:0.7;\"></div>\n        <div style=\"width:52px;height:52px;background:var(--color-absolute-black);border-radius:50%;opacity:0.9;\"></div>\n        <div style=\"width:52px;height:52px;background:#888;border-radius:50%;opacity:0.6;\"></div>\n      </div>\n    </div>\n    <div style=\"position:absolute;top:12px;left:16px;font-family:var(--font-aeonik);font-size:11px;font-weight:500;color:rgba(255,255,255,0.35);letter-spacing:0.06em;text-transform:uppercase;\">3D Canvas</div>\n  </div>\n  <div style=\"display:flex;align-items:center;border-top:1px solid rgba(0,0,0,0.1);padding:14px 0;margin-top:0;\">