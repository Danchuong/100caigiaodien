      "components": [
        {
          "html": "<div style=\"--color-canvas-white:#ffffff;--color-type-black:#000000;--color-charcoal-text:#282828;--color-surface-gray:#f4f4f4;--color-sunset-orange:#ec520b;--font-custom37866:'Helvetica Neue',Arial,sans-serif;--font-apple-system:-apple-system,system-ui,sans-serif;width:600px;background:var(--color-canvas-white);padding:56px 48px 60px 48px;box-sizing:border-box;font-family:var(--font-apple-system);\">\n  <h1 style=\"font-family:var(--font-custom37866);font-size:72px;font-weight:400;line-height:1.0;letter-spacing:-0.050em;color:var(--color-type-black);margin:0 0 36px 0;padding:0;\">Design and launch outstanding websites</h1>\n  <a href=\"#\" style=\"display:inline-block;background:var(--color-sunset-orange);color:var(--color-canvas-white);font-family:var(--font-custom37866);font-size:16px;font-weight:400;letter-spacing:-0.014em;line-height:1.0;padding:14px 28px;border-radius:200px;text-decoration:none;border:none;cursor:pointer;\">Try Readymag</a>\n</div>",
          "name": "Call-to-Action Hero Headline Block",
          "role": "",
          "description": ""
        },
        {
          "html": "<div style=\"--color-canvas-white:#ffffff;--color-type-black:#000000;--color-charcoal-text:#282828;--color-sunset-orange:#ec520b;--color-vivid-yellow:#ffcc00;--color-warning-orange:#ff5000;--font-custom37866:'Helvetica Neue',Arial,sans-serif;--font-apple-system:-apple-system,system-ui,sans-serif;width:600px;display:flex;gap:12px;box-sizing:border-box;font-family:var(--font-apple-system);\">\n  <!-- Dark card -->\n  <div style=\"flex:1;background:#111111;border-radius:20px;padding:36px 32px 36px 32px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;min-height:320px;\">\n    <h2 style=\"font-family:var(--font-custom37866);font-size:38px;font-weight:400;line-height:1.0;letter-spacing:-0.050em;color:var(--color-canvas-white);margin:0 0 24px 0;padding:0;\">Attract with interactivity</h2>\n    <p style=\"font-family:var(--font-apple-system);font-size:15px;line-height:1.5;letter-spacing:-0.006em;color:#aaaaaa;margin:0;padding:0;\">Add multi-step animations, custom cursors, shadows, slideshows, galleries and hotspots and make objects behave in ways you can imagine.</p>\n  </div>\n  <!-- Yellow card -->\n  <div style=\"flex:1;background:var(--color-vivid-yellow);border-radius:20px;padding:36px 32px 36px 32px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;min-height:320px;\">\n    <h2 style=\"font-family:var(--font-custom37866);font-size:38px;font-weight:400;line-height:1.0;letter-spacing:-0.050em;color:var(--color-type-black);margin:0 0 24px 0;padding:0;\">Streamline teamwork</h2>\n    <div style=\"display:flex;flex-direction:column;gap:4px;\">\n      <span style=\"font-family:var(--font-custom37866);font-size:28px;font-weight:400;letter-spacing:-0.044em;color:rgba(0,0,0,0.28);line-height:1.1;\">Preview</span>\n      <span style=\"font-family:var(--font-custom37866);font-size:28px;font-weight:700;letter-spacing:-0.044em;color:var(--color-type-black);line-height:1.1;\">Collaborate</span>\n      <span style=\"font-family:var(--font-custom37866);font-size:28px;font-weight:700;letter-spacing:-0.044em;color:var(--color-type-black);line-height:1.1;\">Connect domain</span>\n      <span style=\"font-family:var(--font-custom37866);font-size:28px;font-weight:700;letter-spacing:-0.044em;color:var(--color-type-black);line-height:1.1;\">Publish</span>\n      <span style=\"font-family:var(--font-custom37866);font-size:28px;font-weight:400;letter-spacing:-0.044em;color:rgba(0,0,0,0.28);line-height:1.1;\">Delete</span>\n    </div>\n    <p style=\"font-family:var(--font-apple-system);font-size:14px;line-height:1.5;letter-spacing:-0.006em;color:var(--color-type-black);margin:16px 0 0 0;padding:0;\">Invite co-creators and allow them to either work on the overall web design or just safely tweak the content.</p>\n  </div>\n</div>",
