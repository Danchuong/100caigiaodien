        {
          "html": "<style>\n  :root {\n    --color-storm-graphite: #252422;\n    --color-canvas-white: #ffffff;\n    --color-cloud-whisper: #f4f4f4;\n    --color-subtle-ash: #5e5e5e;\n    --color-azalea-frost: #f9cdcd;\n    --font-sctogroteska: 'Inter', sans-serif;\n  }\n\n  .showcase-section {\n    background: var(--color-cloud-whisper);\n    width: 600px;\n    box-sizing: border-box;\n    padding: 40px 40px 50px 40px;\n    font-family: var(--font-sctogroteska);\n  }\n\n  .showcase-cta-row {\n    display: flex;\n    align-items: center;\n    margin-bottom: 40px;\n  }\n\n  .see-work-btn {\n    display: inline-block;\n    font-family: var(--font-sctogroteska);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-storm-graphite);\n    background: transparent;\n    border: 1px solid var(--color-storm-graphite);\n    border-radius: 50px;\n    padding: 12px 24px;\n    text-decoration: none;\n    letter-spacing: 0.04em;\n    text-transform: uppercase;\n    cursor: pointer;\n    line-height: 1.4;\n  }\n\n  .showcase-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 24px;\n    align-items: start;\n  }\n\n  .work-card {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n  }\n\n  .work-card-image {\n    width: 100%;\n    height: 200px;\n    border-radius: 0;\n    object-fit: cover;\n    display: block;\n    overflow: hidden;\n  }\n\n  .work-card-image-patagonia {\n    background: linear-gradient(160deg, #b8a89a 0%, #8c7a6e 30%, #6b5a4e 60%, #c8a882 100%);\n    width: 100%;\n    height: 200px;\n  }\n\n  .work-card-image-wilson {\n    background: linear-gradient(140deg, #e8e4e0 0%, #d4ccc8 40%, #c0b8b4 100%);\n    width: 100%;\n    height: 200px;\n  }\n\n  .work-card-image-google {\n    background: linear-gradient(135deg, #e0dcd8 0%, #c8c4c0 50%, #b4b0ac 100%);\n    width: 100%;\n    height: 200px;\n  }\n\n  .work-card-body {\n    padding: 16px 0 0 0;\n  }\n\n  .work-card-title {\n    font-family: var(--font-sctogroteska);\n    font-size: 14px;\n    font-weight: 700;\n    color: var(--color-storm-graphite);\n    letter-spacing: -0.0140em;\n    line-height: 1.1;\n    text-transform: uppercase;\n    margin: 0 0 8px 0;\n  }\n\n  .work-card-desc {\n    font-family: var(--font-sctogroteska);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-storm-graphite);\n    letter-spacing: -0.0100em;\n    line-height: 1.4;\n    text-transform: uppercase;\n    margin: 0;\n  }\n\n  .work-card-text-only {\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    padding-top: 8px;\n  }\n</style>\n<div class=\"showcase-section\">\n  <div class=\"showcase-cta-row\">\n    <a class=\"see-work-btn\" href=\"#\">SEE THE WORK</a>\n  </div>\n  <div class=\"showcase-grid\">\n    <div class=\"work-card\">\n      <div class=\"work-card-image work-card-image-patagonia\"></div>\n      <div class=\"work-card-body\">\n        <div class=\"work-card-title\">PATAGONIA</div>\n        <div class=\"work-card-desc\">AN ECOMMERCE EXPERIENCE DRIVEN BY PATAGONIA'S BRAND MISSION</div>\n      </div>\n    </div>\n    <div class=\"work-card\">\n      <div class=\"work-card-image work-card-image-wilson\"></div>\n      <div class=\"work-card-body\">\n        <div class=\"work-card-title\">WILSON</div>\n        <div class=\"work-card-desc\">A CENTURY-OLD SPORTS BRAND FINDING ITS PLACE IN CULTURE</div>\n      </div>\n    </div>\n  </div>\n  <div style=\"margin-top:24px;display:flex;gap:24px;align-items:flex-start;\">\n    <div class=\"work-card\" style=\"flex:1;\">\n      <div class=\"work-card-image work-card-image-google\"></div>\n      <div class=\"work-card-body\">\n        <div class=\"work-card-title\">GOOGLE STORE</div>\n        <div class=\"work-card-desc\">AN ECOMMERCE EXPERIENCE HELPING GOOGLE BRING ITS HARDWARE TO PEOPLE ACROSS THE GLOBE</div>\n      </div>\n    </div>\n    <div style=\"flex:1;\"></div>\n  </div>\n</div>",
          "name": "Work Showcase Cards",
          "role": "",
          "description": ""
