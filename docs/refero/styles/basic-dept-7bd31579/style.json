      "components": [
        {
          "html": "<style>\n  :root {\n    --color-storm-graphite: #252422;\n    --color-canvas-white: #ffffff;\n    --color-cloud-whisper: #f4f4f4;\n    --color-subtle-ash: #5e5e5e;\n    --color-azalea-frost: #f9cdcd;\n    --font-sctogroteska: 'Inter', sans-serif;\n  }\n\n  .watch-reel-wrapper {\n    background: var(--color-cloud-whisper);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    min-height: 340px;\n    width: 600px;\n    box-sizing: border-box;\n    font-family: var(--font-sctogroteska);\n  }\n\n  .watch-reel-btn {\n    width: 140px;\n    height: 140px;\n    border-radius: 50%;\n    background: var(--color-canvas-white);\n    border: none;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    text-decoration: none;\n    flex-direction: column;\n    box-sizing: border-box;\n  }\n\n  .watch-reel-btn span {\n    font-family: var(--font-sctogroteska);\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--color-storm-graphite);\n    letter-spacing: -0.0130em;\n    line-height: 1.2;\n    text-align: center;\n    text-transform: uppercase;\n    display: block;\n  }\n\n  .watch-reel-caption {\n    margin-top: 20px;\n    font-family: var(--font-sctogroteska);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-subtle-ash);\n    letter-spacing: -0.0100em;\n    line-height: 1.4;\n    text-align: center;\n    text-transform: uppercase;\n  }\n</style>\n<div class=\"watch-reel-wrapper\">\n  <a class=\"watch-reel-btn\" href=\"#\">\n    <span>WATCH</span>\n    <span>REEL</span>\n  </a>\n  <div class=\"watch-reel-caption\">BASIC/DEPT®<br>2010—</div>\n</div>",
          "name": "Watch Reel CTA Button",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-storm-graphite: #252422;\n    --color-canvas-white: #ffffff;\n    --color-cloud-whisper: #f4f4f4;\n    --color-subtle-ash: #5e5e5e;\n    --color-azalea-frost: #f9cdcd;\n    --font-sctogroteska: 'Inter', sans-serif;\n  }\n\n  .awards-section {\n    background: var(--color-cloud-whisper);\n    width: 600px;\n    box-sizing: border-box;\n    padding: 60px 40px 60px 40px;\n    font-family: var(--font-sctogroteska);\n  }\n\n  .awards-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 0;\n    align-items: start;\n  }\n\n  .award-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 28px;\n    padding: 0 16px;\n  }\n\n  .award-item + .award-item {\n    border-left: 1px solid rgba(37,36,34,0.12);\n  }\n\n  .award-logo {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 56px;\n  }\n\n  .award-logo-text {\n    font-family: var(--font-sctogroteska);\n    font-size: 28px;\n    font-weight: 700;\n    color: var(--color-storm-graphite);\n    letter-spacing: -0.035em;\n    line-height: 1.0;\n    text-align: center;\n  }\n\n  .award-logo-text.adage {\n    font-size: 30px;\n    font-style: italic;\n  }\n\n  .award-logo-block {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n  }\n\n  .award-logo-block .logo-top {\n    font-family: var(--font-sctogroteska);\n    font-size: 10px;\n    font-weight: 400;\n    color: var(--color-storm-graphite);\n    letter-spacing: 0.04em;\n    line-height: 1.4;\n    text-transform: uppercase;\n  }\n\n  .award-logo-block .logo-main {\n    font-family: var(--font-sctogroteska);\n    font-size: 22px;\n    font-weight: 700;\n    color: var(--color-storm-graphite);\n    letter-spacing: -0.035em;\n    line-height: 1.0;\n    text-transform: uppercase;\n  }\n\n  .award-logo-block .logo-sub {\n    font-family: var(--font-sctogroteska);\n    font-size: 10px;\n    font-weight: 400;\n    color: var(--color-storm-graphite);\n    letter-spacing: 0.06em;\n    line-height: 1.4;\n    text-transform: uppercase;\n  }\n\n  .award-label {\n    font-family: var(--font-sctogroteska);\n    font-size: 10px;\n    font-weight: 400;\n    color: var(--color-storm-graphite);\n    letter-spacing: 0.04em;\n    line-height: 1.4;\n    text-align: center;\n    text-transform: uppercase;\n  }\n\n  .divider {\n    width: 100%;\n    height: 1px;\n    background: rgba(37,36,34,0.15);\n    margin-top: 50px;\n  }\n</style>\n<div class=\"awards-section\">\n  <div class=\"awards-grid\">\n    <div class=\"award-item\">\n      <div class=\"award-logo\">\n        <span class=\"award-logo-text adage\">AdAge</span>\n      </div>\n      <div class=\"award-label\">Design and Branding<br>Agency of the Year</div>\n    </div>\n    <div class=\"award-item\">\n      <div class=\"award-logo\">\n        <div class=\"award-logo-block\">\n          <span class=\"logo-top\">THE</span>\n          <span class=\"logo-main\">WEBBY</span>\n          <span class=\"logo-sub\">AWARDS</span>\n        </div>\n      </div>\n      <div class=\"award-label\">Agency of the Year</div>\n    </div>\n    <div class=\"award-item\">\n      <div class=\"award-logo\">\n        <span class=\"award-logo-text\" style=\"font-size:22px;font-weight:400;letter-spacing:-0.02em;\">campaign<sup style=\"font-size:11px;vertical-align:super;\">US</sup></span>\n      </div>\n      <div class=\"award-label\">Digital Innovation Agency<br>of the Year Finalist</div>\n    </div>\n  </div>\n  <div class=\"divider\"></div>\n</div>",
          "name": "Awards Recognition Strip",
