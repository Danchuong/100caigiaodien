        {
          "html": "<div style=\"--color-obsidian:#000000;--color-ghost-white:#ffffff;--color-charcoal-accent:#0e0e12;--color-slate-text:#535457;--color-deep-black-text:#010205;--color-input-placeholder:#949598;--font-porsche-next:'Porsche Next',Inter,Montserrat,sans-serif;box-sizing:border-box;font-family:var(--font-porsche-next);background:var(--color-ghost-white);width:600px;padding:0;\">\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px;\">\n\n    <div style=\"background:var(--color-obsidian);border-radius:8px;overflow:hidden;position:relative;cursor:pointer;\">\n      <div style=\"width:100%;height:280px;background:linear-gradient(160deg,#1c1c1e 0%,#2a2a2e 40%,#111 100%);position:relative;display:flex;align-items:flex-end;\">\n        <div style=\"position:absolute;top:0;left:0;right:0;bottom:0;background:repeating-linear-gradient(45deg,transparent,transparent 40px,rgba(255,255,255,0.01) 40px,rgba(255,255,255,0.01) 80px);\"></div>\n        <div style=\"position:absolute;top:20px;left:50%;transform:translateX(-50%);\">\n          <span style=\"font-family:var(--font-porsche-next);font-size:43px;font-weight:600;color:var(--color-ghost-white);letter-spacing:-0.01em;font-style:italic;\">911</span>\n        </div>\n        <div style=\"width:100%;height:120px;background:linear-gradient(to top,rgba(0,0,0,0.9),transparent);position:absolute;bottom:0;\"></div>\n        <div style=\"width:90%;height:60px;background:linear-gradient(90deg,#2a2a2e 0%,#1a1a1e 50%,#2a2a2e 100%);border-radius:30px 30px 0 0;margin:0 auto;position:relative;z-index:1;flex-shrink:0;\"></div>\n      </div>\n      <div style=\"padding:16px 20px 24px 20px;\">\n        <p style=\"font-family:var(--font-porsche-next);font-size:14px;font-weight:400;color:var(--color-input-placeholder);margin:0 0 4px 0;line-height:1.5;\">Deportivo icónico</p>\n        <h3 style=\"font-family:var(--font-porsche-next);font-size:22px;font-weight:600;color:var(--color-ghost-white);margin:0 0 12px 0;line-heig