var(--font-porsche-next);font-size:22px;font-weight:600;color:var(--color-ghost-white);margin:0 0 12px 0;line-height:1.26;\">718</h3>\n        <a href=\"#\" style=\"font-family:var(--font-porsche-next);font-size:14px;font-weight:400;color:var(--color-ghost-white);text-decoration:none;display:inline-flex;align-items:center;gap:6px;border-bottom:1px solid rgba(255,255,255,0.3);padding-bottom:1px;\">Descubrir\n          <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M2 6h8M7 3l3 3-3 3\" stroke=\"#fff\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </a>\n      </div>\n    </div>\n\n  </div>\n</div>",
