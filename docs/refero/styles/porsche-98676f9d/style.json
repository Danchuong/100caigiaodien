      "components": [
        {
          "html": "<div style=\"--color-obsidian:#000000;--color-ghost-white:#ffffff;--color-charcoal-accent:#0e0e12;--color-slate-text:#535457;--color-deep-black-text:#010205;--color-input-placeholder:#949598;--font-porsche-next:'Porsche Next',Inter,Montserrat,sans-serif;box-sizing:border-box;font-family:var(--font-porsche-next);background:var(--color-obsidian);width:600px;padding:48px 48px 52px 48px;position:relative;border-radius:8px;overflow:hidden;\">\n  <div style=\"position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,#1a1a1a 0%,#000 60%);z-index:0;\"></div>\n  <div style=\"position:relative;z-index:1;\">\n    <p style=\"font-family:var(--font-porsche-next);font-size:14px;font-weight:400;color:var(--color-input-placeholder);letter-spacing:0.08em;text-transform:uppercase;margin:0 0 24px 0;line-height:1.5;\">Nuevo modelo — Próximo lanzamiento</p>\n    <h1 style=\"font-family:var(--font-porsche-next);font-size:54px;font-weight:400;color:var(--color-ghost-white);margin:0 0 32px 0;line-height:1.19;\">Pulso a toda<br>velocidad.</h1>\n    <div style=\"display:flex;gap:0;margin-bottom:40px;\">\n      <div style=\"text-align:center;margin-right:24px;\">\n        <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:600;color:var(--color-ghost-white);line-height:1.21;display:block;\">2</span>\n        <span style=\"font-family:var(--font-porsche-next);font-size:12px;font-weight:400;color:var(--color-input-placeholder);letter-spacing:0.06em;text-transform:uppercase;\">días</span>\n      </div>\n      <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:400;color:var(--color-slate-text);line-height:1.21;margin-right:24px;display:flex;align-items:flex-start;padding-top:2px;\">:</span>\n      <div style=\"text-align:center;margin-right:24px;\">\n        <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:600;color:var(--color-ghost-white);line-height:1.21;display:block;\">20</span>\n        <span style=\"font-family:var(--font-porsche-next);font-size:12px;font-weight:400;color:var(--color-input-placeholder);letter-spacing:0.06em;text-transform:uppercase;\">horas</span>\n      </div>\n      <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:400;color:var(--color-slate-text);line-height:1.21;margin-right:24px;display:flex;align-items:flex-start;padding-top:2px;\">:</span>\n      <div style=\"text-align:center;margin-right:24px;\">\n        <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:600;color:var(--color-ghost-white);line-height:1.21;display:block;\">46</span>\n        <span style=\"font-family:var(--font-porsche-next);font-size:12px;font-weight:400;color:var(--color-input-placeholder);letter-spacing:0.06em;text-transform:uppercase;\">min</span>\n      </div>\n      <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:400;color:var(--color-slate-text);line-height:1.21;margin-right:24px;display:flex;align-items:flex-start;padding-top:2px;\">:</span>\n      <div style=\"text-align:center;\">\n        <span style=\"font-family:var(--font-porsche-next);font-size:33px;font-weight:600;color:var(--color-ghost-white);line-height:1.21;display:block;\">39</span>\n        <span style=\"font-family:var(--font-porsche-next);font-size:12px;font-weight:400;color:var(--color-input-placeholder);letter-spacing:0.06em;text-transform:uppercase;\">seg</span>\n      </div>\n    </div>\n    <a href=\"#\" style=\"display:inline-block;font-family:var(--font-porsche-next);font-size:16px;font-weight:400;color:var(--color-ghost-white);background:transparent;border:1px solid var(--color-ghost-white);border-radius:12px;padding:12px 28px;text-decoration:none;letter-spacing:0.02em;transition:background 0.2s;\">Descubra más →</a>\n  </div>\n</div>",
