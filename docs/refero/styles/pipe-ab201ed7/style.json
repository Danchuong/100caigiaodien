        {
          "html": "<div style=\"--color-midnight-core:#000000;--color-ivory-canvas:#ffffff;--color-slate-text:#808080;--color-onyx-layer:#1a1a1a;--color-ghost-white:#f5f5f5;--color-molten-orange:#e2572c;--font-suisse-font:'Inter',sans-serif;background:var(--color-midnight-core);padding:48px 32px;box-sizing:border-box;width:100%;font-family:var(--font-suisse-font);\"><p style=\"margin:0 0 8px 0;font-family:var(--font-suisse-font);font-size:12px;font-weight:400;color:var(--color-slate-text);letter-spacing:0.006em;text-transform:uppercase;\">By the numbers</p><h2 style=\"margin:0 0 40px 0;font-family:var(--font-suisse-font);font-size:24px;font-weight:400;color:var(--color-ivory-canvas);line-height:1.33;letter-spacing:-0.007em;\">Trusted by platforms moving real money</h2><div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;background:#111;\"><div style=\"background:var(--color-midnight-core);padding:32px 24px;box-sizing:border-box;\"><p style=\"margin:0 0 4px 0;font-family:var(--font-suisse-font);font-size:32px;font-weight:400;color:var(--color-ivory-canvas);line-height:1.25;letter-spacing:-0.007em;\">$3B<span style=\"color:var(--color-molten-orange);\">+</span></p><p style=\"margin:0;font-family:var(--font-suisse-font);font-size:13px;font-weight:400;color:var(--color-slate-text);line-height:1.63;\">Capital deployed to businesses</p></div><div style=\"background:var(--color-midnight-core);padding:32px 24px;box-sizing:border-box;\"><p style=\"margin:0 0 4px 0;font-family:var(--font-suisse-font);font-size:32px;font-weight:400;color:var(--color-ivory-canvas);line-height:1.25;letter-spacing:-0.007em;\">150<span style=\"color:var(--color-molten-orange);\">+</span></p><p style=\"margin:0;font-family:var(--font-suisse-font);font-size:13px;font-weight:400;color:var(--color-slate-text);line-height:1.63;\">Platform partners worldwide</p></div><div style=\"background:var(--color-midnight-core);padding:32px 24px;box-sizing:border-box;\"><p style=\"margin:0 0 4px 0;font-family:var(--font-suisse-font);font-size:32px;font-weight:400;color:var(--color-ivory-canvas);line-height:1.25;letter-spacing:-0.007em;\">24h<span style=\"color:var(--color-molten-orange);\"></span></p><p style=\"margin:0;font-family:var(--font-suisse-font);font-size:13px;font-weight:400;color:var(--color-slate-text);line-height:1.63;\">Average time to first payout</p></div></div><div style=\"margin-top:32px;background:var(--color-onyx-layer);border-radius:16px;padding:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;box-sizing:border-box;\"><div><p style=\"margin:0 0 4px 0;font-family:var(--font-suisse-font);font-size:14px;font-weight:400;color:var(--color-ivory-canvas);line-height:1.43;\">Ready to embed financial tools in your platform?</p><p style=\"margin:0;font-family:var(--font-suisse-font);font-size:13px;font-weight:400;color:var(--color-slate-text);line-height:1.63;\">Talk to our team and get live in weeks, not months.</p></div><a href=\"#\" style=\"flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;background:var(--color-molten-orange);color:var(--color-midnight-core);font-family:var(--font-suisse-font);font-size:14px;font-weight:400;line-height:1.43;padding:12px 20px;border-radius:8px;text-decoration:none;white-space:nowrap;\">Book a demo</a></div></div>",
