      "components": [
        {
          "html": "<style>\n  :root {\n    --color-pitch-black: #000000;\n    --color-pure-white: #ffffff;\n    --color-deep-shadow: #0a0a0a;\n    --color-mid-gray: #a3a3a3;\n    --color-near-black: #262626;\n    --font-abc-oracle: 'Inter', sans-serif;\n    --spacing-6: 6px;\n    --spacing-8: 8px;\n    --spacing-12: 12px;\n    --spacing-48: 48px;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap');\n\n  .writing-section {\n    background: var(--color-pitch-black);\n    width: 600px;\n    box-sizing: border-box;\n    padding: var(--spacing-12);\n    font-family: var(--font-abc-oracle);\n  }\n\n  .writing-header {\n    color: var(--color-pure-white);\n    font-size: 14px;\n    font-weight: 500;\n    font-family: var(--font-abc-oracle);\n    margin: 0 0 var(--spacing-48) 0;\n    padding: 0;\n  }\n\n  .writing-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 0;\n    align-items: start;\n  }\n\n  .writing-column {\n    display: flex;\n    flex-direction: column;\n    gap: 32px;\n  }\n\n  .writing-item {\n    display: flex;\n    flex-direction: column;\n    gap: var(--spacing-6);\n    cursor: pointer;\n    text-decoration: none;\n  }\n\n  .writing-item:hover .writing-title {\n    opacity: 0.7;\n  }\n\n  .writing-title {\n    color: var(--color-pure-white);\n    font-size: 14px;\n    font-weight: 500;\n    font-family: var(--font-abc-oracle);\n    line-height: 1.25;\n    margin: 0;\n    transition: opacity 0.15s ease;\n  }\n\n  .writing-date {\n    color: var(--color-mid-gray);\n    font-size: 14px;\n    font-weight: 400;\n    font-family: var(--font-abc-oracle);\n    line-height: 1.25;\n    margin: 0;\n  }\n</style>\n<div class=\"writing-section\">\n  <p class=\"writing-header\">Writing</p>\n  <div class=\"writing-grid\">\n    <div class=\"writing-column\">\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">On Feeling</span>\n        <span class=\"writing-date\">Oct 30, 2025</span>\n      </a>\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">Connection</span>\n        <span class=\"writing-date\">Mar 1, 2024</span>\n      </a>\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">Happy Pride Month</span>\n        <span class=\"writing-date\">May 31, 2023</span>\n      </a>\n    </div>\n    <div class=\"writing-column\">\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">Blog Questions Challenge</span>\n        <span class=\"writing-date\">Mar 15, 2025</span>\n      </a>\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">Only A Lifetime</span>\n        <span class=\"writing-date\">Jun 2, 2023</span>\n      </a>\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">The Creative Gap</span>\n        <span class=\"writing-date\">Mar 1, 2023</span>\n      </a>\n    </div>\n    <div class=\"writing-column\">\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">2024–2025</span>\n        <span class=\"writing-date\">Dec 31, 2024</span>\n      </a>\n      <a class=\"writing-item\" href=\"#\">\n        <span class=\"writing-title\">House of 1000 Mirrors</span>\n        <span class=\"writing-date\">May 31, 2023</span>\n      </a>\n    </div>\n  </div>\n</div>",
