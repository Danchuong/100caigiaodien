        {
          "html": "<style>\n  :root {\n    --color-pitch-black: #000000;\n    --color-pure-white: #ffffff;\n    --color-deep-shadow: #0a0a0a;\n    --color-near-black: #262626;\n    --color-mid-gray: #a3a3a3;\n    --color-faint-gray: #e5e5e5;\n    --font-abc-oracle: 'Inter', sans-serif;\n    --spacing-6: 6px;\n    --spacing-8: 8px;\n    --spacing-12: 12px;\n    --spacing-48: 48px;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap');\n\n  .project-wrapper {\n    background: var(--color-pure-white);\n    width: 600px;\n    box-sizing: border-box;\n    padding: var(--spacing-12);\n    font-family: var(--font-abc-oracle);\n  }\n\n  .project-card {\n    display: flex;\n    flex-direction: column;\n    gap: var(--spacing-12);\n    background: var(--color-pure-white);\n    padding: var(--spacing-12);\n    cursor: pointer;\n    text-decoration: none;\n    transition: background 0.15s ease;\n  }\n\n  .project-card:hover {\n    background: var(--color-pitch-black);\n  }\n\n  .project-card:hover .project-title,\n  .project-card:hover .project-desc,\n  .project-card:hover .project-meta {\n    color: var(--color-pure-white);\n  }\n\n  .project-card:hover .project-meta {\n    color: #a3a3a3;\n  }\n\n  .project-image {\n    width: 100%;\n    height: 200px;\n    background: var(--color-near-black);\n    border-radius: 4px;\n    overflow: hidden;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .project-image-inner {\n    width: 78%;\n    height: 80%;\n    background: #1a1a1a;\n    border-radius: 8px;\n    border: 1px solid #333;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n  }\n\n  .mock-topbar {\n    height: 16px;\n    background: #111;\n    border-bottom: 1px solid #2a2a2a;\n    display: flex;\n    align-items: center;\n    padding: 0 8px;\n    gap: 4px;\n    flex-shrink: 0;\n  }\n\n  .mock-dot {\n    width: 5px;\n    height: 5px;\n    border-radius: 50%;\n    background: #333;\n  }\n\n  .mock-body {\n    flex: 1;\n    display: flex;\n    gap: 0;\n    overflow: hidden;\n  }\n\n  .mock-sidebar {\n    width: 28%;\n    background: #0f0f0f;\n    border-right: 1px solid #222;\n    padding: 6px 4px;\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n  }\n\n  .mock-sidebar-item {\n    height: 4px;\n    background: #2a2a2a;\n    border-radius: 2px;\n    width: 80%;\n  }\n\n  .mock-sidebar-item.active {\n    background: #2d5aff;\n    width: 90%;\n  }\n\n  .mock-content {\n    flex: 1;\n    background: #161616;\n    padding: 6px;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .mock-row {\n    height: 3px;\n    background: #252525;\n    border-radius: 2px;\n  }\n\n  .mock-row.wide {\n    width: 90%;\n  }\n\n  .mock-row.short {\n    width: 50%;\n  }\n\n  .mock-row.medium {\n    width: 70%;\n  }\n\n  .project-info {\n    display: flex;\n    flex-direction: column;\n    gap: var(--spacing-6);\n  }\n\n  .project-title {\n    color: var(--color-pitch-black);\n    font-size: 14px;\n    font-weight: 500;\n    font-family: var(--font-abc-oracle);\n    line-height: 1.25;\n    margin: 0;\n    transition: color 0.15s ease;\n  }\n\n  .project-desc {\n    color: var(--color-pitch-black);\n    font-size: 14px;\n    font-weight: 400;\n    font-family: var(--font-abc-oracle);\n    line-height: 1.43;\n    margin: 0;\n    transition: color 0.15s ease;\n  }\n\n  .project-meta {\n    color: var(--color-mid-gray);\n    font-size: 14px;\n    font-weight: 400;\n    font-family: var(--font-abc-oracle);\n    line-height: 1.25;\n    margin: 0;\n    transition: color 0.15s ease;\n  }\n</style>\n<div class=\"project-wrapper\">\n  <a class=\"project-card\" href=\"#\">\n    <div class=\"project-image\">\n      <div class=\"project-image-inner\">\n        <div class=\"mock-topbar\">\n          <div class=\"mock-dot\"></div>\n          <div class=\"mock-dot\"></div>\n          <div class=\"mock-dot\"></div>\n        </div>\n        <div class=\"mock-body\">\n          <div class=\"mock-sidebar\">\n            <div class=\"mock-sidebar-item\"></div>\n            <div class=\"mock-sidebar-item active\"></div>\n            <div class=\"mock-sidebar-item\"></div>\n            <div class=\"mock-sidebar-item\"></div>\n            <div class=\"mock-sidebar-item\"></div>\n            <div class=\"mock-sidebar-item\"></div>\n            <div class=\"mock-sidebar-item\"></div>\n          </div>\n          <div class=\"mock-content\">\n            <div class=\"mock-row wide\"></div>\n            <div class=\"mock-row short\"></div>\n            <div class=\"mock-row medium\"></div>\n            <div class=\"mock-row wide\"></div>\n            <div class=\"mock-row short\"></div>\n            <div class=\"mock-row medium\"></div>\n            <div class=\"mock-row wide\"></div>\n            <div class=\"mock-row short\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"project-info\">\n      <p class=\"project-title\">Regpit</p>\n      <p class=\"project-desc\">Anti-money laundering process-management platform</p>\n      <p class=\"project-meta\">2024–2025 · Studio Lenzing</p>\n    </div>\n  </a>\n</div>",
