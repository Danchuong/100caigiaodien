          "html": "<div style=\"--color-dyson-ink:#333333;--color-ghost-gray:#999999;--color-canvas-white:#ffffff;--color-deep-graphite:#000000;--color-success-green:#79b928;--color-dyson-blue:#0066cc;--color-product-highlight-orange:#ac5d00;--color-warm-paper:#fff8e6;--color-light-silver:#ebebeb;--color-steel-gray:#dadada;--font-dysonfutura:'Futura Std',Futura,'Century Gothic',sans-serif;font-family:var(--font-dysonfutura);background:#f5f5f5;padding:32px;width:600px;box-sizing:border-box;\"><h2 style=\"font-family:var(--font-dysonfutura);font-size:28px;font-weight:500;color:var(--color-dyson-ink);margin:0 0 24px 0;line-height:1.22;\">Destacados</h2><div style=\"background:var(--color-canvas-white);border-radius:0;width:280px;display:flex;flex-direction:column;\"><div style=\"background:var(--color-canvas-white);padding:16px;border-bottom:1px solid var(--color-steel-gray);\"><div style=\"width:100%;height:220px;background:var(--color-canvas-white);display:flex;align-items:center;justify-content:center;\"><div style=\"width:120px;height:180px;background:linear-gradient(135deg,#c8d8e8 0%,#a0b8cc 50%,#7090a8 100%);border-radius:8px;position:relative;\"><div style=\"position:absolute;bottom:10px;left:50%;transform:translateX(-50%);width:40px;height:60px;background:linear-gradient(180deg,#e8a020 0%,#c07010 100%);border-radius:4px;\"></div></div></div><div style=\"margin-top:12px;\"><span style=\"display:inline-block;background:transparent;color:var(--color-product-highlight-orange);font-family:var(--font-dysonfutura);font-size:12px;font-weight:500;letter-spacing:0.5px;padding:0 0 4px 0;\">NUEVO</span><h3 style=\"font-family:var(--font-dysonfutura);font-size:16px;font-weight:400;color:var(--color-dyson-ink);margin:4px 0 0 0;line-height:1.4;\">Fregona eléctrica Dyson Clean+Wash Hygiene</h3></div></div><div style=\"padding:16px;\"><p style=\"font-family:var(--font-dysonfutura);font-size:22px;font-weight:500;color:var(--color-dyson-blue);margin:0 0 16px 0;\">499,00 €</p><but