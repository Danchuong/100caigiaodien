px solid var(--color-electric-yellow);border-radius:0px;padding:10px 24px;font-family:var(--font-univers-next-pro);font-size:14px;font-weight:400;cursor:pointer;letter-spacing:0em;line-height:1.2;\">Learn More →</button></div><div style=\"border-top:1px solid var(--color-asphalt-gray);padding-top:20px;display:flex;gap:32px;\"><div><div style=\"color:var(--color-electric-yellow);font-size:36px;font-weight:300;letter-spacing:-0.02em;line-height:1.13;font-family:var(--font-univers-next-pro);\">99.9%</div><div style=\"color:var(--color-industrial-silver);font-size:12px;font-family:var(--font-univers-next-pro);margin-top:4px;\">Uptime Guarantee</div></div><div><div style=\"color:var(--color-electric-yellow);font-size:36px;font-weight:300;letter-spacing:-0.02em;line-height:1.13;font-family:var(--font-univers-next-pro);\">500MW</div><div style=\"color:var(--color-industrial-silver);font-size:12px;font-family:var(--font-univers-next-pro);margin-top:4px;\">Deployed Capacity</div></div><div><div style=\"color:var(--color-electric-yellow);font-size:36px;font-weight:300;letter-spacing:-0.02em;line-height:1.13;font-family:var(--font-univers-next-pro);\">24/7</div><div style=\"color:var(--color-industrial-silver);font-size:12px;font-family:var(--font-univers-next-pro);margin-top:4px;\">Live Monitoring</div></div></div></div>",
