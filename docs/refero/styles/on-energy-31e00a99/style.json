          "html": "<div style=\"--color-midnight-steel:#000000;--color-data-center-graphite:#202020;--color-industrial-silver:#afafaf;--color-screen-white:#eeeeee;--color-electric-yellow:#fff313;--color-asphalt-gray:#4b4b4b;--font-univers-next-pro:'Inter',sans-serif;width:600px;box-sizing:border-box;padding:40px;background:var(--color-midnight-steel);font-family:var(--font-univers-next-pro);border-radius:9px;\"><div style=\"display:flex;gap:16px;align-items:stretch;\"><div style=\"flex:1;display:flex;flex-direction:column;justify-content:space-between;background:rgba(255,255,255,0.06);border-radius:9px;padding:24px;border:1px solid var(--color-asphalt-gray);\"><div><div style=\"display:flex;align-items:center;gap:8px;margin-bottom:16px;\"><span style=\"width:8px;height:8px;border-radius:50%;background:var(--color-electric-yellow);display:inline-block;\"></span><span style=\"color:var(--color-industrial-silver);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-family:var(--font-univers-next-pro);\">Discover AI UPS</span></div><div style=\"color:var(--color-screen-white);font-size:16px;font-weight:300;line-height:1.38;font-family:var(--font-univers-next-pro);margin-bottom:12px;\">The first medium voltage UPS purpose-built for grid-safe data centers.</div><div style=\"color:var(--color-industrial-silver);font-size:12px;line-height:1.5;font-family:var(--font-univers-next-pro);margin-bottom:20px;\">ON.energy's AI UPS integrates seamlessly with hyperscale infrastructure, providing resilient, intelligent power at unprecedented scale.</div></div><div style=\"display:flex;flex-direction:column;gap:10px;\"><div style=\"display:flex;align-items:center;gap:10px;padding:10px 0;border-top:1px solid var(--color-asphalt-gray);\"><div style=\"width:6px;height:6px;border-radius:1px;background:var(--color-electric-yellow);flex-shrink:0;\"></div><div style=\"color:var(--color-screen-white);font-size:12px;font-family:var(--font-univers-next-pro);\">Medium voltage architecture</div></div><div style=\"display:flex;align-items:center;gap:10px;padding:10px 0;border-top:1px solid var(--color-asphalt-gray);\"><div style=\"width:6px;height:6px;border-radius:1px;background:var(--color-electric-yellow);flex-shrink:0;\"></div><div style=\"color:var(--color-screen-white);font-size:12px;font-family:var(--font-univers-next-pro);\">AI-powered energy management</div></div><div style=\"display:flex;align-items:center;gap:10px;padding:10px 0;border-top:1px solid var(--color-asphalt-gray);\"><div style=\"width:6px;height:6px;border-radius:1px;background:var(--color-electric-yellow);flex-shrink:0;\"></div><div style=\"color:var(--color-screen-white);font-size:12px;font-family:var(--font-univers-next-pro);\">Grid-safe, zero-transfer switching</div></div><div style=\"display:flex;align-items:center;gap:10px;padding:10px 0;border-top:1px solid var(--color-asphalt-gray);\"><div style=\"width:6px;height:6px;border-radius:1px;background:var(--color-electric-yellow);flex-shrink:0;\"></div><div style=\"color:var(--color-screen-white);font-size:12px;font-family:var(--font-univers-next-pro);\">Modular, scalable deployment</div></div></div><button style=\"margin-top:24px;background:var(--color-electric-yellow);color:var(--color-midnight-steel);border:1.5px solid var(--color-midnight-steel);border-radius:6px;padding:10px 17px;font-family:var(--font-univers-next-pro);font-size:14px;font-weight:400;cursor:pointer;width:100%;text-align:center;\">Explore the Technology</button></div><div style=\"width:160px;flex-shrink:0;display:flex;flex-direction:column;gap:12px;\"><div style=\"flex:1;background:var(--color-data-center-graphite);border-radius:9px;overflow:hidden;border:1px solid var(--color-asphalt-gray);display:flex;align-items:center;justify-content:center;\"><div style=\"width:100%;height:140px;background:linear-gradient(135deg,#2a2a2a 0%,#1a1a1a 100%);border-radius:9px;display:flex;align-items:center;justify-content:center;\"><div style=\"width:60px;height:80