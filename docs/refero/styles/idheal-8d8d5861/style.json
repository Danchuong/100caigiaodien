    "designSystem": {
      "dos": [
        "Prioritize Ink Black text (#000000) on Canvas White (#ffffff) backgrounds for all primary content.",
        "Use Helvetica Neue LT Pro Medium for large headings to establish a serious and authoritative tone.",
