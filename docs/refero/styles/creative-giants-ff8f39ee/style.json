        {
          "html": "<style>:root{--color-canvas-white:#fffef7;--color-ink-black:#000000;--color-medium-gray:#666666;--color-light-gray:#aaaaaa;--color-vivid-orchid:#ffacea;--color-muted-teal:#a5ebd6;--font-switzer:system-ui,sans-serif;}*{box-sizing:border-box;margin:0;padding:0;}</style><div style=\"background:var(--color-canvas-white);font-family:var(--font-switzer);padding:48px 40px;width:600px;\"><p style=\"font-family:var(--font-switzer);font-size:12px;font-weight:400;color:var(--color-ink-black);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:16px;\">NEWS & OPINION</p><div style=\"display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;\"><h2 style=\"font-family:var(--font-switzer);font-size:54px;line-height:1.0;letter-spacing:-1.242px;font-weight:300;color:var(--color-ink-black);\">Stay up to date</h2><div style=\"display:flex;gap:8px;flex-shrink:0;margin-bottom:6px;\"><button style=\"width:40px;height:40px;border-radius:50%;border:1px solid var(--color-ink-black);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M10 3L5 8L10 13\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button><button style=\"width:40px;height:40px;border-radius:50%;border:1px solid var(--color-ink-black);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M6 3L11 8L6 13\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div></div><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:24px;\"><div style=\"display:flex;flex-direction:column;gap:12px;\"><div style=\"width:100%;height:160px;background:var(--color-vivid-orchid);border-radius:0px;overflow:hidden;\"><div style=\"width:100%;height:100%;background:linear-gradient(135deg,#ffacea 0%,#ee77cf 100%);\"></div></div><h3 style=\"font-family:var(--font-switzer);font-size:16px;font-weight:400;color:var(--color-ink-black);line-height:1.4;\">CALM Missed Birthdays Wins Big</h3><p style=\"font-family:var(--font-switzer);font-size:14px;font-weight:300;color:var(--color-medium-gray);line-height:1.5;\">There are certain projects that offer a sense of pride, regardless of how they're received in the industry.</p></div><div style=\"display:flex;flex-direction:column;gap:12px;\"><div style=\"width:100%;height:160px;background:var(--color-muted-teal);border-radius:0px;overflow:hidden;\"><div style=\"width:100%;height:100%;background:linear-gradient(135deg,#a5ebd6 0%,#48d1d6 100%);\"></div></div><h3 style=\"font-family:var(--font-switzer);font-size:16px;font-weight:400;color:var(--color-ink-black);line-height:1.4;\">Shoulders of Giants</h3><p style=\"font-family:var(--font-switzer);font-size:14px;font-weight:300;color:var(--color-medium-gray);line-height:1.5;\">Your monthly look at where we're finding inspiration in the world.</p></div></div></div>",
