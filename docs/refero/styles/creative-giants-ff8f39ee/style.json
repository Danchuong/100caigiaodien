          "html": "<style>:root{--color-canvas-white:#fffef7;--color-ink-black:#000000;--color-medium-gray:#666666;--font-switzer:system-ui,sans-serif;}*{box-sizing:border-box;margin:0;padding:0;}</style><div style=\"background:var(--color-canvas-white);font-family:var(--font-switzer);padding:32px;width:600px;display:flex;align-items:center;justify-content:space-between;\"><div style=\"display:flex;align-items:center;gap:16px;\"><div style=\"width:40px;height:40px;background:var(--color-ink-black);border-radius:50%;display:flex;align-items:center;justify-content:center;\"><span style=\"color:var(--color-canvas-white);font-family:var(--font-switzer);font-size:16px;font-weight:400;letter-spacing:-0.01em;\">G</span></div><div style=\"display:flex;flex-direction:column;gap:2px;\"><span style=\"font-family:var(--font-switzer);font-size:12px;font-weight:400;color:var(--color-ink-black);letter-spacing:0.04em;text-transform:uppercase;\">UNIQUE PUBLIC INTERVENTIONS</span><span style=\"font-family:var(--font-switzer);font-size:12px;font-weight:400;color:var(--color-ink-black);letter-spacing:0.04em;text-transform:uppercase;\">// IMMERSIVE ACTIVATIONS</span></div></div><button style=\"background:var(--color-ink-black);color:var(--color-canvas-white);font-family:var(--font-switzer);font-size:14px;font-weight:400;border:none;border-radius:1440px;padding:14px 24px;cursor:pointer;letter-spacing:0.01em;\">Menu</button></div>",
