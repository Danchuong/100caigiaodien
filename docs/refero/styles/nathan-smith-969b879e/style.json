: column; gap: 8px;\">\n      <div style=\"background: var(--color-fuchsia-burst); width: 100%; aspect-ratio: 1/1; border-radius: 0px; box-shadow: var(--shadow-xl);\"></div>\n      <div style=\"display: flex; justify-content: space-between; align-items: baseline;\">\n        <span style=\"font-family: var(--font-fk-display); font-size: 14px; font-weight: 400; color: var(--color-ghost-white); line-height: 1.2;\">→ NTS Radio</span>\n        <span style=\"font-family: var(--font-fk-display); font-size: 14px; font-weight: 400; color: var(--color-off-black); line-height: 1.2;\">NTS</span>\n      </div>\n    </div>\n\n    <!-- Card 4 -->\n    <div style=\"display: flex; flex-direction: column; gap: 8px;\">\n      <div style=\"background: var(--color-blazing-orange); width: 100%; aspect-ratio: 1/1; border-radius: 0px; box-shadow: var(--shadow-xl);\"></div>\n      <div style=\"display: flex; justify-content: space-between; align-items: baseline;\">\n        <span style=\"font-family: var(--font-fk-display); font-size: 14px; font-weight: 400; color: var(--color-ghost-white); line-height: 1.2;\">→ Kettle's Yard</span>\n        <span style=\"font-family: var(--font-fk-display); font-size: 14px; font-weight: 400; color: var(--color-off-black); line-height: 1.2;\">Freelance</span>\n      </div>\n    </div>\n\n  </div>\n</div>\n</div>",
