      "components": [
        {
          "html": "<style>\n  :root {\n    --color-greige-canvas: #faf6f0;\n    --color-midnight-ink: #000000;\n    --color-soft-graphite: #5e697f;\n    --color-pure-white: #ffffff;\n    --font-unbounded: 'Unbounded', 'Montserrat', 'Poppins', sans-serif;\n    --font-inter: 'Inter', sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Unbounded:wght@400;500&display=swap');\n</style>\n<div style=\"background: var(--color-greige-canvas); padding: 48px 40px; font-family: var(--font-inter); border: 1px solid var(--color-midnight-ink); display: flex; flex-direction: column; align-items: flex-start; gap: 32px; max-width: 600px; box-sizing: border-box;\">\n  <div style=\"display: flex; flex-direction: column; gap: 12px;\">\n    <h2 style=\"font-family: var(--font-unbounded); font-size: 34px; font-weight: 500; line-height: 1.2; letter-spacing: 0.01em; color: var(--color-midnight-ink); margin: 0;\">Start building today.</h2>\n    <p style=\"font-family: var(--font-inter); font-size: 18px; font-weight: 400; line-height: 1.6; letter-spacing: -0.02em; color: var(--color-soft-graphite); margin: 0;\">Join thousands of creative teams already using Hello Ivy to manage their projects effortlessly.</p>\n  </div>\n  <div style=\"display: flex; flex-wrap: wrap; gap: 12px; align-items: center;\">\n    <a href=\"#\" style=\"display: inline-flex; align-items: center; gap: 8px; background: var(--color-midnight-ink); color: var(--color-pure-white); font-family: var(--font-inter); font-size: 16px; font-weight: 600; letter-spacing: -0.02em; text-decoration: none; padding: 14px 28px; border-radius: 9999px; border: none; cursor: pointer;\">Get Started Free</a>\n    <a href=\"#\" style=\"display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--color-midnight-ink); font-family: var(--font-inter); font-size: 16px; font-weight: 600; letter-spacing: -0.02em; text-decoration: none; padding: 14px 28px; border-radius: 8px; border: 1.5px solid var(--color-midnight-ink); cursor: pointer;\">View Pricing</a>\n    <a href=\"#\" style=\"display: inline-flex; align-items: center; gap: 6px; background: transparent; color: var(--color-soft-graphite); font-family: var(--font-inter); font-size: 15px; font-weight: 400; letter-spacing: -0.02em; text-decoration: none; padding: 14px 4px; border-radius: 0; border: none; cursor: pointer;\">Log in <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M3 8h10M9 4l4 4-4 4\" stroke=\"#5e697f\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></a>\n  </div>\n  <p style=\"font-family: var(--font-inter); font-size: 13px; font-weight: 400; color: var(--color-soft-graphite); letter-spacing: -0.02em; margin: 0;\">No credit card required · Free 14-day trial · Cancel anytime</p>\n</div>",
