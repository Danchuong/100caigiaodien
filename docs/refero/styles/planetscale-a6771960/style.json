      "components": [
        {
          "html": "<div style=\"all:unset;display:block;box-sizing:border-box;font-family:'Courier New',Courier,monospace;--color-midnight-graphite:#111111;--color-ash-black:#000000;--color-cloud-white:#fafafa;--color-steel-gray:#414141;--color-smoke-gray:#737373;--color-stone-gray:#c1c1c1;--color-electric-blue:#0b6ec5;--color-flame-orange:#f35815;--color-marigold-yellow:#f2b600;--color-verdant-green:#22a652;--font-ui-monospace:'Courier New',Courier,monospace;\">\n  <div style=\"width:600px;background:var(--color-midnight-graphite);padding:12px 24px;display:flex;align-items:center;justify-content:center;gap:12px;box-sizing:border-box;\">\n    <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" style=\"flex-shrink:0;\">\n      <rect x=\"2\" y=\"2\" width=\"5\" height=\"5\" fill=\"var(--color-flame-orange)\"/>\n      <rect x=\"9\" y=\"2\" width=\"5\" height=\"5\" fill=\"var(--color-flame-orange)\"/>\n      <rect x=\"2\" y=\"9\" width=\"5\" height=\"5\" fill=\"var(--color-flame-orange)\"/>\n      <rect x=\"9\" y=\"9\" width=\"5\" height=\"5\" fill=\"var(--color-flame-orange)\"/>\n    </svg>\n    <span style=\"font-family:var(--font-ui-monospace);font-size:14px;color:var(--color-cloud-white);letter-spacing:-0.006em;line-height:1.5;\">Introducing Database Traffic Control™: resource budgets for your Postgres query traffic.</span>\n    <a href=\"#\" style=\"display:inline-block;background:var(--color-marigold-yellow);color:var(--color-ash-black);font-family:var(--font-ui-monospace);font-size:13px;font-weight:700;letter-spacing:-0.006em;padding:4px 10px;text-decoration:none;border-radius:0;white-space:nowrap;flex-shrink:0;\">Learn more</a>\n  </div>\n</div>",
          "name": "Announcement Banner",
          "role": "",
          "description": ""
        },
        {
          "html": "<div style=\"all:unset;display:block;box-sizing:border-box;font-family:'Courier New',Courier,monospace;--color-midnight-graphite:#111111;--color-ash-black:#000000;--color-cloud-white:#fafafa;--color-steel-gray:#414141;--color-smoke-gray:#737373;--color-stone-gray:#c1c1c1;--color-electric-blue:#0b6ec5;--color-flame-orange:#f35815;--color-marigold-yellow:#f2b600;--color-verdant-green:#22a652;--font-ui-monospace:'Courier New',Courier,monospace;\">\n  <div style=\"width:600px;box-sizing:border-box;border:1px solid var(--color-stone-gray);\">\n    <!-- Tab Bar -->\n    <div style=\"display:flex;border-bottom:1px solid var(--color-stone-gray);\">\n      <button style=\"flex:1;padding:16px 24px;background:var(--color-steel-gray);color:var(--color-cloud-white);font-family:var(--font-ui-monospace);font-size:14px;font-weight:500;letter-spacing:-0.006em;border:none;border-radius:0;cursor:pointer;text-align:center;\">Vitess</button>\n      <button style=\"flex:1;padding:16px 24px;background:transparent;color:var(--color-steel-gray);font-family:var(--font-ui-monospace);font-size:14px;font-weight:400;letter-spacing:-0.006em;border:none;border-left:1px solid var(--color-stone-gray);border-radius:0;cursor:pointer;text-align:center;\">Postgres</button>\n      <button style=\"flex:1;padding:16px 24px;background:transparent;color:var(--color-steel-gray);font-family:var(--font-ui-monospace);font-size:14px;font-weight:400;letter-spacing:-0.006em;border:none;border-left:1px solid var(--color-stone-gray);border-radius:0;cursor:pointer;text-align:center;\">Neki</button>\n    </div>\n    <!-- Tab Content -->\n    <div style=\"padding:24px;background:var(--color-cloud-white);\">\n      <p style=\"font-family:var(--font-ui-monospace);font-size:15px;color:var(--color-steel-gray);line-height:1.6;letter-spacing:-0.006em;margin:0 0 16px 0;\">\n        <a href=\"#\" style=\"color:var(--color-electric-blue);text-decoration:none;font-family:var(--font-ui-monospace);\">Vitess</a> allows MySQL databases to <a href=\"#\" style=\"color:var(--color-electric-blue);text-decoration:none;font-family:var(--font-ui-monospace);\">scale horizontally through explicit sharding</a> — enabling a shared nothing architecture distributing data across thousands of nodes, all routed through a single database connection.\n      </p>\n      <p style=\"font-family:var(--font-ui-monospace);font-size:15px;color:var(--color-steel-gray);line-height:1.6;letter-spacing:-0.006em;margin:0;\">\n        Vitess was developed at YouTube by the founders of PlanetScale to scale their main MySQL database to petabytes of data on 70,000 nodes across 20 data centers. Now maintained and managed by PlanetScale, Vitess powers the databases of some of the web's largest properties: Slack, HubSpot, Blizzard, Etsy, GitHub, Block, Bloomberg, Yelp, and more.\n      </p>\n      <!-- VTGate diagram hint -->\n      <div style=\"margin-top:24px;border:1px dashed var(--color-stone-gray);padding:16px 24px;text-align:center;\">\n        <span style=\"font-family:var(--font-ui-monospace);font-size:13px;color:var(--color-smoke-gray);letter-spacing:-0.006em;\">VTGate</span>\n      </div>\n    </div>\n  </div>\n</div>",
          "name": "Tabbed Content Switcher",
          "role": "",
          "description": ""
        },
        {
          "html": "<div style=\"all:unset;display:block;box-sizing:border-box;font-family:'Courier New',Courier,monospace;--color-midnight-graphite:#111111;--color-ash-black:#000000;--color-cloud-white:#fafafa;--color-steel-gray:#414141;--color-smoke-gray:#737373;--color-stone-gray:#c1c1c1;--color-electric-blue:#0b6ec5;--color-flame-orange:#f35815;--color-marigold-yellow:#f2b600;--color-verdant-green:#22a652;--font-ui-monospace:'Courier New',Courier,monospace;\">\n  <div style=\"width:600px;box-sizing:border-box;background:var(--color-cloud-white);padding:0;\">\n    <!-- Testimonial -->\n    <div style=\"padding:32px 24px 32px 28px;border-left:3px solid var(--color-flame-orange);margin-bottom:32px;\">\n      <p style=\"font-family:var(--font-ui-monospace);font-size:15px;color:var(--color-steel-gray);line-height:1.6;letter-spacing:-0.006em;margin:0 0 16px 0;\">&#34;We chose PlanetScale to host our most demanding Vitess and Postgres workloads, doing millions of queries per second on hundreds of terabytes of data.&#34;</p>\n      <p style=\"font-family:var(--font-ui-monospace);font-size:13px;color:var(--color-smoke-gray);letter-spacing:-0.006em;margin:0;line-height:1.5;\">— Sualeh Asif — Chief Product Officer @Anysphere (Cursor)</p>\n    </div>\n    <!-- Hero headline block -->\n    <div style=\"padding:0 24px 32px 24px;\">\n      <h2 style=\"font-family:var(--font-ui-monospace);font-size:22px;font-weight:700;color:var(--color-ash-black);letter-spacing:-0.006em;line-height:1.3;margin:0 0 16px 0;\">The world's fastest and most scalable cloud databases</h2>\n      <p style=\"font-family:var(--font-ui-monospace);font-size:15px;color:var(--color-steel-gray);line-height:1.6;letter-spacing:-0.006em;margin:0 0 12px 0;\">PlanetScale brings you the <a href=\"#\" style=\"color:var(--color-electric-blue);text-decoration:none;font-family:var(--font-ui-monospace);\">fastest databases</a> available in the cloud. Both our Postgres and Vitess databases deliver exceptional speed and reliability, with Vitess adding ultra scalability through horizontal sharding.</p>\n      <p style=\"font-family:var(--font-ui-monospace);font-size:15px;color:var(--color-steel-gray);line-height:1.6;letter-spacing:-0.006em;margin:0 0 24px 0;\">Our blazing fast <a href=\"#\" style=\"color:var(--color-electric-blue);text-decoration:none;font-family:var(--font-ui-monospace);\">NVMe drives</a> unlock <strong style=\"font-family:var(--font-ui-monospace);\">unlimited IOPS</strong>, bringing data center performance to the cloud. We offer a range of <a href=\"#\" style=\"color:var(--color-electric-blue);text-decoration:none;font-family:var(--font-ui-monospace);\">deployment options</a> to cover all of your security and compliance requirements.</p>\n      <div style=\"display:flex;gap:12px;align-items:center;\">\n        <a href=\"#\" style=\"display:inline-block;background:var(--color-flame-orange);color:#fff;font-family:var(--font-ui-monospace);font-size:14px;font-weight:600;letter-spacing:-0.006em;padding:12px 20px;text-decoration:none;border-radius:0;\">Get started</a>\n        <a href=\"#\" style=\"display:inline-block;background:var(--color-midnight-graphite);color:var(--color-cloud-white);font-family:var(--font-ui-monospace);font-size:14px;font-weight:500;letter-spacing:-0.006em;padding:12px 20px;text-decoration:none;border-radius:0;\">Get in touch</a>\n        <a href=\"#\" style=\"display:inline-block;color:var(--color-steel-gray);font-family:var(--font-ui-monospace);font-size:14px;letter-spacing:-0.006em;padding:12px 4px;text-decoration:none;border-radius:0;\">Log in</a>\n      </div>\n    </div>\n  </div>\n</div>",
