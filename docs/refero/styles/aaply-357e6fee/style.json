      "components": [
        {
          "html": "<div style=\"--color-whiteboard-background:#f2f2f2;--color-canvas:#ffffff;--color-onyx-ink:#000000;--color-fog:#e6e6e6;--color-lemon-zest:#e6e51e;--color-playful-burst-orange:#ff8562;--color-bubblegum-red:#f34646;--color-electric-violet:#466cf3;--font-poppins:'Poppins',system-ui,sans-serif;--font-inter:'Inter',sans-serif;font-family:var(--font-inter);background:var(--color-whiteboard-background);padding:48px 32px;display:flex;flex-direction:column;align-items:center;gap:24px;border-radius:30px;width:100%;box-sizing:border-box;\"><style>@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&family=Inter:wght@300;400;500;700&display=swap');.btn-cta:hover{opacity:0.9;transform:translateY(-1px);}.btn-outline:hover{background:var(--color-onyx-ink);color:var(--color-canvas);}.btn-login:hover{background:var(--color-fog);}</style><p style=\"font-family:var(--font-inter);font-size:14px;font-weight:500;color:#888;letter-spacing:0.05em;text-transform:uppercase;margin:0 0 4px 0;\">Aaply — Button System</p><h2 style=\"font-family:var(--font-poppins);font-size:27px;font-weight:700;color:var(--color-onyx-ink);letter-spacing:-0.513px;line-height:1.33;margin:0 0 8px 0;text-align:center;\">Start building better apps today</h2><div style=\"display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:8px;\"><a href=\"#\" class=\"btn-cta\" style=\"display:inline-flex;align-items:center;gap:8px;background:var(--color-lemon-zest);color:var(--color-onyx-ink);font-family:var(--font-inter);font-size:16px;font-weight:600;text-decoration:none;padding:16px 28px;border-radius:30px;border:none;cursor:pointer;transition:all 0.2s ease;box-sizing:border-box;\">Sign up for free <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M3 8h10M9 4l4 4-4 4\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></a><a href=\"#\" class=\"btn-outline\" style