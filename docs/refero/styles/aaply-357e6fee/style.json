r);font-size:14px;font-weight:600;padding:7px 18px;border-radius:50px;\">Design</span><span style=\"display:inline-flex;align-items:center;background:var(--color-playful-burst-orange);color:#fff;font-family:var(--font-inter);font-size:14px;font-weight:600;padding:7px 18px;border-radius:50px;\">Prototype</span><span style=\"display:inline-flex;align-items:center;background:var(--color-sunshine-yellow);color:var(--color-onyx-ink);font-family:var(--font-inter);font-size:14px;font-weight:600;padding:7px 18px;border-radius:50px;\">Beta</span><span style=\"display:inline-flex;align-items:center;background:var(--color-neon-yellow);color:var(--color-onyx-ink);font-family:var(--font-inter);font-size:14px;font-weight:600;padding:7px 18px;border-radius:50px;\">New</span><span style=\"display:inline-flex;align-items:center;background:var(--color-canvas);color:var(--color-onyx-ink);font-family:var(--font-inter);font-size:14px;font-weight:500;padding:7px 18px;border-radius:50px;border:1.5px solid var(--color-fog);\">Draft</span></div><div style=\"margin-top:36px;display:flex;gap:16px;flex-wrap:wrap;justify-content:center;\"><div style=\"background:var(--color-canvas);border-radius:16px;padding:14px 20px;display:inline-flex;align-items:center;gap:10px;box-shadow:rgba(0,0,0,0.2) 0px 10px 10px -5px;\"><div style=\"width:10px;height:10px;border-radius:50%;background:var(--color-bubblegum-red);flex-shrink:0;\"></div><span style=\"font-family:var(--font-inter);font-size:14px;color:var(--color-onyx-ink);font-weight:500;\">Needs attention</span></div><div style=\"background:var(--color-canvas);border-radius:16px;padding:14px 20px;display:inline-flex;align-items:center;gap:10px;box-shadow:rgba(0,0,0,0.2) 0px 10px 10px -5px;\"><div style=\"width:10px;height:10px;border-radius:50%;background:var(--color-lemon-zest);flex-shrink:0;\"></div><span style=\"font-family:var(--font-inter);font-size:14px;color:var(--color-onyx-ink);font-weight:500;\">Ready to ship</span></div><div style=\"background:var(--color-canvas);border-radius:16px;padding:14px 20px;display:inline-flex;align-items:center;gap:10px;box-shadow:rgba(0,0,0,0.2) 0px 10px 10px -5px;\"><div style=\"width:10px;height:10px;border-radius:50%;background:var(--color-electric-violet);flex-shrink:0;\"></div><span style=\"font-family:var(--font-inter);font-size:14px;color:var(--color-onyx-ink);font-weight:500;\">In progress</span></div></div></div>",
