        {
          "html": "<div style=\"--color-whiteboard-background:#f2f2f2;--color-canvas:#ffffff;--color-onyx-ink:#000000;--color-fog:#e6e6e6;--color-lemon-zest:#e6e51e;--color-bubblegum-red:#f34646;--color-electric-violet:#466cf3;--color-playful-burst-orange:#ff8562;--color-sunshine-yellow:#f5bd50;--font-poppins:'Poppins',system-ui,sans-serif;--font-inter:'Inter',sans-serif;--shadow-md:rgba(0,0,0,0.2) 0px 10px 10px -5px;background:var(--color-whiteboard-background);padding:48px 32px;font-family:var(--font-inter);border-radius:30px;width:100%;box-sizing:border-box;\"><style>@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&family=Inter:wght@400;500;700&display=swap');</style><p style=\"font-family:var(--font-inter);font-size:14px;font-weight:500;color:#888;letter-spacing:0.05em;text-transform:uppercase;margin:0 0 6px 0;text-align:center;\">Why Aaply</p><h2 style=\"font-family:var(--font-poppins);font-size:34px;font-weight:700;color:var(--color-onyx-ink);letter-spacing:-0.646px;line-height:1.1;margin:0 0 32px 0;text-align:center;\">Everything your team needs</h2><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;\"><div style=\"background:var(--color-canvas);border-radius:30px;padding:28px 24px;box-shadow:var(--shadow-md);display:flex;flex-direction:column;gap:12px;\"><div style=\"width:44px;height:44px;border-radius:16px;background:var(--color-lemon-zest);display:flex;align-items:center;justify-content:center;\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\"><rect x=\"3\" y=\"3\" width=\"8\" height=\"8\" rx=\"2\" fill=\"#000\"/><rect x=\"13\" y=\"3\" width=\"8\" height=\"8\" rx=\"2\" fill=\"#000\"/><rect x=\"3\" y=\"13\" width=\"8\" height=\"8\" rx=\"2\" fill=\"#000\"/><rect x=\"13\" y=\"13\" width=\"8\" height=\"8\" rx=\"2\" fill=\"#000\"/></svg></div><h3 style=\"font-family:var(--font-poppins);font-size:18px;font-weight:700;color:var(--color-onyx-ink);margin:0;line-height:1.3;\">Design System</h3><p style=\"font-family:var(--font-inter);font-size:14px;color:#555;margin:0;line-height:1.57;\">Build reusable UI components and maintain visual consistency across all your screens.</p></div><div style=\"background:var(--color-onyx-ink);border-radius:30px;padding:28px 24px;box-shadow:var(--shadow-md);display:flex;flex-direction:column;gap:12px;\"><div style=\"width:44px;height:44px;border-radius:16px;background:var(--color-electric-violet);display:flex;align-items:center;justify-content:center;\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"4\" fill=\"#fff\"/><circle cx=\"17\" cy=\"15\" r=\"4\" fill=\"#fff\" opacity=\"0.6\"/><line x1=\"13\" y1=\"9\" x2=\"17\" y2=\"9\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg></div><h3 style=\"font-family:var(--font-poppins);font-size:18px;font-weight:700;color:#fff;margin:0;line-height:1.3;\">Team Collaboration</h3><p style=\"font-family:var(--font-inter);font-size:14px;color:#aaa;margin:0;line-height:1.57;\">Work together in real-time with live cursors, comments, and shared project spaces.</p></div><div style=\"background:var(--color-bubblegum-red);border-radius:30px;padding:28px 24px;box-shadow:var(--shadow-md);display:flex;flex-direction:column;gap:12px;\"><div style=\"width:44px;height:44px;border-radius:16px;background:rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z\" fill=\"#fff\"/></svg></div><h3 style=\"font-family:var(--font-poppins);font-size:18px;font-weight:700;color:#fff;margin:0;line-height:1.3;\">Prototyping</h3><p style=\"font-family:var(--font-inter);font-size:14px;color:rgba(255,255,255,0.8);margin:0;line-height:1.57;\">Create interactive, clickable prototypes that feel like the real app in minutes.</p></div><div style=\"background:var(--color-canvas);border-radius:30px;padding:28px 24px;box-shadow:var(--shadow-md);display:flex;flex-direction:column;gap:8px;\"><p style=\"font-family:var(--font-inter);font-size:13px;font-weight:500;color:#888;margin:0;text-transform:uppercase;letter-spacing:0.06em;\">Teams using Aaply</p><p style=\"font-family:var(--font-poppins);font-size:44px;font-weight:700;color:var(--color-onyx-ink);margin:0;line-height:1;\">12k+</p><p style=\"font-family:var(--font-inter);font-size:14px;color:#555;margin:0;line-height:1.57;\">Product &amp; design teams worldwide trust Aaply to build better mobile apps.</p><div style=\"display:flex;gap:-6px;margin-top:4px;\"><div style=\"width:28px;height:28px;border-radius:50%;background:var(--color-playful-burst-orange);border:2px solid #fff;\"></div><div style=\"width:28px;height:28px;border-radius:50%;background:var(--color-electric-violet);border:2px solid #fff;margin-left:-8px;\"></div><div style=\"width:28px;height:28px;border-radius:50%;background:var(--color-lemon-zest);border:2px solid #fff;margin-left:-8px;\"></div><div style=\"width:28px;height:28px;border-radius:50%;background:var(--color-sunshine-yellow);border:2px solid #fff;margin-left:-8px;\"></div></div></div></div></div>",
