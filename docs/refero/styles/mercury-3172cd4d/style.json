        {
          "html": "<style>:root{--color-mercury-blue:#5266eb;--color-deep-space:#171721;--color-midnight-slate:#1e1e2a;--color-lead:#70707d;--color-starlight:#ededf3;--color-silver:#c3c3cc;--font-arcadiadisplay:'Manrope',Inter,sans-serif;--font-arcadia:'Manrope',Inter,sans-serif;}</style><div style=\"background:var(--color-deep-space);padding:64px 48px;font-family:var(--font-arcadia);width:100%;box-sizing:border-box;border-radius:4px;\"><h2 style=\"font-family:var(--font-arcadiadisplay);font-size:32px;font-weight:360;line-height:1.2;color:var(--color-starlight);margin:0 0 48px 0;font-feature-settings:'ss01' on;\">Everything you do with money.<br>All in one place.</h2><div style=\"border-top:1px solid var(--color-lead);margin-bottom:0;\"></div><div style=\"border-bottom:1px solid var(--color-lead);padding:24px 0;\"><div style=\"display:flex;align-items:flex-start;gap:12px;\"><span style=\"width:8px;height:8px;border-radius:50%;background:var(--color-starlight);flex-shrink:0;margin-top:7px;\"></span><div><p style=\"font-family:var(--font-arcadiadisplay);font-size:18px;font-weight:480;color:var(--color-starlight);margin:0 0 10px 0;font-feature-settings:'ss01' on;\">Business banking &amp; more</p><p style=\"font-family:var(--font-arcadia);font-size:15px;font-weight:360;line-height:1.55;color:var(--color-silver);margin:0;letter-spacing:0.28px;\">Apply for free checking and savings accounts with zero minimums, earn up to 3.65% yield with Treasury by Mercury Advisory,<sup style=\"font-size:10px;\">2</sup> and access loans<sup style=\"font-size:10px;\">3</sup> to help you grow.</p></div></div></div><div style=\"border-bottom:1px solid var(--color-lead);padding:22px 0;\"><p style=\"font-family:var(--font-arcadiadisplay);font-size:18px;font-weight:360;color:var(--color-starlight);margin:0;font-feature-settings:'ss01' on;\">Cards &amp; expense management</p></div><div style=\"border-bottom:1px solid var(--color-lead);padding:22px 0;\"><p style=\"font-family:var(--font-arcadiadisplay);font-size:18px;font-weight:360;color:var(--color-starlight);margin:0;font-feature-settings:'ss01' on;\">Payments &amp; invoicing</p></div><div style=\"border-bottom:1px solid var(--color-lead);padding:22px 0;\"><p style=\"font-family:var(--font-arcadiadisplay);font-size:18px;font-weight:360;color:var(--color-starlight);margin:0;font-feature-settings:'ss01' on;\">Accounting</p></div><div style=\"padding-top:32px;\"><a href=\"#\" style=\"font-family:var(--font-arcadia);font-size:16px;font-weight:400;color:var(--color-starlight);text-decoration:underline;text-underline-offset:3px;letter-spacing:0.16px;\">Launch demo</a></div></div>",
