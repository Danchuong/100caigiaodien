var(--font-arcadia);font-size:13px;color:var(--color-lead);letter-spacing:0.28px;\">Ghost button</span></div><div style=\"display:flex;align-items:center;gap:16px;flex-wrap:wrap;\"><button style=\"background:var(--color-graphite);color:var(--color-starlight);border:none;border-radius:32px;padding:14px 24px;font-family:var(--font-arcadia);font-size:15px;font-weight:400;cursor:pointer;letter-spacing:0.16px;\">Log in</button><span style=\"font-family:var(--font-arcadia);font-size:13px;color:var(--color-lead);letter-spacing:0.28px;\">Surface button</span></div></div></div>",
