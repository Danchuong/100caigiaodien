      "components": [
        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500&family=EB+Garamond:wght@400&family=DM+Serif+Display:wght@400&display=swap');\n\n  :root {\n    --color-carbon: #141414;\n    --color-graphite: #262626;\n    --color-pewter: #666666;\n    --color-ghost-white: #f2f2f2;\n    --color-snow: #ffffff;\n    --color-svelte-orange: #d43008;\n    --font-dm-serif-display: 'DM Serif Display', serif;\n    --font-eb-garamond: 'EB Garamond', serif;\n    --font-fira-sans: 'Fira Sans', sans-serif;\n    --spacing-5: 5px;\n    --spacing-7: 7px;\n    --spacing-8: 8px;\n    --spacing-10: 10px;\n    --spacing-17: 17px;\n    --spacing-40: 40px;\n    --spacing-48: 48px;\n    --spacing-100: 100px;\n  }\n\n  .svelte-definition-block {\n    background: var(--color-snow);\n    padding: 48px 48px 52px 48px;\n    font-family: var(--font-fira-sans);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n\n  .svelte-pronunciation {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n    flex-wrap: wrap;\n  }\n\n  .svelte-ipa {\n    font-family: var(--font-eb-garamond);\n    font-size: 40px;\n    font-weight: 400;\n    color: var(--color-svelte-orange);\n    line-height: 1.2;\n    letter-spacing: -0.5px;\n  }\n\n  .svelte-badge {\n    background: var(--color-graphite);\n    color: var(--color-snow);\n    font-family: var(--font-fira-sans);\n    font-size: 10px;\n    font-weight: 400;\n    letter-spacing: 0.08em;\n    padding: 3px 7px;\n    border-radius: 4px;\n    text-transform: uppercase;\n    align-self: center;\n  }\n\n  .svelte-adjective-desc {\n    font-family: var(--font-fira-sans);\n    font-size: 16px;\n    color: var(--color-graphite);\n    line-height: 1.5;\n    align-self: center;\n  }\n\n  .svelte-body {\n    font-family: var(--font-eb-garamond);\n    font-size: 22px;\n    font-weight: 400;\n    color: var(--color-graphite);\n    line-height: 1.5;\n    margin: 0 0 20px 0;\n  }\n\n  .svelte-cta-link {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-family: var(--font-fira-sans);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-svelte-orange);\n    text-decoration: none;\n    letter-spacing: 0.10em;\n    text-transform: uppercase;\n    margin-top: 8px;\n  }\n\n  .svelte-cta-link:hover {\n    text-decoration: underline;\n  }\n</style>\n\n<div class=\"svelte-definition-block\">\n  <div class=\"svelte-pronunciation\">\n    <span class=\"svelte-ipa\">/&#712;sv&#603;lt/</span>\n    <span class=\"svelte-badge\">Adjective</span>\n    <span class=\"svelte-adjective-desc\">attractively thin, graceful and stylish</span>\n  </div>\n  <p class=\"svelte-body\">Svelte is a UI framework that uses a compiler to let you write breathtakingly concise components that do minimal work in the browser, using languages you already know — HTML, CSS and JavaScript. It&#8217;s a love letter to web development.</p>\n  <p class=\"svelte-body\">But don&#8217;t take our word for it. Developers consistently rank Svelte as the framework they&#8217;re most excited about using.</p>\n  <a href=\"#\" class=\"svelte-cta-link\">\n    GET STARTED\n    <svg width=\"14\" height=\"10\" viewBox=\"0 0 14 10\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M8.5 1L13 5L8.5 9\" stroke=\"#d43008\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      <line x1=\"1\" y1=\"5\" x2=\"12.5\" y2=\"5\" stroke=\"#d43008\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n    </svg>\n  </a>\n</div>",
          "name": "GET STARTED CTA Button",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500&family=EB+Garamond:wght@400&family=DM+Serif+Display:wght@400&display=swap');\n\n  :root {\n    --color-carbon: #141414;\n    --color-graphite: #262626;\n    --color-pewter: #666666;\n    --color-ghost-white: #f2f2f2;\n    --color-snow: #ffffff;\n    --color-svelte-orange: #d43008;\n    --font-dm-serif-display: 'DM Serif Display', serif;\n    --font-eb-garamond: 'EB Garamond', serif;\n    --font-fira-sans: 'Fira Sans', sans-serif;\n  }\n\n  .search-wrapper {\n    background: var(--color-snow);\n    padding: 48px;\n    max-width: 600px;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n\n  .search-label {\n    font-family: var(--font-fira-sans);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-pewter);\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n  }\n\n  .search-bar {\n    display: flex;\n    align-items: center;\n    background: var(--color-ghost-white);\n    border-radius: 4px;\n    padding: 8px 12px;\n    gap: 10px;\n    width: 100%;\n    box-sizing: border-box;\n    border: 1px solid transparent;\n  }\n\n  .search-bar:focus-within {\n    border-color: #d4d4d4;\n  }\n\n  .search-icon {\n    flex-shrink: 0;\n    color: var(--color-pewter);\n  }\n\n  .search-input {\n    flex: 1;\n    background: transparent;\n    border: none;\n    outline: none;\n    font-family: var(--font-fira-sans);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-graphite);\n    line-height: 1.5;\n  }\n\n  .search-input::placeholder {\n    color: var(--color-pewter);\n  }\n\n  .search-kbd-group {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    flex-shrink: 0;\n  }\n\n  .search-kbd {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    background: var(--color-snow);\n    border: 1px solid #d4d4d4;\n    border-radius: 4px;\n    padding: 2px 6px;\n    font-family: var(--font-fira-sans);\n    font-size: 11px;\n    font-weight: 400;\n    color: var(--color-pewter);\n    line-height: 1.4;\n  }\n\n  .search-hint {\n    font-family: var(--font-fira-sans);\n    font-size: 12px;\n    color: var(--color-pewter);\n    line-height: 1.5;\n  }\n\n  .search-hint a {\n    color: var(--color-svelte-orange);\n    text-decoration: none;\n  }\n\n  .search-hint a:hover {\n    text-decoration: underline;\n  }\n</style>\n\n<div class=\"search-wrapper\">\n  <span class=\"search-label\">Search the docs</span>\n  <div class=\"search-bar\">\n    <svg class=\"search-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <circle cx=\"6.5\" cy=\"6.5\" r=\"4.5\" stroke=\"#666666\" stroke-width=\"1.4\"/>\n      <line x1=\"10\" y1=\"10\" x2=\"14\" y2=\"14\" stroke=\"#666666\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n    </svg>\n    <input class=\"search-input\" type=\"text\" placeholder=\"search\" />\n    <div class=\"search-kbd-group\">\n      <kbd class=\"search-kbd\">&#8984;</kbd>\n      <kbd class=\"search-kbd\">K</kbd>\n    </div>\n  </div>\n  <span class=\"search-hint\">Quick access to docs, tutorials, and the <a href=\"#\">API reference</a></span>\n</div>",
