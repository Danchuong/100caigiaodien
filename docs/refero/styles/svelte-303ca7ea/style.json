        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500&family=EB+Garamond:wght@400&family=DM+Serif+Display:ital,wght@0,400;1,400&display=swap');\n\n  :root {\n    --color-carbon: #141414;\n    --color-graphite: #262626;\n    --color-pewter: #666666;\n    --color-ghost-white: #f2f2f2;\n    --color-snow: #ffffff;\n    --color-svelte-orange: #d43008;\n    --font-dm-serif-display: 'DM Serif Display', serif;\n    --font-eb-garamond: 'EB Garamond', serif;\n    --font-fira-sans: 'Fira Sans', sans-serif;\n  }\n\n  .companies-block {\n    background: var(--color-snow);\n    padding: 56px 40px 48px 40px;\n    max-width: 600px;\n    box-sizing: border-box;\n    text-align: center;\n  }\n\n  .companies-headline {\n    font-family: var(--font-dm-serif-display);\n    font-size: 42px;\n    font-weight: 400;\n    color: var(--color-carbon);\n    line-height: 1.18;\n    margin: 0 0 40px 0;\n    letter-spacing: -0.5px;\n  }\n\n  .companies-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 0;\n    border: 1px solid var(--color-ghost-white);\n    border-radius: 4px;\n    overflow: hidden;\n    margin-bottom: 36px;\n  }\n\n  .company-cell {\n    padding: 22px 16px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-right: 1px solid var(--color-ghost-white);\n    border-bottom: 1px solid var(--color-ghost-white);\n  }\n\n  .company-cell:nth-child(3n) {\n    border-right: none;\n  }\n\n  .company-cell:nth-last-child(-n+3) {\n    border-bottom: none;\n  }\n\n  .company-name {\n    font-family: var(--font-fira-sans);\n    font-size: 14px;\n    font-weight: 400;\n    color: #bbbbbb;\n    letter-spacing: 0.02em;\n  }\n\n  .company-name-serif {\n    font-family: var(--font-eb-garamond);\n    font-size: 16px;\n    font-weight: 400;\n    color: #bbbbbb;\n    font-style: italic;\n  }\n\n  .companies-link {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-family: var(--font-fira-sans);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-svelte-orange);\n    text-decoration: none;\n    letter-spacing: 0.01em;\n  }\n\n  .companies-link:hover {\n    text-decoration: underline;\n  }\n</style>\n\n<div class=\"companies-block\">\n  <h2 class=\"companies-headline\">used by companies<br>you&#8217;ve heard of</h2>\n  <div class=\"companies-grid\">\n    <div class=\"company-cell\"><span class=\"company-name\">Stack Overflow</span></div>\n    <div class=\"company-cell\"><span class=\"company-name\">Yelp</span></div>\n    <div class=\"company-cell\"><span class=\"company-name\">Square</span></div>\n    <div class=\"company-cell\"><span class=\"company-name\">Apple</span></div>\n    <div class=\"company-cell\"><span class=\"company-name\">Spotify</span></div>\n    <div class=\"company-cell\"><span class=\"company-name-serif\">The New York Times</span></div>\n  </div>\n  <a href=\"#\" class=\"companies-link\">\n    Watch the full Svelte Origins documentary\n    <svg width=\"13\" height=\"10\" viewBox=\"0 0 13 10\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M7.5 1L12 5L7.5 9\" stroke=\"#d43008\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      <line x1=\"0.5\" y1=\"5\" x2=\"11.5\" y2=\"5\" stroke=\"#d43008\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n    </svg>\n  </a>\n</div>",
