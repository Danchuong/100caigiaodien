          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400&family=Inter:wght@300;400;500&display=swap');\n\n  :root {\n    --color-ebon-depth: #000000;\n    --color-whisper-white: #ffffff;\n    --color-onyx-shadow: #0c1018;\n    --color-mist-gray: #9e9fa3;\n    --color-steel-glimmer: #6d7074;\n    --font-serrif-condensed-regular: 'IBM Plex Serif', Georgia, serif;\n    --font-saans-variable: 'Inter', system-ui, sans-serif;\n  }\n\n  .buttons-section {\n    width: 600px;\n    padding: 52px 40px;\n    background: #f7f3f0;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    gap: 32px;\n  }\n\n  .buttons-label {\n    font-family: var(--font-saans-variable);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-mist-gray);\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    margin: 0 0 12px 0;\n  }\n\n  .buttons-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 12px;\n    align-items: center;\n  }\n\n  .btn-pill {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    font-family: var(--font-saans-variable);\n    font-size: 14px;\n    font-weight: 400;\n    letter-spacing: -0.01em;\n    line-height: 1;\n    border: none;\n    cursor: pointer;\n    text-decoration: none;\n    transition: opacity 0.18s ease;\n    white-space: nowrap;\n    border-radius: 90px;\n  }\n\n  .btn-pill:hover {\n    opacity: 0.75;\n  }\n\n  .btn-subtle {\n    background: rgba(153, 161, 175, 0.12);\n    color: var(--color-ebon-depth);\n    padding: 14px 24px;\n  }\n\n  .btn-subtle-dark {\n    background: rgba(12, 16, 24, 0.08);\n    color: var(--color-onyx-shadow);\n    padding: 14px 24px;\n  }\n\n  .btn-solid {\n    background: var(--color-onyx-shadow);\n    color: var(--color-whisper-white);\n    padding: 14px 24px;\n  }\n\n  .btn-ghost {\n    background: transparent;\n    color: var(--color-mist-gray);\n    padding: 14px 24px;\n    border: 1px solid rgba(153, 161, 175, 0.3);\n  }\n\n  .btn-small {\n    padding: 10px 18px;\n    font-size: 12px;\n  }\n\n  .btn-icon {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 40px;\n    height: 40px;\n    background: rgba(153, 161, 175, 0.12);\n    border-radius: 90px;\n    border: none;\n    cursor: pointer;\n  }\n\n  .btn-icon:hover {\n    opacity: 0.7;\n  }\n\n  .section-title {\n    font-family: var(--font-saans-variable);\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--color-onyx-shadow);\n    letter-spacing: -0.01em;\n    margin: 0 0 16px 0;\n    opacity: 0.5;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    font-size: 10px;\n  }\n\n  .divider {\n    height: 1px;\n    background: rgba(153, 161, 175, 0.2);\n    margin: 0;\n  }\n</style>\n<div class=\"buttons-section\">\n  <div>\n    <div class=\"section-title\">Primary Actions</div>\n    <div class=\"buttons-row\">\n      <a href=\"#\" class=\"btn-pill btn-subtle\">Our work</a>\n      <a href=\"#\" class=\"btn-pill btn-subtle\">Learn more</a>\n      <a href=\"#\" class=\"btn-pill btn-subtle btn-small\">View case study</a>\n    </div>\n  </div>\n\n  <div class=\"divider\"></div>\n\n  <div>\n    <div class=\"section-title\">Navigation & Secondary</div>\n    <div class=\"buttons-row\">\n      <a href=\"#\" class=\"btn-pill btn-solid\">Join</a>\n      <a href=\"#\" class=\"btn-pill btn-ghost\">Contact</a>\n      <a href=\"#\" class=\"btn-pill btn-ghost\">Services</a>\n      <button class=\"btn-icon\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M2 7H12M7 2L12 7L7 12\" stroke=\"#0c1018\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n    </div>\n  </div>\n\n  <div class=\"divider\"></div>\n\n  <div>\n    <div class=\"section-title\">States</div>\n    <div class=\"buttons-row\">\n      <a href=\"#\" class=\"btn-pill btn-subtle\" style=\"opacity:0.4;pointer-events:none;\">Disabled</a>\n      <a href=\"#\" class=\"btn-pill btn-subtle\" style=\"background:rgba(153,161,175,0.22);\">Hover state</a>\n      <a href=\"#\" class=\"btn-pill btn-subtle\" style=\"display:inline-flex;gap:8px;align-items:center;\">\n        <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"6\" cy=\"6\" r=\"5\" stroke=\"#0c1018\" stroke-width=\"1.2\"/>\n          <path d=\"M4 6L5.5 7.5L8 4.5\" stroke=\"#0c1018\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        With icon\n      </a>\n    </div>\n  </div>\n</div>",
