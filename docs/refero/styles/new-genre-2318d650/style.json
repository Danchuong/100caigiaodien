      "components": [
        {
          "html": "<style>\n  :root {\n    --color-ebon-depth: #000000;\n    --color-whisper-white: #ffffff;\n    --color-midnight-oil-stain: #1e1310;\n    --color-onyx-shadow: #0c1018;\n    --color-mist-gray: #9e9fa3;\n    --color-steel-glimmer: #6d7074;\n    --font-serrif-condensed-regular: 'IBM Plex Serif', Georgia, serif;\n    --font-saans-variable: 'Inter', system-ui, sans-serif;\n    --font-saans-medium: 'Inter', system-ui, sans-serif;\n    --font-saans-regular: 'Inter', system-ui, sans-serif;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400&family=Inter:wght@300;400;500&display=swap');\n\n  .cookie-wrapper {\n    width: 600px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: flex-end;\n    padding: 32px;\n    background: linear-gradient(rgb(40, 14, 1) 0%, rgb(24, 38, 68) 15.2608%, rgb(90, 118, 159) 30.284%, rgb(135, 161, 196) 43.3787%, rgb(193, 211, 230) 58.8313%, rgb(254, 249, 225) 79.7139%, rgb(247, 243, 240) 100%);\n    min-height: 160px;\n    box-sizing: border-box;\n  }\n\n  .cookie-banner {\n    background: var(--color-whisper-white);\n    border-radius: 8px;\n    padding: 20px 24px;\n    display: flex;\n    align-items: center;\n    gap: 32px;\n    box-shadow: 0 4px 24px rgba(0,0,0,0.10);\n    max-width: 320px;\n    width: 100%;\n  }\n\n  .cookie-text {\n    font-family: var(--font-saans-variable);\n    font-size: 12px;\n    font-weight: 400;\n    line-height: 1.4;\n    color: var(--color-onyx-shadow);\n    letter-spacing: -0.01em;\n    flex: 1;\n    margin: 0;\n  }\n\n  .cookie-btn {\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    font-family: var(--font-saans-variable);\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--color-onyx-shadow);\n    letter-spacing: -0.01em;\n    white-space: nowrap;\n    padding: 0;\n    border-radius: 50px;\n    line-height: 1;\n    text-decoration: none;\n    display: inline-block;\n  }\n\n  .cookie-btn:hover {\n    opacity: 0.7;\n  }\n</style>\n<div class=\"cookie-wrapper\">\n  <div class=\"cookie-banner\">\n    <p class=\"cookie-text\">We use cookies to personalize content, run ads, and analyze traffic.</p>\n    <button class=\"cookie-btn\">Okay</button>\n  </div>\n</div>",
