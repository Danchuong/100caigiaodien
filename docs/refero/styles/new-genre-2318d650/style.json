        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400&family=Inter:wght@300;400;500&display=swap');\n\n  :root {\n    --color-ebon-depth: #000000;\n    --color-whisper-white: #ffffff;\n    --color-onyx-shadow: #0c1018;\n    --color-mist-gray: #9e9fa3;\n    --color-steel-glimmer: #6d7074;\n    --font-serrif-condensed-regular: 'IBM Plex Serif', Georgia, serif;\n    --font-saans-variable: 'Inter', system-ui, sans-serif;\n  }\n\n  .process-section {\n    width: 600px;\n    background: #f7f3f0;\n    padding: 48px 24px;\n    box-sizing: border-box;\n    font-family: var(--font-saans-variable);\n  }\n\n  .process-heading {\n    font-family: var(--font-saans-variable);\n    font-size: 20px;\n    font-weight: 400;\n    color: var(--color-onyx-shadow);\n    letter-spacing: -0.02em;\n    line-height: 1.15;\n    margin: 0 0 32px 0;\n  }\n\n  .process-cards {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 12px;\n  }\n\n  .process-card {\n    background: var(--color-whisper-white);\n    border-radius: 16px;\n    padding: 24px 20px 0 20px;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    min-height: 260px;\n  }\n\n  .process-card-title {\n    font-family: var(--font-saans-variable);\n    font-size: 16px;\n    font-weight: 500;\n    color: var(--color-onyx-shadow);\n    letter-spacing: -0.01em;\n    line-height: 1.15;\n    margin: 0 0 10px 0;\n  }\n\n  .process-card-desc {\n    font-family: var(--font-saans-variable);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-mist-gray);\n    letter-spacing: -0.01em;\n    line-height: 1.4;\n    margin: 0 0 24px 0;\n    flex: 1;\n  }\n\n  .process-card-img {\n    width: 100%;\n    flex-shrink: 0;\n    height: 110px;\n    border-radius: 8px;\n    margin-top: auto;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    overflow: hidden;\n  }\n\n  .img-think {\n    background: linear-gradient(to bottom, #f0eeec, #d8d4ce);\n    position: relative;\n  }\n\n  .img-create {\n    background: linear-gradient(to bottom, #f0eeec, #ddd0c0);\n  }\n\n  .img-build {\n    background: linear-gradient(to bottom, #f0eeec, #e0cdb8);\n  }\n\n  .plant-svg {\n    width: 100%;\n    height: 100%;\n  }\n</style>\n<div class=\"process-section\">\n  <h2 class=\"process-heading\">Our process, crafted through decades of shared experience</h2>\n  <div class=\"process-cards\">\n    <div class=\"process-card\">\n      <div class=\"process-card-title\">Think</div>\n      <div class=\"process-card-desc\">We read the soil to find where ideas take root, uncovering opportunities, directions, and missions.</div>\n      <div class=\"process-card-img img-think\">\n        <svg viewBox=\"0 0 80 110\" xmlns=\"http://www.w3.org/2000/svg\" class=\"plant-svg\">\n          <line x1=\"40\" y1=\"110\" x2=\"40\" y2=\"30\" stroke=\"#1a1a0f\" stroke-width=\"1.5\"/>\n          <ellipse cx=\"40\" cy=\"28\" rx=\"12\" ry=\"18\" fill=\"#1a1a0f\" transform=\"rotate(-10 40 28)\"/>\n          <ellipse cx=\"40\" cy=\"22\" rx=\"10\" ry=\"16\" fill=\"#1a1a0f\" transform=\"rotate(5 40 22)\"/>\n          <ellipse cx=\"36\" cy=\"38\" rx=\"7\" ry=\"12\" fill=\"#2a2a15\" transform=\"rotate(-25 36 38)\"/>\n        </svg>\n      </div>\n    </div>\n    <div class=\"process-card\">\n      <div class=\"process-card-title\">Create</div>\n      <div class=\"process-card-desc\">We coax the invisible into the inevitable, crafting identities and systems to support your growth.</div>\n      <div class=\"process-card-img img-create\">\n        <svg viewBox=\"0 0 80 110\" xmlns=\"http://www.w3.org/2000/svg\" class=\"plant-svg\">\n          <line x1=\"40\" y1=\"110\" x2=\"40\" y2=\"40\" stroke=\"#3a2a10\" stroke-width=\"1.5\"/>\n          <ellipse cx=\"40\" cy=\"42\" rx=\"10\" ry=\"14\" fill=\"#c8a06a\" transform=\"rotate(5 40 42)\"/>\n          <ellipse cx=\"40\" cy=\"36\" rx=\"8\" ry=\"12\" fill=\"#d4a860\" transform=\"rotate(-5 40 36)\"/>\n          <path d=\"M34 55 Q40 35 46 55\" fill=\"#a07840\" stroke=\"none\"/>\n        </svg>\n      </div>\n    </div>\n    <div class=\"process-card\">\n      <div class=\"process-card-title\">Build</div>\n      <div class=\"process-card-desc\">We engineer scalable digital products and experiences ready for real-world impact.</div>\n      <div class=\"process-card-img img-build\">\n        <svg viewBox=\"0 0 80 110\" xmlns=\"http://www.w3.org/2000/svg\" class=\"plant-svg\">\n          <line x1=\"40\" y1=\"110\" x2=\"40\" y2=\"55\" stroke=\"#3a2a10\" stroke-width=\"1.5\"/>\n          <ellipse cx=\"42\" cy=\"48\" rx=\"22\" ry=\"18\" fill=\"#d4a06a\" transform=\"rotate(-5 42 48)\"/>\n          <ellipse cx=\"38\" cy=\"44\" rx=\"18\" ry=\"14\" fill=\"#c89060\" transform=\"rotate(10 38 44)\"/>\n          <ellipse cx=\"44\" cy=\"52\" rx=\"16\" ry=\"12\" fill=\"#e0b880\" transform=\"rotate(-15 44 52)\"/>\n          <line x1=\"40\" y1=\"30\" x2=\"42\" y2=\"20\" stroke=\"#8a3020\" stroke-width=\"1\"/>\n          <ellipse cx=\"43\" cy=\"18\" rx=\"3\" ry=\"5\" fill=\"#c04040\"/>\n        </svg>\n      </div>\n    </div>\n  </div>\n</div>",
