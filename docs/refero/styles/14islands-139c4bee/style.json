        {
          "html": "<style>\n  :root {\n    --color-canvas-white: #f2f2f2;\n    --color-deep-graphite: #070707;\n    --color-off-white: #ffffff;\n    --color-soft-gray-highlight: #a2a2a9;\n    --color-medium-gray-highlight: #797979;\n    --font-aftenscreen: 'Montserrat', 'Open Sans', sans-serif;\n    --font-bentonsans: 'Inter', 'Lato', sans-serif;\n  }\n  .section-heading {\n    background: var(--color-canvas-white);\n    padding: 64px 48px 64px 48px;\n    font-family: var(--font-aftenscreen);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n  .section-heading__line {\n    display: block;\n    font-family: var(--font-aftenscreen);\n    font-size: 72px;\n    line-height: 0.88;\n    letter-spacing: -0.04em;\n    font-weight: 400;\n    margin: 0;\n  }\n  .section-heading__line--muted {\n    color: var(--color-soft-gray-highlight);\n  }\n  .section-heading__line--dark {\n    color: var(--color-deep-graphite);\n  }\n  .section-heading__sub {\n    margin-top: 36px;\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-medium-gray-highlight);\n    font-weight: 400;\n    max-width: 380px;\n  }\n  .section-heading__cta {\n    display: inline-block;\n    margin-top: 28px;\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-deep-graphite);\n    font-weight: 400;\n    text-decoration: none;\n    border-bottom: 1px solid var(--color-deep-graphite);\n    padding-bottom: 2px;\n    letter-spacing: 0;\n  }\n</style>\n<div class=\"section-heading\">\n  <span class=\"section-heading__line section-heading__line--muted\">Lovable Products</span>\n  <span class=\"section-heading__line section-heading__line--dark\" style=\"margin-top: 4px;\">from vision to launch</span>\n  <p class=\"section-heading__sub\">We partner with ambitious teams to design and build digital products that people genuinely love to use — from early strategy through to launch and beyond.</p>\n  <a href=\"#\" class=\"section-heading__cta\">View our work</a>\n</div>",
