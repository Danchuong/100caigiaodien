      "components": [
        {
          "html": "<style>\n  :root {\n    --color-canvas-white: #f2f2f2;\n    --color-deep-graphite: #070707;\n    --color-off-white: #ffffff;\n    --color-soft-gray-highlight: #a2a2a9;\n    --color-medium-gray-highlight: #797979;\n    --font-aftenscreen: 'Montserrat', 'Open Sans', sans-serif;\n    --font-bentonsans: 'Inter', 'Lato', sans-serif;\n  }\n  .agency-intro {\n    background: var(--color-canvas-white);\n    padding: 60px 48px 56px 48px;\n    font-family: var(--font-bentonsans);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n  .agency-intro__label {\n    font-family: var(--font-bentonsans);\n    font-size: 12px;\n    line-height: 1.2;\n    letter-spacing: 0.08em;\n    color: var(--color-soft-gray-highlight);\n    text-transform: uppercase;\n    margin-bottom: 14px;\n    font-weight: 400;\n  }\n  .agency-intro__tagline {\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-deep-graphite);\n    font-weight: 400;\n    margin: 0 0 56px 0;\n    text-transform: uppercase;\n    letter-spacing: 0.01em;\n  }\n  .agency-intro__headline {\n    font-family: var(--font-aftenscreen);\n    font-size: 80px;\n    line-height: 0.88;\n    letter-spacing: -0.04em;\n    color: var(--color-deep-graphite);\n    font-weight: 400;\n    margin: 0 0 -8px 0;\n  }\n  .agency-intro__headline-row {\n    display: flex;\n    align-items: baseline;\n    gap: 16px;\n  }\n  .agency-intro__amp {\n    font-family: var(--font-aftenscreen);\n    font-size: 80px;\n    line-height: 0.88;\n    letter-spacing: -0.04em;\n    color: var(--color-soft-gray-highlight);\n    font-weight: 400;\n  }\n  .agency-intro__headline-tech {\n    font-family: var(--font-aftenscreen);\n    font-size: 80px;\n    line-height: 0.88;\n    letter-spacing: -0.04em;\n    color: var(--color-deep-graphite);\n    font-weight: 400;\n    margin: 0;\n  }\n</style>\n<div class=\"agency-intro\">\n  <p class=\"agency-intro__label\">Creative Agency</p>\n  <p class=\"agency-intro__tagline\">We design and build lovable digital products,<br>brands, and experiences.</p>\n  <div style=\"overflow:hidden;\">\n    <p class=\"agency-intro__headline\" style=\"margin:0 0 4px 0;\">Design</p>\n    <div class=\"agency-intro__headline-row\">\n      <span class=\"agency-intro__amp\">&amp;</span>\n      <span class=\"agency-intro__headline-tech\">Technology</span>\n    </div>\n  </div>\n</div>",
          "name": "Agency Intro Block",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-canvas-white: #f2f2f2;\n    --color-deep-graphite: #070707;\n    --color-off-white: #ffffff;\n    --color-soft-gray-highlight: #a2a2a9;\n    --color-medium-gray-highlight: #797979;\n    --font-aftenscreen: 'Montserrat', 'Open Sans', sans-serif;\n    --font-bentonsans: 'Inter', 'Lato', sans-serif;\n  }\n  .work-grid {\n    background: var(--color-canvas-white);\n    padding: 40px 32px;\n    font-family: var(--font-bentonsans);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n  .work-grid__grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n  }\n  .work-grid__card {\n    display: flex;\n    flex-direction: column;\n  }\n  .work-grid__image {\n    width: 100%;\n    height: 190px;\n    border-radius: 4.16667px;\n    margin-bottom: 12px;\n    overflow: hidden;\n    flex-shrink: 0;\n  }\n  .work-grid__image--cartier {\n    background: #1a2744;\n  }\n  .work-grid__image--polyai {\n    background: #c8c2b8;\n  }\n  .work-grid__image--lynseye {\n    background: #d4c97a;\n  }\n  .work-grid__image--bio {\n    background: #b8cfd6;\n  }\n  .work-grid__image-inner {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .work-grid__meta {\n    display: flex;\n    align-items: baseline;\n    gap: 0;\n    flex-wrap: wrap;\n  }\n  .work-grid__client {\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-deep-graphite);\n    font-weight: 400;\n  }\n  .work-grid__separator {\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-soft-gray-highlight);\n    font-weight: 400;\n    margin: 0 6px;\n  }\n  .work-grid__industry {\n    font-family: var(--font-bentonsans);\n    font-size: 16px;\n    line-height: 1.4;\n    color: var(--color-soft-gray-highlight);\n    font-weight: 400;\n  }\n</style>\n<div class=\"work-grid\">\n  <div class=\"work-grid__grid\">\n    <div class=\"work-grid__card\">\n      <div class=\"work-grid__image work-grid__image--cartier\">\n        <div class=\"work-grid__image-inner\">\n          <div style=\"width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.12);\"></div>\n        </div>\n      </div>\n      <div class=\"work-grid__meta\">\n        <span class=\"work-grid__client\">Cartier</span>\n        <span class=\"work-grid__separator\">—</span>\n        <span class=\"work-grid__industry\">Luxury</span>\n      </div>\n    </div>\n    <div class=\"work-grid__card\">\n      <div class=\"work-grid__image work-grid__image--polyai\">\n        <div class=\"work-grid__image-inner\">\n          <svg width=\"80\" height=\"28\" viewBox=\"0 0 80 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"0\" y=\"14\" width=\"4\" height=\"14\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"6\" y=\"8\" width=\"4\" height=\"20\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"12\" y=\"4\" width=\"4\" height=\"24\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"18\" y=\"2\" width=\"4\" height=\"26\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"24\" y=\"6\" width=\"4\" height=\"22\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"30\" y=\"10\" width=\"4\" height=\"18\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"36\" y=\"3\" width=\"4\" height=\"25\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"42\" y=\"7\" width=\"4\" height=\"21\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"48\" y=\"11\" width=\"4\" height=\"17\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"54\" y=\"5\" width=\"4\" height=\"23\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"60\" y=\"9\" width=\"4\" height=\"19\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"66\" y=\"13\" width=\"4\" height=\"15\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n            <rect x=\"72\" y=\"16\" width=\"4\" height=\"12\" rx=\"2\" fill=\"rgba(255,255,255,0.7)\"/>\n          </svg>\n        </div>\n      </div>\n      <div class=\"work-grid__meta\">\n        <span class=\"work-grid__client\">Poly AI</span>\n        <span class=\"work-grid__separator\">—</span>\n        <span class=\"work-grid__industry\">AI Technologies</span>\n      </div>\n    </div>\n    <div class=\"work-grid__card\">\n      <div class=\"work-grid__image work-grid__image--lynseye\">\n        <div class=\"work-grid__image-inner\">\n          <div style=\"width:64px;height:110px;background:rgba(255,255,255,0.85);border-radius:4px;display:flex;align-items:flex-start;padding:8px;box-sizing:border-box;\">\n            <div style=\"width:100%;\">\n              <div style=\"height:6px;background:#222;border-radius:2px;margin-bottom:5px;width:80%;\"></div>\n              <div style=\"height:4px;background:#aaa;border-radius:2px;margin-bottom:3px;width:60%;\"></div>\n              <div style=\"height:4px;background:#aaa;border-radius:2px;margin-bottom:3px;width:50%;\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"work-grid__meta\">\n        <span class=\"work-grid__client\">Lynseye</span>\n        <span class=\"work-grid__separator\">—</span>\n        <span class=\"work-grid__industry\">Fashion</span>\n      </div>\n    </div>\n    <div class=\"work-grid__card\">\n      <div class=\"work-grid__image work-grid__image--bio\">\n        <div class=\"work-grid__image-inner\">\n          <div style=\"width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.25);\"></div>\n        </div>\n      </div>\n      <div class=\"work-grid__meta\">\n        <span class=\"work-grid__client\">BioAtla</span>\n        <span class=\"work-grid__separator\">—</span>\n        <span class=\"work-grid__industry\">Biotech</span>\n      </div>\n    </div>\n  </div>\n</div>",
