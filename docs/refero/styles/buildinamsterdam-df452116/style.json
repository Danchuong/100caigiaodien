">Services</a>\n      <a href=\"#\" style=\"display:flex;align-items:center;padding:0 20px;font-family:var(--font-nhaasgrotesktxpro);font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-arctic-white);text-decoration:none;background:transparent;border-radius:0;line-height:1.2;transition:background 0.15s;\">About</a>\n      <a href=\"#\" style=\"display:flex;align-items:center;padding:0 20px;font-family:var(--font-nhaasgrotesktxpro);font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-midnight-ink);background:var(--color-canvas-off-white);text-decoration:none;border-radius:4px 4px 0 0;line-height:1.2;\">Contact</a>\n    </div>\n  </nav>\n  <div style=\"background:var(--color-arctic-white);padding:16px 20px;display:flex;align-items:center;justify-content:flex-end;\">\n    <span style=\"font-family:var(--font-nhaasgrotesktxpro);font-size:10px;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-midnight-ink);line-height:1.2;\">CERTIFIED SHOPIFY PLUS PARTNER</span>\n  </div>\n</div>",
