        {
          "html": "<div style=\"--color-midnight-ink:#000000;--color-deep-graphite:#111111;--color-charcoal-surface:#191919;--color-dark-slate:#202020;--color-medium-gray:#3a3a3a;--color-stone-accent:#606060;--color-light-steel:#b4b4b4;--color-almost-white:#eeeeee;--color-highlight-orange:#DA5C2C;--font-berkeleymono:'IBM Plex Mono',monospace;--font-inter:'Inter',sans-serif;background:var(--color-midnight-ink);padding:48px 40px;width:600px;box-sizing:border-box;font-family:var(--font-berkeleymono);\"><p style=\"font-family:var(--font-berkeleymono);font-size:13px;color:var(--color-stone-accent);margin:0 0 16px 0;font-weight:400;\">~/</p><h1 style=\"font-family:var(--font-berkeleymono);font-size:32px;line-height:1.25;color:var(--color-almost-white);font-weight:400;margin:0 0 20px 0;max-width:520px;\">Observability re-invented for high-scale engineering teams</h1><p style=\"font-family:var(--font-berkeleymono);font-size:14px;line-height:1.57;color:var(--color-light-steel);margin:0 0 36px 0;max-width:440px;font-weight:400;\">The agent-native platform for logs, metrics, traces, and events. Built for humans and machines alike.</p><div style=\"display:flex;gap:16px;align-items:center;\"><a href=\"#\" style=\"display:inline-block;background:var(--color-highlight-orange);color:var(--color-almost-white);font-family:var(--font-berkeleymono);font-size:14px;font-weight:400;padding:10px 20px;border-radius:2px;text-decoration:none;box-shadow:rgba(0,0,0,0.05) 0px 1px 2px 0px;letter-spacing:normal;\">Book a demo</a><a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-almost-white);font-family:var(--font-berkeleymono);font-size:14px;font-weight:400;padding:9px 20px;border-radius:2px;text-decoration:none;border:1px solid var(--color-almost-white);letter-spacing:normal;\">Sign up for free →</a></div></div>",
