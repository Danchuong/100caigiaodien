      "components": [
        {
          "html": "<div style=\"--color-midnight-ink:#0a0a0a;--color-obsidian-slate:#262626;--color-electric-green:#27f795;--color-pure-white:#ffffff;--color-silver-mist:#8d8d8d;--font-roboto:'Roboto',system-ui,sans-serif;--font-roboto-mono:'Roboto Mono',monospace; background:var(--color-midnight-ink);padding:48px 24px;display:flex;flex-direction:column;align-items:center;gap:32px;width:600px;box-sizing:border-box;\"><p style=\"font-family:var(--font-roboto);font-size:18px;color:var(--color-silver-mist);margin:0;text-align:center;line-height:1.67;\">The data infrastructure and tooling to ship enterprise grade analytical features faster and at a fraction of the cost</p><div style=\"display:flex;align-items:center;gap:24px;flex-wrap:wrap;justify-content:center;\"><a href=\"#\" style=\"font-family:var(--font-roboto-mono);font-size:14px;font-weight:400;color:var(--color-midnight-ink);background:var(--color-electric-green);padding:12px 28px;border-radius:0px;text-decoration:none;letter-spacing:-0.0840em;display:inline-block;\">Try for free</a><a href=\"#\" style=\"font-family:var(--font-roboto-mono);font-size:14px;font-weight:400;color:var(--color-electric-green);background:transparent;padding:12px 28px;border-radius:0px;text-decoration:none;letter-spacing:-0.0840em;border:1px solid var(--color-electric-green);display:inline-block;\">Contact sales</a></div></div>",
