        {
          "html": "<div style=\"--color-canvas-white:#ffffff;--color-ebony-text:#000000;--color-sky-blue:#006aff;--color-horizon-gray:#dce2ea;--color-cloud-cover:#f9fafb;--color-ghost-button-background:#eff2f6;--color-slate-text:#405168;--color-steel-icon:#667b99;--font-intervariable:'Inter',system-ui,sans-serif;box-sizing:border-box;font-family:var(--font-intervariable);background:var(--color-canvas-white);width:600px;\">\n  <!-- Auth panel -->\n  <div style=\"padding:24px 20px 28px 20px;border-right:1px solid var(--color-horizon-gray);width:200px;display:inline-block;vertical-align:top;\">\n    <div style=\"margin-bottom:16px;\">\n      <svg width=\"32\" height=\"28\" viewBox=\"0 0 32 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M6.5 2C3.5 5 2 9 2 14c0 3.5 1 6.5 3 9s4.5 3.5 7.5 3.5c1.5 0 3-.5 4-1.5L18 24c1 1.5 2.5 2.5 4.5 2.5 2 0 3.5-.8 4.7-2.3C28.4 22.7 29 20.7 29 18.5c0-2-.5-4-1.5-5.5-1-1.8-2.5-3.5-4.5-5-2-1.5-4-2.5-6.5-3C14 4.5 11 3.5 9 2.5 8 2 7.2 1.8 6.5 2z\" fill=\"var(--color-sky-blue)\"/></svg>\n    </div>\n    <h2 style=\"font-family:var(--font-intervariable);font-size:20px;font-weight:700;color:var(--color-ebony-text);line-height:1.25;margin:0 0 16px 0;\">Join the conversation</h2>\n    <div style=\"display:flex;flex-direction:column;gap:10px;\">\n      <button style=\"font-family:var(--font-intervariable);font-size:14px;font-weight:600;color:#ffffff;background:var(--color-sky-blue);border:none;border-radius:999px;padding:8px 18px;cursor:pointer;text-align:center;\">Create account</button>\n      <button style=\"font-family:var(--font-intervariable);font-size:14px;font-weight:600;color:var(--color-ebony-text);background:var(--color-ghost-button-background);border:none;border-radius:999px;padding:8px 18px;cursor:pointer;text-align:center;\">Sign in</button>\n    </div>\n    <div style=\"margin-top:16px;display:flex;align-items:center;gap:5px;cursor:pointer;\">\n      <span style=\"font-family:var(--font-intervariable);font-size:13px;color:var(--color-ebony-text);\">English</span>\n      <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4l4 4 4-4\" stroke=\"var(--color-steel-icon)\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </div>\n  </div>\n  <!-- Tab bar -->\n  <div style=\"display:inline-block;vertical-align:top;width:380px;border-bottom:1px solid var(--color-horizon-gray);\">\n    <div style=\"display:flex;align-items:stretch;\">\n      <div style=\"flex:1;text-align:center;padding:14px 0 0 0;position:relative;\">\n        <span style=\"font-family:var(--font-intervariable);font-size:15px;font-weight:700;color:var(--color-ebony-text);display:block;padding-bottom:14px;\">Discover</span>\n        <div style=\"position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:60px;height:3px;background:var(--color-sky-blue);border-radius:2px;\"></div>\n      </div>\n      <div style=\"flex:1;text-align:center;padding:14px 0 0 0;\">\n        <span style=\"font-family:var(--font-intervariable);font-size:15px;font-weight:500;color:var(--color-slate-text);display:block;padding-bottom:14px;\">Feeds ✨</span>\n      </div>\n    </div>\n    <!-- Search bar -->\n    <div style=\"padding:12px 16px;background:var(--color-canvas-white);border-bottom:1px solid var(--color-horizon-gray);\">\n      <div style=\"display:flex;align-items:center;gap:8px;background:var(--color-ghost-button-background);border-radius:999px;padding:9px 14px;\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--color-steel-icon)\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg>\n        <input type=\"text\" placeholder=\"Search\" style=\"border:none;background:transparent;font-family:var(--font-intervariable);font-size:14px;color:var(--color-ebony-text);outline:none;width:100%;\" />\n      </div>\n    </div>\n  </div>\n</div>",
