        {
          "html": "<style>\n  :root {\n    --color-midnight-grid: #000000;\n    --color-slate-night: #0e0c0c;\n    --color-faded-ash: #aeafb0;\n    --color-ghost-white: #fafaf9;\n    --color-subtle-gray: #e5e7eb;\n    --color-blaze-orange: #f6511d;\n    --font-primary: 'Inter', sans-serif;\n  }\n</style>\n<div style=\"background: #0a0808; padding: 32px 24px; font-family: 'Inter', sans-serif; max-width: 600px; box-sizing: border-box;\">\n  <p style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 300; line-height: 1.6; color: var(--color-faded-ash); margin: 0 0 32px 0; text-align: right;\">Conway can find threats at every stage of the fraud lifecycle,<br>learning from every resolved case.</p>\n  <div style=\"display: flex; flex-direction: column; gap: 0px; position: relative;\">\n    <div style=\"position: absolute; left: 7px; top: 16px; bottom: 16px; width: 1px; background: rgba(250,250,249,0.12);\"></div>\n    <!-- Stage 1 -->\n    <div style=\"display: flex; align-items: flex-start; gap: 20px; padding: 16px 0; border-bottom: 1px solid rgba(250,250,249,0.07);\">\n      <div style=\"width: 15px; height: 15px; border-radius: 50%; border: 1px solid rgba(250,250,249,0.3); background: #0a0808; flex-shrink: 0; margin-top: 3px; position: relative; z-index: 1;\"></div>\n      <div style=\"flex: 1;\">\n        <div style=\"font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 300; color: var(--color-ghost-white); margin-bottom: 10px; letter-spacing: -0.01em;\">Onboarding</div>\n        <div style=\"display: flex; flex-wrap: wrap; gap: 6px;\">\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Fake Accounts</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">First-Party Fraud</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Synthetic Identity</span>\n        </div>\n      </div>\n    </div>\n    <!-- Stage 2 -->\n    <div style=\"display: flex; align-items: flex-start; gap: 20px; padding: 16px 0; border-bottom: 1px solid rgba(250,250,249,0.07);\">\n      <div style=\"width: 15px; height: 15px; border-radius: 50%; border: 1px solid rgba(250,250,249,0.3); background: #0a0808; flex-shrink: 0; margin-top: 3px; position: relative; z-index: 1;\"></div>\n      <div style=\"flex: 1;\">\n        <div style=\"font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 300; color: var(--color-ghost-white); margin-bottom: 10px; letter-spacing: -0.01em;\">Login &amp; Session</div>\n        <div style=\"display: flex; flex-wrap: wrap; gap: 6px;\">\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Credential Stuffing</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Session Hijacking</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Phishing</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">ATO</span>\n        </div>\n      </div>\n    </div>\n    <!-- Stage 3 (active) -->\n    <div style=\"display: flex; align-items: flex-start; gap: 20px; padding: 16px 0; border-bottom: 1px solid rgba(250,250,249,0.07);\">\n      <div style=\"width: 15px; height: 15px; border-radius: 50%; border: 1px solid var(--color-blaze-orange); background: var(--color-blaze-orange); flex-shrink: 0; margin-top: 3px; position: relative; z-index: 1;\"></div>\n      <div style=\"flex: 1;\">\n        <div style=\"font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 300; color: var(--color-ghost-white); margin-bottom: 10px; letter-spacing: -0.01em;\">Transaction</div>\n        <div style=\"display: flex; flex-wrap: wrap; gap: 6px;\">\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Wire Transfers</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Card Fraud</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Cross-Product Fraud</span>\n        </div>\n      </div>\n    </div>\n    <!-- Stage 4 -->\n    <div style=\"display: flex; align-items: flex-start; gap: 20px; padding: 16px 0; border-bottom: 1px solid rgba(250,250,249,0.07);\">\n      <div style=\"width: 15px; height: 15px; border-radius: 50%; border: 1px solid rgba(250,250,249,0.3); background: #0a0808; flex-shrink: 0; margin-top: 3px; position: relative; z-index: 1;\"></div>\n      <div style=\"flex: 1;\">\n        <div style=\"font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 300; color: var(--color-ghost-white); margin-bottom: 10px; letter-spacing: -0.01em;\">Post-Transaction</div>\n        <div style=\"display: flex; flex-wrap: wrap; gap: 6px;\">\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Return Abuse</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">First-Party Disputes</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Chargebacks</span>\n        </div>\n      </div>\n    </div>\n    <!-- Stage 5 -->\n    <div style=\"display: flex; align-items: flex-start; gap: 20px; padding: 16px 0;\">\n      <div style=\"width: 15px; height: 15px; border-radius: 50%; border: 1px solid rgba(250,250,249,0.3); background: #0a0808; flex-shrink: 0; margin-top: 3px; position: relative; z-index: 1;\"></div>\n      <div style=\"flex: 1;\">\n        <div style=\"font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 300; color: var(--color-ghost-white); margin-bottom: 10px; letter-spacing: -0.01em;\">Anti-Money Laundering</div>\n        <div style=\"display: flex; flex-wrap: wrap; gap: 6px;\">\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Mule Networks</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Sanctions Evasion</span>\n          <span style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: var(--color-faded-ash); border: 1px solid rgba(250,250,249,0.18); padding: 4px 10px; border-radius: 0;\">Layering</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
