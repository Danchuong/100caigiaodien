      "components": [
        {
          "html": "<style>\n  :root {\n    --color-greige-canvas: #e5ebda;\n    --color-deep-plum: #44394c;\n    --color-pure-white: #ffffff;\n    --color-ash-border: #c0c3b6;\n    --color-input-pale-gray: #b0b2a9;\n    --color-true-black: #000000;\n    --color-accent-yellow: #FFFF00;\n    --font-montreal: 'Inter', sans-serif;\n    --font-grotesk: 'IBM Plex Sans', sans-serif;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400&family=IBM+Plex+Sans:wght@700&display=swap');\n\n  .cta-wrapper {\n    width: 600px;\n    background: var(--color-greige-canvas);\n    padding: 40px;\n    box-sizing: border-box;\n    font-family: var(--font-montreal);\n    display: flex;\n    justify-content: flex-end;\n  }\n\n  .cta-card {\n    background: var(--color-pure-white);\n    padding: 20px 20px 20px 20px;\n    width: 240px;\n    box-sizing: border-box;\n  }\n\n  .cta-card__text {\n    font-family: var(--font-montreal);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    line-height: 1.4;\n    letter-spacing: 0.023em;\n    margin: 0 0 16px 0;\n  }\n\n  .cta-card__action {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .cta-card__icon {\n    width: 28px;\n    height: 28px;\n    background: var(--color-deep-plum);\n    border-radius: 4px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .cta-card__link {\n    font-family: var(--font-montreal);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    text-decoration: none;\n    letter-spacing: 0.02em;\n    border-bottom: 1px solid var(--color-deep-plum);\n    padding-bottom: 1px;\n    line-height: 1.3;\n  }\n</style>\n<div class=\"cta-wrapper\">\n  <div class=\"cta-card\">\n    <p class=\"cta-card__text\">Tell us about your project. Let's collaborate and make real results.</p>\n    <div class=\"cta-card__action\">\n      <div class=\"cta-card__icon\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M3 11L11 3M11 3H5M11 3V9\" stroke=\"#ffffff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <a href=\"#\" class=\"cta-card__link\">Send us your thoughts.</a>\n    </div>\n  </div>\n</div>",
          "name": "Contact CTA Banner",
          "role": "",
          "description": ""
