          "html": "<style>\n  :root {\n    --color-greige-canvas: #e5ebda;\n    --color-deep-plum: #44394c;\n    --color-pure-white: #ffffff;\n    --color-ash-border: #c0c3b6;\n    --font-montreal: 'Inter', sans-serif;\n    --font-grotesk: 'IBM Plex Sans', sans-serif;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400&family=IBM+Plex+Sans:wght@700&display=swap');\n\n  .agency-wrapper {\n    width: 600px;\n    background: var(--color-greige-canvas);\n    padding: 54px 40px 60px 40px;\n    box-sizing: border-box;\n    font-family: var(--font-montreal);\n  }\n\n  .agency-eyebrow {\n    font-family: var(--font-montreal);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    letter-spacing: 0.02em;\n    line-height: 1.3;\n    opacity: 0.55;\n    margin: 0 0 18px 0;\n  }\n\n  .agency-headline {\n    font-family: var(--font-montreal);\n    font-size: 43px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    line-height: 1.1;\n    letter-spacing: -0.01em;\n    margin: 0 0 40px 0;\n  }\n\n  .agency-divider {\n    width: 100%;\n    height: 1px;\n    background: var(--color-ash-border);\n    margin: 0 0 30px 0;\n  }\n\n  .agency-body {\n    font-family: var(--font-montreal);\n    font-size: 18px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    line-height: 1.5;\n    letter-spacing: 0.02em;\n    margin: 0 0 40px 0;\n    max-width: 480px;\n  }\n\n  .agency-services {\n    display: flex;\n    gap: 0;\n    flex-wrap: wrap;\n  }\n\n  .agency-service-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    margin-right: 30px;\n    margin-bottom: 10px;\n  }\n\n  .agency-service-dot {\n    width: 5px;\n    height: 5px;\n    border-radius: 50%;\n    background: var(--color-deep-plum);\n    opacity: 0.5;\n    flex-shrink: 0;\n  }\n\n  .agency-service-label {\n    font-family: var(--font-montreal);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    letter-spacing: 0.023em;\n    line-height: 1.3;\n  }\n\n  .agency-cta {\n    margin-top: 40px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .agency-cta__link {\n    font-family: var(--font-montreal);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    letter-spacing: 0.023em;\n    text-decoration: none;\n    border-bottom: 1px solid var(--color-deep-plum);\n    padding-bottom: 1px;\n    line-height: 1.3;\n  }\n\n  .agency-cta__arrow {\n    display: flex;\n    align-items: center;\n  }\n</style>\n<div class=\"agency-wrapper\">\n  <p class=\"agency-eyebrow\">A Strategic Design and Technology Agency</p>\n  <h2 class=\"agency-headline\">Spring/Summer is a Copenhagen-based design agency</h2>\n  <div class=\"agency-divider\"></div>\n  <p class=\"agency-body\">creating impactful brands, websites, and commerce experiences. We combine strategy, technology, and aesthetics to help ambitious companies grow.</p>\n  <div class=\"agency-services\">\n    <div class=\"agency-service-item\"><div class=\"agency-service-dot\"></div><span class=\"agency-service-label\">Brand Strategy</span></div>\n    <div class=\"agency-service-item\"><div class=\"agency-service-dot\"></div><span class=\"agency-service-label\">Digital Design</span></div>\n    <div class=\"agency-service-item\"><div class=\"agency-service-dot\"></div><span class=\"agency-service-label\">Web Development</span></div>\n    <div class=\"agency-service-item\"><div class=\"agency-service-dot\"></div><span class=\"agency-service-label\">Commerce</span></div>\n    <div class=\"agency-service-item\"><div class=\"agency-service-dot\"></div><span class=\"agency-service-label\">Art Direction</span></div>\n  </div>\n  <div class=\"agency-cta\">\n    <div class=\"agency-cta__arrow\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M3 13L13 3M13 3H6M13 3V10\" stroke=\"#44394c\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </div>\n    <a href=\"#\" class=\"agency-cta__link\">See our work</a>\n  </div>\n</div>",
