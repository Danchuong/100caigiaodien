          "html": "<style>\n  :root {\n    --color-greige-canvas: #e5ebda;\n    --color-deep-plum: #44394c;\n    --color-pure-white: #ffffff;\n    --color-ash-border: #c0c3b6;\n    --font-montreal: 'Inter', sans-serif;\n    --font-grotesk: 'IBM Plex Sans', sans-serif;\n  }\n\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400&family=IBM+Plex+Sans:wght@700&display=swap');\n\n  .projects-wrapper {\n    width: 600px;\n    background: var(--color-greige-canvas);\n    padding: 30px 0 0 0;\n    box-sizing: border-box;\n    font-family: var(--font-montreal);\n  }\n\n  .projects-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0 40px 20px 40px;\n  }\n\n  .projects-header__label {\n    font-family: var(--font-montreal);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-deep-plum);\n    letter-spacing: 0.02em;\n    opacity: 0.6;\n  }\n\n  .projects-nav {\n    display: flex;\n    gap: 12px;\n    align-items: center;\n  }\n\n  .projects-nav__btn {\n    background: none;\n    border: 1px solid var(--color-ash-border);\n    cursor: pointer;\n    width: 30px;\n    height: 30px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 4px;\n    padding: 0;\n  }\n\n  .projects-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 0;\n  }\n\n  .project-card {\n    position: relative;\n    overflow: hidden;\n    cursor: pointer;\n  }\n\n  .project-card__image {\n    width: 100%;\n    height: 220px;\n    display: block;\n  }\n\n  .project-card__img-1 {\n    background: linear-gradient(160deg, #8ab3c8 0%, #c5a97e 50%, #d4956a 100%);\n  }\n\n  .project-card__img-2 {\n    background: linear-gradient(160deg, #2c2c2c 0%, #4a4a4a 50%, #1a1a1a 100%);\n  }\n\n  .project-card__overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    padding: 14px 16px;\n  }\n\n  .project-card__client {\n    font-family: var(--font-montreal);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-pure-white);\n    letter-spacing: 0.02em;\n    line-height: 1.3;\n    margin: 0 0 2px 0;\n  }\n\n  .project-card__desc {\n    font-family: var(--font-montreal);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--color-pure-white);\n    letter-spacing: 0.02em;\n    opacity: 0.75;\n    line-height: 1.3;\n    margin: 0;\n  }\n\n  .project-card__mockup {\n    position: absolute;\n    bottom: 16px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 75%;\n    height: 90px;\n    background: var(--color-pure-white);\n    border-radius: 4px;\n    overflow: hidden;\n    box-shadow: 0 4px 24px rgba(0,0,0,0.18);\n    display: flex;\n    flex-direction: column;\n    padding: 8px;\n    box-sizing: border-box;\n  }\n\n  .mockup-title {\n    font-family: var(--font-grotesk);\n    font-size: 11px;\n    font-weight: 700;\n    color: var(--color-true-black);\n    line-height: 1.1;\n    margin: 0 0 6px 0;\n  }\n\n  .mockup-body {\n    width: 80%;\n    height: 5px;\n    background: #e0e0e0;\n    border-radius: 2px;\n    margin-bottom: 3px;\n  }\n\n  .mockup-body-short {\n    width: 60%;\n    height: 5px;\n    background: #e0e0e0;\n    border-radius: 2px;\n  }\n\n  .mockup-dark {\n    background: #1a1a1a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 8px;\n  }\n\n  .mockup-dark-text {\n    font-family: var(--font-grotesk);\n    font-size: 28px;\n    font-weight: 700;\n    color: var(--color-pure-white);\n    line-height: 1;\n    opacity: 0.3;\n    letter-spacing: -1px;\n  }\n</style>\n<div class=\"projects-wrapper\">\n  <div class=\"projects-header\">\n    <span class=\"projects-header__label\">Selected work</span>\n    <div class=\"projects-nav\">\n      <button class=\"projects-nav__btn\" aria-label=\"Previous\">\n        <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\">\n          <path d=\"M8 10L4 6L8 2\" stroke=\"#44394c\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n      <button class=\"projects-nav__btn\" aria-label=\"Next\">\n        <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\">\n          <path d=\"M4 2L8 6L4 10\" stroke=\"#44394c\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n    </div>\n  </div>\n  <div class=\"projects-grid\">\n    <div class=\"project-card\">\n      <div class=\"project-card__image project-card__img-1\"></div>\n      <div class=\"project-card__overlay\">\n        <p class=\"project-card__client\">Support Greenland</p>\n        <p class=\"project-card__desc\">Kalaallit Nunaat Kalaallit Pigaat</p>\n      </div>\n      <div class=\"project-card__mockup\">\n        <div class=\"mockup-title\">SUPPORT<br>GREENLAND</div>\n        <div class=\"mockup-body\"></div>\n        <div class=\"mockup-body-short\"></div>\n      </div>\n    </div>\n    <div class=\"project-card\">\n      <div class=\"project-card__image project-card__img-2\"></div>\n      <div class=\"project-card__overlay\">\n        <p class=\"project-card__client\">Implement</p>\n        <p class=\"project-card__desc\">Online Headquarters</p>\n      </div>\n      <div class=\"project-card__mockup mockup-dark\">\n        <span class=\"mockup-dark-text\">IM</span>\n      </div>\n    </div>\n  </div>\n</div>",
