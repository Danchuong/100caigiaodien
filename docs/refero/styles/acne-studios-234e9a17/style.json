          "html": "<div style=\"--color-text-black:#000000;--color-background-white:#ffffff;--color-form-surface:#f7f7f7;--color-secondary-text-gray:#6b6b6b;--color-action-violet:#0018a8;--font-helvetica-monospaced-pro:'Space Mono',monospace;width:600px;background:var(--color-background-white);box-sizing:border-box;padding:40px 0 0;\">\n\n  <div style=\"border-top:1px solid var(--color-text-black);border-bottom:1px solid var(--color-text-black);display:flex;align-items:stretch;\">\n    <div style=\"flex:1;display:flex;align-items:center;background:var(--color-form-surface);padding:0 10px;\">\n      <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.3\" style=\"flex-shrink:0;margin-right:8px;\"><circle cx=\"5\" cy=\"5\" r=\"3.5\"/><line x1=\"8\" y1=\"8\" x2=\"11\" y2=\"11\"/></svg>\n      <input type=\"text\" placeholder=\"Search for products, categories...\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-text-black);background:transparent;border:none;outline:none;width:100%;padding:19px 0;\" />\n    </div>\n    <button style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-text-black);background:var(--color-background-white);border:none;border-left:1px solid var(--color-text-black);padding:4px 18px 18px;cursor:pointer;white-space:nowrap;border-radius:0;\">SEARCH</button>\n  </div>\n\n  <div style=\"margin-top:20px;padding:0 0 20px;\">\n    <div style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-secondary-text-gray);margin-bottom:10px;\">POPULAR SEARCHES</div>\n    <div style=\"display:flex;flex-wrap:wrap;gap:4px;\">\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;text-underline-offset:2px;padding:2px 0;\">Jeans</a>\n      <span style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;color:var(--color-secondary-text-gray);padding:2px 2px;\">/</span>\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;text-underline-offset:2px;padding:2px 0;\">T-Shirts</a>\n      <span style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;color:var(--color-secondary-text-gray);padding:2px 2px;\">/</span>\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;text-underline-offset:2px;padding:2px 0;\">Bags</a>\n      <span style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;color:var(--color-secondary-text-gray);padding:2px 2px;\">/</span>\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;text-underline-offset:2px;padding:2px 0;\">Hoodies</a>\n      <span style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;color:var(--color-secondary-text-gray);padding:2px 2px;\">/</span>\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;text-underline-offset:2px;padding:2px 0;\">Runway</a>\n      <span style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;color:var(--color-secondary-text-gray);padding:2px 2px;\">/</span>\n      <a href=\"#\" style=\"font-family:var(--font-helvetica-monospaced-pro);font-size:9px;font-weight:400;letter-spacing:0.0330em;color:var(--color-action-violet);text-decoration:underline;tex