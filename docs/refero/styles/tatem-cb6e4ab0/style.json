          "html": "<div style=\"--color-twilight-ink:#000000;--color-polar-white:#ffffff;--color-pewter-mist:#919191;--color-silver-tone:#b5b5b5;--color-obsidian-grey:#606060;--color-charcoal-black:#3b3b3b;--color-mist-grey:#c2c2c2;--color-cerulean-accent:#007eed;--color-sky-gradient:linear-gradient(rgb(90,118,148) 0%,rgb(117,141,165) 17%,rgb(126,150,168) 47%,rgb(156,173,179) 75%,rgb(171,183,181) 100%);--font-inter:'Inter',system-ui,sans-serif;background:var(--color-sky-gradient);padding:48px 40px;display:flex;flex-direction:column;gap:32px;align-items:flex-start;min-height:220px;box-sizing:border-box;\"><p style=\"font-family:var(--font-inter);font-size:13px;font-weight:400;color:rgba(255,255,255,0.7);letter-spacing:-0.1px;margin:0;\">Now in early access.</p><h1 style=\"font-family:var(--font-inter);font-size:40px;font-weight:400;color:var(--color-polar-white);letter-spacing:-0.28px;line-height:1.2;margin:0;\">The email experience<br>you've been waiting for.</h1><div style=\"display:flex;align-items:center;gap:16px;flex-wrap:wrap;\"><button style=\"font-family:var(--font-inter);font-size:14px;font-weight:400;color:rgba(255,255,255,0.95);background:rgba(252,252,252,0.08);border:1px solid rgba(255,255,255,0.06);border-radius:8px;padding:10px 16px;cursor:pointer;letter-spacing:-0.1px;\">Get started</button><span style=\"font-family:var(--font-inter);font-size:14px;font-weight:400;color:rgba(255,255,255,0.65);letter-spacing:-0.1px;display:flex;align-items:center;gap:6px;\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 6H2M5 3l-3 3 3 3\" stroke=\"rgba(255,255,255,0.6)\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Fast, beautiful, simple.</span></div></div>",
          "name": "CTA Button Group",
