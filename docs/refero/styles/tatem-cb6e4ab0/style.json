dius:5px;border:1px solid #333;\"></div></div><div style=\"display:flex;gap:5px;justify-content:center;\"><div style=\"height:28px;width:38px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#3a3a3a;border-radius:5px;border:1px solid #505050;display:flex;align-items:center;justify-content:center;\"><span style=\"font-family:var(--font-inter);font-size:11px;color:var(--color-polar-white);font-weight:400;\">K</span></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div></div><div style=\"display:flex;gap:5px;justify-content:center;\"><div style=\"height:28px;width:50px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:50px;background:#252525;border-radius:5px;border:1px solid #333;\"></div></div><div style=\"display:flex;gap:5px;justify-content:center;\"><div style=\"height:28px;width:34px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:34px;background:#3a3a3a;border-radius:5px;border:1px solid #505050;display:flex;align-items:center;justify-content:center;\"><span style=\"font-family:var(--font-inter);font-size:11px;color:var(--color-polar-white);font-weight:400;\">⌘</span></div><div style=\"height:28px;width:110px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:34px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:22px;background:#252525;border-radius:5px;border:1px solid #333;\"></div><div style=\"height:28px;width:34px;background:#252525;border-radius:5px;border:1px solid #333;\"></div></div></div><div style=\"background:#2a2a2a;border-radius:6px;padding:6px 20px;\"><span style=\"font-family:var(--font-inter);font-size:13px;font-weight:400;color:var(--color-polar-white);letter-spacing:-0.1px;\">Command menu</span></div></div></div>",
