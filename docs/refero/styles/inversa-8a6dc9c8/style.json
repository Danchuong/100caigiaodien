      "components": [
        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Inter:wght@400&display=swap');\n\n  :root {\n    --color-deep-forest: #13140e;\n    --color-creme-paper: #f4f3e8;\n    --color-lime-accent: #ebfc72;\n    --color-stone-grey: #404040;\n    --color-muddy-banks: #84837b;\n    --font-nb-international-pro: 'Inter', sans-serif;\n    --font-jetbrains-mono: 'JetBrains Mono', 'Fira Code', monospace;\n  }\n\n  .button-group-wrapper {\n    background: var(--color-deep-forest);\n    padding: 48px 40px;\n    display: flex;\n    flex-direction: column;\n    gap: 32px;\n    font-family: var(--font-jetbrains-mono);\n    max-width: 600px;\n    box-sizing: border-box;\n  }\n\n  .button-group-label {\n    font-family: var(--font-nb-international-pro);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-muddy-banks);\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin-bottom: 4px;\n  }\n\n  .button-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 14px;\n    align-items: center;\n  }\n\n  .btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    font-family: var(--font-jetbrains-mono);\n    font-size: 13px;\n    font-weight: 400;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    text-decoration: none;\n    cursor: pointer;\n    border: none;\n    outline: none;\n    padding: 11px 18px;\n    border-radius: 3.6px;\n    line-height: 1.2;\n    white-space: nowrap;\n  }\n\n  .btn-lime {\n    background: var(--color-lime-accent);\n    color: var(--color-deep-forest);\n    border-radius: 3.6px;\n  }\n\n  .btn-dark {\n    background: var(--color-deep-forest);\n    color: var(--color-creme-paper);\n    border-radius: 3.6px;\n    border: 1px solid var(--color-stone-grey);\n  }\n\n  .btn-ghost {\n    background: transparent;\n    color: var(--color-creme-paper);\n    border-radius: 0px;\n    padding: 11px 0px;\n    border: none;\n    border-bottom: 1px solid var(--color-stone-grey);\n  }\n\n  .divider {\n    border: none;\n    border-top: 1px solid var(--color-stone-grey);\n    margin: 0;\n  }\n\n  .section-title {\n    font-family: var(--font-nb-international-pro);\n    font-size: 13px;\n    color: var(--color-muddy-banks);\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin-bottom: 16px;\n  }\n</style>\n\n<div class=\"button-group-wrapper\">\n  <div>\n    <div class=\"section-title\">Primary Actions</div>\n    <div class=\"button-row\">\n      <button class=\"btn btn-lime\">Explore Origin</button>\n      <button class=\"btn btn-lime\">Get Started</button>\n      <button class=\"btn btn-lime\">View Report →</button>\n    </div>\n  </div>\n\n  <hr class=\"divider\" />\n\n  <div>\n    <div class=\"section-title\">Secondary Actions</div>\n    <div class=\"button-row\">\n      <button class=\"btn btn-dark\">Learn More</button>\n      <button class=\"btn btn-dark\">Download PDF</button>\n      <button class=\"btn btn-dark\">Contact Us</button>\n    </div>\n  </div>\n\n  <hr class=\"divider\" />\n\n  <div>\n    <div class=\"section-title\">Ghost / Navigation</div>\n    <div class=\"button-row\">\n      <button class=\"btn btn-ghost\">About</button>\n      <button class=\"btn btn-ghost\">Solutions</button>\n      <button class=\"btn btn-ghost\">Case Studies</button>\n      <button class=\"btn btn-ghost\">Menu +–</button>\n    </div>\n  </div>\n</div>",
          "name": "Lime CTA Button Group",
          "role": "",
          "description": ""
