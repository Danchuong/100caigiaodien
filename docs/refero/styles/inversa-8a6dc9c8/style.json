          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Inter:wght@400&display=swap');\n\n  :root {\n    --color-deep-forest: #13140e;\n    --color-creme-paper: #f4f3e8;\n    --color-lime-accent: #ebfc72;\n    --color-stone-grey: #404040;\n    --color-muddy-banks: #84837b;\n    --font-nb-international-pro: 'Inter', sans-serif;\n    --font-jetbrains-mono: 'JetBrains Mono', 'Fira Code', monospace;\n  }\n\n  .alerts-wrapper {\n    background: var(--color-deep-forest);\n    padding: 40px;\n    max-width: 600px;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n    font-family: var(--font-jetbrains-mono);\n  }\n\n  .alerts-header {\n    font-family: var(--font-nb-international-pro);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-muddy-banks);\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n  }\n\n  .alert-banner {\n    display: flex;\n    align-items: flex-start;\n    gap: 14px;\n    padding: 18px;\n    border-radius: 3.6px;\n    border: 1px solid var(--color-stone-grey);\n    background: #1a1c14;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .alert-banner.alert-active {\n    border-color: var(--color-lime-accent);\n    background: #1d2012;\n  }\n\n  .alert-banner.alert-active::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 0;\n    bottom: 0;\n    width: 3px;\n    background: var(--color-lime-accent);\n  }\n\n  .alert-banner.alert-warning::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 0;\n    bottom: 0;\n    width: 3px;\n    background: var(--color-creme-paper);\n  }\n\n  .alert-banner.alert-muted::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 0;\n    bottom: 0;\n    width: 3px;\n    background: var(--color-stone-grey);\n  }\n\n  .alert-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    flex-shrink: 0;\n    margin-top: 4px;\n  }\n\n  .dot-active { background: var(--color-lime-accent); }\n  .dot-warning { background: var(--color-creme-paper); }\n  .dot-muted { background: var(--color-stone-grey); }\n\n  .alert-content {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .alert-title {\n    font-family: var(--font-nb-international-pro);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-creme-paper);\n    letter-spacing: -0.03em;\n    line-height: 1.25;\n  }\n\n  .alert-active .alert-title {\n    color: var(--color-lime-accent);\n  }\n\n  .alert-body {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 13px;\n    font-weight: 300;\n    color: var(--color-muddy-banks);\n    line-height: 1.62;\n  }\n\n  .alert-meta {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-top: 8px;\n  }\n\n  .alert-tag {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 11px;\n    font-weight: 400;\n    color: var(--color-deep-forest);\n    background: var(--color-lime-accent);\n    padding: 2px 8px;\n    border-radius: 3.6px;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n  }\n\n  .alert-tag.tag-neutral {\n    background: var(--color-stone-grey);\n    color: var(--color-creme-paper);\n  }\n\n  .alert-time {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 11px;\n    color: var(--color-stone-grey);\n    letter-spacing: 0.04em;\n  }\n\n  .alert-action {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 12px;\n    color: var(--color-lime-accent);\n    text-decoration: none;\n    border-bottom: 1px solid var(--color-stone-grey);\n    padding-bottom: 1px;\n    white-space: nowrap;\n    flex-shrink: 0;\n    margin-top: 4px;\n    align-self: flex-start;\n  }\n</style>\n\n<div class=\"alerts-wrapper\">\n  <div class=\"alerts-header\">Active Field Alerts</div>\n\n  <div class=\"alert-banner alert-active\">\n    <div class=\"alert-dot dot-active\"></div>\n    <div class=\"alert-content\">\n      <div class=\"alert-title\">Invasive Detection — Zone 7B</div>\n      <div class=\"alert-body\">Spotted Lanternfly cluster confirmed in northeastern corridor. Spread rate exceeds threshold parameters.</div>\n      <div class=\"alert-meta\">\n        <span class=\"alert-tag\">Critical</span>\n        <span class=\"alert-time\">02:14 ago</span>\n      </div>\n    </div>\n    <a href=\"#\" class=\"alert-action\">Respond →</a>\n  </div>\n\n  <div class=\"alert-banner alert-warning\">\n    <div class=\"alert-dot dot-warning\"></div>\n    <div class=\"alert-content\">\n      <div class=\"alert-title\">Water Quality Anomaly — River Delta</div>\n      <div class=\"alert-body\">pH variance detected in monitoring grid 4. Possible early indicator of aquatic invasive species activity.</div>\n      <div class=\"alert-meta\">\n        <span class=\"alert-tag tag-neutral\">Monitoring</span>\n        <span class=\"alert-time\">1h 08m ago</span>\n      </div>\n    </div>\n    <a href=\"#\" class=\"alert-action\">Review →</a>\n  </div>\n\n  <div class=\"alert-banner alert-muted\">\n    <div class=\"alert-dot dot-muted\"></div>\n    <div class=\"alert-content\">\n      <div class=\"alert-title\">Routine Scan Complete — Sector 12</div>\n      <div class=\"alert-body\">No anomalies detected. Next automated scan scheduled in 6 hours.</div>\n      <div class=\"alert-meta\">\n        <span class=\"alert-tag tag-neutral\">Resolved</span>\n        <span class=\"alert-time\">4h 31m ago</span>\n      </div>\n    </div>\n  </div>\n</div>",
