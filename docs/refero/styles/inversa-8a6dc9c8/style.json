        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Inter:wght@400&display=swap');\n\n  :root {\n    --color-deep-forest: #13140e;\n    --color-creme-paper: #f4f3e8;\n    --color-lime-accent: #ebfc72;\n    --color-stone-grey: #404040;\n    --color-muddy-banks: #84837b;\n    --font-nb-international-pro: 'Inter', sans-serif;\n    --font-jetbrains-mono: 'JetBrains Mono', 'Fira Code', monospace;\n  }\n\n  .stats-wrapper {\n    background: var(--color-deep-forest);\n    padding: 48px 40px;\n    max-width: 600px;\n    box-sizing: border-box;\n    font-family: var(--font-jetbrains-mono);\n  }\n\n  .stats-eyebrow {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--color-muddy-banks);\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    margin-bottom: 32px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .stats-eyebrow::before {\n    content: '';\n    display: inline-block;\n    width: 20px;\n    height: 1px;\n    background: var(--color-muddy-banks);\n  }\n\n  .stats-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 0;\n    border-top: 1px solid var(--color-stone-grey);\n    border-left: 1px solid var(--color-stone-grey);\n  }\n\n  .stat-card {\n    padding: 29px 21px;\n    border-right: 1px solid var(--color-stone-grey);\n    border-bottom: 1px solid var(--color-stone-grey);\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  .stat-value {\n    font-family: var(--font-nb-international-pro);\n    font-size: 58px;\n    font-weight: 400;\n    color: var(--color-creme-paper);\n    line-height: 1.06;\n    letter-spacing: -0.03em;\n  }\n\n  .stat-value span {\n    color: var(--color-lime-accent);\n    font-size: 36px;\n  }\n\n  .stat-label {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 13px;\n    font-weight: 300;\n    color: var(--color-muddy-banks);\n    line-height: 1.62;\n    letter-spacing: 0.02em;\n    text-transform: uppercase;\n  }\n\n  .stat-desc {\n    font-family: var(--font-jetbrains-mono);\n    font-size: 13px;\n    font-weight: 300;\n    color: var(--color-creme-paper);\n    line-height: 1.62;\n    margin-top: 4px;\n    opacity: 0.6;\n  }\n</style>\n\n<div class=\"stats-wrapper\">\n  <div class=\"stats-eyebrow\">Impact by the numbers</div>\n  <div class=\"stats-grid\">\n    <div class=\"stat-card\">\n      <div class=\"stat-value\">42<span>K+</span></div>\n      <div class=\"stat-label\">Species Tracked</div>\n      <div class=\"stat-desc\">Monitored across 6 continents in real time</div>\n    </div>\n    <div class=\"stat-card\">\n      <div class=\"stat-value\">98<span>%</span></div>\n      <div class=\"stat-label\">Detection Rate</div>\n      <div class=\"stat-desc\">Invasive event identification accuracy</div>\n    </div>\n    <div class=\"stat-card\">\n      <div class=\"stat-value\">3.2<span>M</span></div>\n      <div class=\"stat-label\">Hectares Protected</div>\n      <div class=\"stat-desc\">Ecosystem area under active monitoring</div>\n    </div>\n    <div class=\"stat-card\">\n      <div class=\"stat-value\">18<span>h</span></div>\n      <div class=\"stat-label\">Avg. Response Time</div>\n      <div class=\"stat-desc\">From detection to field team deployment</div>\n    </div>\n  </div>\n</div>",
