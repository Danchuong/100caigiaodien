      "components": [
        {
          "html": "<div style=\"--color-canvas-white:#ffffff;--color-ink-black:#0f0f0f;--color-medium-gray:#606060;--color-accent-blue:#065fd4;--color-border-gray:#c6c6c6;--font-roboto:Roboto,system-ui,sans-serif;--font-youtube-sans:Roboto,system-ui,sans-serif;box-sizing:border-box;background:#f9f9f9;padding:32px;display:flex;justify-content:center;align-items:center;min-height:240px;\"><div style=\"background:var(--color-canvas-white);border:1px solid #eeeeee;border-radius:10px;padding:32px 40px 28px 40px;max-width:540px;width:100%;text-align:center;font-family:var(--font-roboto);\"><h2 style=\"margin:0 0 16px 0;font-family:var(--font-roboto);font-size:18px;font-weight:700;color:var(--color-ink-black);line-height:1.3;\">Your YouTube history is off</h2><p style=\"margin:0 0 12px 0;font-family:var(--font-roboto);font-size:14px;color:var(--color-ink-black);line-height:1.5;\">You can turn on watch and search history at any time to get the latest videos tailored to you.</p><p style=\"margin:0 0 24px 0;font-family:var(--font-roboto);font-size:14px;color:var(--color-ink-black);line-height:1.5;\">To update your selection, turn on YouTube History and confirm your settings to accept the use of cookies and data. <a href=\"#\" style=\"color:var(--color-accent-blue);text-decoration:none;font-family:var(--font-roboto);font-size:14px;\">Learn more</a></p><button style=\"display:block;width:100%;padding:12px 16px;background:rgba(0,0,0,0.05);border:none;border-radius:18px;font-family:var(--font-roboto);font-size:14px;font-weight:700;color:var(--color-ink-black);cursor:pointer;text-align:center;\">Update setting</button></div></div>",
          "name": "History Off — Dialogue Card",
          "role": "",
          "description": ""
