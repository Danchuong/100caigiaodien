      "components": [
        {
          "html": "<div style=\"--color-midnight-ink:#000000;--color-canvas-white:#ffffff;--color-whisper-gray:#f6f6f6;--color-charcoal-text:#333333;--color-input-border-gray:#767676;--color-subtle-silver:#afafaf;--color-slate-shadow:#d6d6d6;--color-lagoon-mist:#9dcdd6;--font-ubermove:system-ui,sans-serif;--font-ubermovetext:system-ui,sans-serif;box-sizing:border-box;font-family:var(--font-ubermovetext);background:var(--color-canvas-white);padding:40px;width:600px;\">\n  <div style=\"display:flex;align-items:center;gap:6px;margin-bottom:16px;\">\n    <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z\" fill=\"#000000\"/></svg>\n    <span style=\"font-family:var(--font-ubermovetext);font-size:14px;color:var(--color-midnight-ink);\">Barcelona, ES</span>\n    <a href=\"#\" style=\"font-family:var(--font-ubermovetext);font-size:14px;color:var(--color-midnight-ink);text-decoration:underline;margin-left:4px;\">Change city</a>\n  </div>\n\n  <h1 style=\"font-family:var(--font-ubermove);font-size:52px;font-weight:700;line-height:1.1;color:var(--color-midnight-ink);margin:0 0 28px 0;\">Go anywhere with Uber</h1>\n\n  <button style=\"display:inline-flex;align-items:center;gap:8px;background:var(--color-whisper-gray);color:var(--color-midnight-ink);border:none;border-radius:999px;padding:10px 16px;font-family:var(--font-ubermovetext);font-size:14px;font-weight:500;cursor:pointer;margin-bottom:20px;\">\n    <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"#000\" stroke-width=\"2\"/><path d=\"M12 6v6l4 2\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg>\n    Pickup now\n    <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M6 9l6 6 6-6\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n  </button>\n\n  <div style=\"background:var(--color-whisper-gray);border-radius:12px;overflow:hidden;margin-bottom:20px;\">\n    <div style=\"display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid var(--color-slate-shadow);\">\n      <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"12\" cy=\"12\" r=\"8\" fill=\"#000\"/></svg>\n      <span style=\"font-family:var(--font-ubermovetext);font-size:16px;color:var(--color-subtle-silver);flex:1;\">Pickup location</span>\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M22 2L11 13\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M22 2L15 22l-4-9-9-4 20-7z\" stroke=\"#000\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n    </div>\n    <div style=\"display:flex;align-items:center;gap:12px;padding:16px 20px;\">\n      <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\" fill=\"#000\"/></svg>\n      <span style=\"font-family:var(--font-ubermovetext);font-size:16px;color:var(--color-subtle-silver);flex:1;\">Dropoff location</span>\n    </div>\n  </div>\n\n  <div style=\"display:flex;align-items:center;gap:20px;\">\n    <button style=\"background:var(--color-midnight-ink);color:var(--color-canvas-white);border:none;border-radius:8px;padding:14px 28px;font-family:var(--font-ubermovetext);font-size:16px;font-weight:500;cursor:pointer;\">See prices</button>\n    <a href=\"#\" style=\"font-family:var(--font-ubermovetext);font-size:14px;color:var(--color-midnight-ink);text-decoration:underline;\">Log in to see your recent activity</a>\n  </div>\n</div>",
