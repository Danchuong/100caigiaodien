dius:12px 12px 0 0;margin-left:8px;\"></div>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"margin-top:40px;background:var(--color-midnight-ink);border-radius:12px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;\">\n    <span style=\"font-family:var(--font-ubermove);font-size:20px;font-weight:400;color:var(--color-canvas-white);\">Ready to travel?</span>\n    <button style=\"background:var(--color-canvas-white);color:var(--color-midnight-ink);border:none;border-radius:999px;padding:12px 20px;font-family:var(--font-ubermovetext);font-size:15px;font-weight:500;cursor:pointer;\">Schedule ahead</button>\n  </div>\n</div>",
