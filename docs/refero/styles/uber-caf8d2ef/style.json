ize:20px;font-weight:400;color:var(--color-midnight-ink);margin-bottom:8px;\">Reserve</div>\n        <div style=\"font-family:var(--font-ubermovetext);font-size:13px;color:var(--color-charcoal-text);line-height:1.43;margin-bottom:16px;\">Reserve your ride in advance so you can relax on the day of your trip.</div>\n      </div>\n      <div style=\"width:72px;height:48px;background:var(--color-lagoon-mist);border-radius:8px;align-self:flex-end;margin-bottom:16px;opacity:0.7;\"></div>\n      <button style=\"background:var(--color-canvas-white);color:var(--color-midnight-ink);border:none;border-radius:999px;padding:8px 16px;font-family:var(--font-ubermovetext);font-size:14px;font-weight:400;cursor:pointer;align-self:flex-start;\">Details</button>\n    </div>\n\n    <div style=\"background:var(--color-whisper-gray);border-radius:8px;padding:20px 16px;display:flex;flex-direction:column;min-height:180px;position:relative;overflow:hidden;\">\n      <div style=\"flex:1;\">\n        <div style=\"font-family:var(--font-ubermove);font-size:20px;font-weight:400;color:var(--color-midnight-ink);margin-bottom:8px;\">Food</div>\n        <div style=\"font-family:var(--font-ubermovetext);font-size:13px;color:var(--color-charcoal-text);line-height:1.43;margin-bottom:16px;\">Order delivery from local restaurants with Uber Eats.</div>\n      </div>\n      <div style=\"width:72px;height:48px;background:#c8e6c9;border-radius:8px;align-self:flex-end;margin-bottom:16px;opacity:0.8;\"></div>\n      <button style=\"background:var(--color-canvas-white);color:var(--color-midnight-ink);border:none;border-radius:999px;padding:8px 16px;font-family:var(--font-ubermovetext);font-size:14px;font-weight:400;cursor:pointer;align-self:flex-start;\">Details</button>\n    </div>\n\n  </div>\n</div>",
