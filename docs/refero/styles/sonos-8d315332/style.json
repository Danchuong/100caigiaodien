      "components": [
        {
          "html": "<style>\n  :root {\n    --color-absolute-zero: #000000;\n    --color-studio-white: #ffffff;\n    --color-soft-gray: #f5f5f5;\n    --color-pale-border: #e0e0e0;\n    --color-ghost-gray: #737373;\n    --font-aktiv-grotesk: 'Inter', sans-serif;\n  }\n</style>\n<div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--color-studio-white);padding:48px 32px;font-family:var(--font-aktiv-grotesk);gap:40px;border-radius:10px;max-width:600px;margin:0 auto;\">\n  <!-- Dark background context buttons -->\n  <div style=\"background:var(--color-absolute-zero);width:100%;padding:48px 32px;border-radius:10px;display:flex;flex-direction:column;align-items:center;gap:24px;\">\n    <p style=\"color:var(--color-studio-white);font-family:var(--font-aktiv-grotesk);font-size:13px;font-weight:400;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 8px 0;\">Sobre fondo oscuro</p>\n    <div style=\"display:flex;flex-wrap:wrap;gap:16px;justify-content:center;\">\n      <a href=\"#\" style=\"display:inline-block;background:var(--color-studio-white);color:var(--color-absolute-zero);font-family:var(--font-aktiv-grotesk);font-size:16px;font-weight:500;text-decoration:none;border:1px solid var(--color-studio-white);border-radius:80px;padding:16px 48px;cursor:pointer;\">Explorar Sonos Play</a>\n      <a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-studio-white);font-family:var(--font-aktiv-grotesk);font-size:16px;font-weight:500;text-decoration:none;border:1px solid var(--color-studio-white);border-radius:80px;padding:16px 48px;cursor:pointer;\">Explorar todo</a>\n    </div>\n  </div>\n  <!-- Light background context buttons -->\n  <div style=\"background:var(--color-studio-white);width:100%;padding:32px;border-radius:10px;display:flex;flex-direction:column;align-items:center;gap:24px;border:1px solid var(--color-pale-border);\">\n    <p style=\"color:var(--color-ghost-gray);font-family:var(--font-aktiv-grotesk);font-size:13px;font-weight:400;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 8px 0;\">Sobre fondo claro</p>\n    <div style=\"display:flex;flex-wrap:wrap;gap:16px;justify-content:center;\">\n      <a href=\"#\" style=\"display:inline-block;background:var(--color-absolute-zero);color:var(--color-studio-white);font-family:var(--font-aktiv-grotesk);font-size:16px;font-weight:500;text-decoration:none;border:1px solid var(--color-absolute-zero);border-radius:80px;padding:16px 48px;cursor:pointer;\">Obtener información</a>\n      <a href=\"#\" style=\"display:inline-block;background:transparent;color:var(--color-absolute-zero);font-family:var(--font-aktiv-grotesk);font-size:16px;font-weight:500;text-decoration:none;border:1px solid var(--color-absolute-zero);border-radius:80px;padding:16px 48px;cursor:pointer;\">Ver productos</a>\n    </div>\n  </div>\n</div>",
