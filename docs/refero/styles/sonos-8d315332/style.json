          "html": "<style>\n  :root {\n    --color-absolute-zero: #000000;\n    --color-studio-white: #ffffff;\n    --color-pale-border: #e0e0e0;\n    --color-ghost-gray: #737373;\n    --font-aktiv-grotesk: 'Inter', sans-serif;\n  }\n</style>\n<div style=\"font-family:var(--font-aktiv-grotesk);max-width:600px;margin:0 auto;\">\n  <div style=\"background:var(--color-absolute-zero);color:var(--color-studio-white);display:flex;align-items:center;justify-content:space-between;padding:12px 20px;position:relative;\">\n    <!-- Close button -->\n    <button style=\"background:transparent;border:none;cursor:pointer;padding:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <line x1=\"2\" y1=\"2\" x2=\"14\" y2=\"14\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n        <line x1=\"14\" y1=\"2\" x2=\"2\" y2=\"14\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n      </svg>\n    </button>\n    <!-- Message -->\n    <p style=\"color:var(--color-studio-white);font-family:var(--font-aktiv-grotesk);font-size:14px;font-weight:400;line-height:1.5;margin:0;text-align:center;flex:1;padding:0 16px;\">Descubre el nuevo Sonos Play. Un sonido estéreo descomunal con un tamaño ideal.</p>\n    <!-- Explore link -->\n    <a href=\"#\" style=\"color:var(--color-studio-white);font-family:var(--font-aktiv-grotesk);font-size:14px;font-weight:400;text-decoration:underline;white-space:nowrap;flex-shrink:0;\">Explorar</a>\n  </div>\n</div>",
