        {
          "html": "<div style=\"--color-storm-slate:#232320;--color-deep-graphite:#1c1c1a;--color-ash-stone:#2e2e2b;--color-ghost-white:#fffffe;--color-silver-thread:#a3a29c;--color-whisper-gray:#75746c;--color-ember-white:rgba(254,254,218,0.055);--color-active-charcoal:#7f7e77;--font-styrene:'Montserrat',sans-serif;background:var(--color-storm-slate);padding:48px 32px;width:600px;box-sizing:border-box;font-family:var(--font-styrene);\"><div style=\"display:flex;flex-direction:column;gap:32px;\"><div style=\"display:flex;justify-content:space-between;align-items:flex-start;gap:24px;\"><div style=\"flex:1;\"><p style=\"margin:0 0 20px 0;color:var(--color-ghost-white);font-family:var(--font-styrene);font-size:20px;font-weight:400;letter-spacing:-1px;line-height:1.2;\">It's very simple.</p><div style=\"display:flex;flex-direction:column;gap:12px;\"><p style=\"margin:0;color:var(--color-ghost-white);font-family:var(--font-styrene);font-size:27px;font-weight:400;letter-spacing:-1.35px;line-height:1.12;\">1 · Find thing on web</p><p style=\"margin:0;color:var(--color-ghost-white);font-family:var(--font-styrene);font-size:27px;font-weight:400;letter-spacing:-1.35px;line-height:1.12;\">2 · Put the thing in a folder</p><p style=\"margin:0;color:var(--color-ghost-white);font-family:var(--font-styrene);font-size:27px;font-weight:400;letter-spacing:-1.35px;line-height:1.12;\">3 · Do it again you son-of-a-gun</p></div></div><div style=\"display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0;\"><button style=\"background:var(--color-active-charcoal);color:rgb(22,22,21);font-family:var(--font-styrene);font-size:11px;font-weight:400;letter-spacing:-0.55px;text-transform:uppercase;border:none;border-radius:9999px;padding:12px 20px;cursor:pointer;line-height:1.56;white-space:nowrap;\">ACCEPT FOLDERS AS YOUR DEITY</button><p style=\"margin:0;color:var(--color-silver-thread);font-family:var(--font-styrene);font-size:14px;font-weight:400;letter-spacing:-0.7px;line-height:1.2;text-align:right;\">And herd your findings like you mean it.</p></div></div></div></div>",
