        {
          "html": "<div style=\"--color-midnight-estate:#000000;--color-greated-parchment:#fef9ed;--color-faded-linen:#f5f0e4;--color-warm-clay:#5d524b;--color-dusty-rose-gradient:linear-gradient(rgb(251,211,190) 50%,rgb(254,249,237) 100%);--font-bradford-ll:'Playfair Display',Georgia,serif;--font-red-hat-mono:'IBM Plex Mono','Courier New',monospace;width:600px;background:var(--color-dusty-rose-gradient);box-sizing:border-box;padding:72px 48px 80px 48px;display:flex;flex-direction:column;align-items:center;justify-content:center;\"><style>@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap');.mission-text{font-family:'Playfair Display',Georgia,serif;font-size:35px;font-weight:400;line-height:1.25;letter-spacing:-0.02em;color:var(--color-warm-clay);text-align:center;margin:0 0 36px 0;max-width:480px;}.mission-badge-row{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}.mission-badge{background:var(--color-faded-linen);color:var(--color-warm-clay);font-family:'IBM Plex Mono','Courier New',monospace;font-size:12px;font-weight:400;letter-spacing:0.05em;line-height:1.6;padding:3.33px 16.67px;border-radius:2.5px;text-transform:none;}</style><p class=\"mission-text\">At MAI, we're building the world's most capable AI systems, with humanity at the center of every decision.</p><div class=\"mission-badge-row\"><span class=\"mission-badge\">Responsible AI</span><span class=\"mission-badge\">Safety</span><span class=\"mission-badge\">Human-Centered</span><span class=\"mission-badge\">Open Research</span></div></div>",
