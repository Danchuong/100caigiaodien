      "components": [
        {
          "html": "<div style=\"--color-midnight-estate:#000000;--color-greated-parchment:#fef9ed;--color-faded-linen:#f5f0e4;--color-warm-clay:#5d524b;--font-bradford-ll:'Playfair Display',Georgia,serif;--font-red-hat-mono:'IBM Plex Mono','Courier New',monospace;display:flex;align-items:center;justify-content:center;width:600px;min-height:120px;background:var(--color-midnight-estate);padding:40px 0;\"><style>@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap');.toggle-pill{display:inline-flex;align-items:center;gap:8px;background:var(--color-greated-parchment);border-radius:65px;padding:8px 16px 8px 10px;cursor:pointer;border:none;outline:none;}.toggle-pill:hover{background:var(--color-faded-linen);}.toggle-off-badge{background:var(--color-warm-clay);color:var(--color-greated-parchment);border-radius:65px;font-family:var(--font-red-hat-mono);font-size:12px;font-weight:500;letter-spacing:0.05em;padding:3px 10px;line-height:1.6;}.toggle-label{font-family:var(--font-red-hat-mono);font-size:13px;font-weight:400;color:var(--color-warm-clay);letter-spacing:-0.013em;line-height:1.6;}</style><button class=\"toggle-pill\" aria-pressed=\"false\" aria-label=\"Toggle Accessibility Mode\"><span class=\"toggle-off-badge\">Off</span><span class=\"toggle-label\">Accessibility Mode</span></button></div>",
