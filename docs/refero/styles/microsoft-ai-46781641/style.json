        {
          "html": "<div style=\"--color-midnight-estate:#000000;--color-greated-parchment:#fef9ed;--color-faded-linen:#f5f0e4;--color-warm-clay:#5d524b;--font-bradford-ll:'Playfair Display',Georgia,serif;--font-red-hat-mono:'IBM Plex Mono','Courier New',monospace;width:600px;background:var(--color-greated-parchment);padding:48px 32px;box-sizing:border-box;font-family:var(--font-bradford-ll);\"><style>@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap');.section-heading{font-family:'Playfair Display',Georgia,serif;font-size:40px;font-weight:400;line-height:1.13;letter-spacing:-0.03em;color:var(--color-warm-clay);text-align:center;margin:0 0 20px 0;}.section-body{font-family:'IBM Plex Mono','Courier New',monospace;font-size:15px;font-weight:400;line-height:1.6;letter-spacing:-0.013em;color:var(--color-warm-clay);text-align:center;max-width:480px;margin:0 auto 36px auto;}.tab-bar{display:flex;align-items:center;background:var(--color-faded-linen);border-radius:65px;padding:6px;gap:0;}.tab-item{flex:1;font-family:'IBM Plex Mono','Courier New',monospace;font-size:13px;font-weight:400;letter-spacing:-0.013em;color:var(--color-warm-clay);text-align:center;padding:12px 16px;border-radius:65px;cursor:pointer;text-decoration:none;line-height:1.25;border:none;background:transparent;transition:background 0.15s;}.tab-item.active{background:var(--color-greated-parchment);text-decoration:underline;font-weight:500;}.tab-item:hover:not(.active){background:rgba(254,249,237,0.6);}</style><h2 class=\"section-heading\">Core products and<br>experiences</h2><p class=\"section-body\">Our major consumer AI products include Copilot, Bing, GroupMe, Edge, and MSN. Our mission is to build state of the art AI models, and create an AI companion for everyone.</p><div class=\"tab-bar\" role=\"tablist\"><button class=\"tab-item active\" role=\"tab\" aria-selected=\"true\">Copilot</button><button class=\"tab-item\" role=\"tab\" aria-selected=\"false\">Bing</button><button class=\"tab-item\" role=\"tab\" aria-selected=\"false\">Edge</button><button class=\"tab-item\" role=\"tab\" aria-selected=\"false\">GroupMe</button></div></div>",
