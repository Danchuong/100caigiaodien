        {
          "html": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f7; padding: 32px; max-width: 600px; box-sizing: border-box;\">\n  <style>\n    :root {\n      --color-obsidian: #131517;\n      --color-graphite: #656768;\n      --color-ash: #a5a6a8;\n      --color-charcoal: #333537;\n      --color-pure-white: #ffffff;\n      --color-flamingo: #f31a7c;\n    }\n  </style>\n\n  <p style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 500; color: var(--color-graphite); letter-spacing: -0.016em; margin: 0 0 16px 0; text-transform: uppercase; letter-spacing: 0.04em;\">Upcoming Events</p>\n\n  <!-- Card 1 -->\n  <div style=\"background: var(--color-pure-white); border-radius: 15px; padding: 16px; margin-bottom: 12px; display: flex; align-items: flex-start; gap: 14px;\">\n    <!-- Date block -->\n    <div style=\"min-width: 44px; text-align: center; background: #f5f5f7; border-radius: 8px; padding: 6px 8px;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 11px; font-weight: 500; color: var(--color-flamingo); letter-spacing: 0.04em; text-transform: uppercase;\">JUL</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 20px; font-weight: 400; color: var(--color-obsidian); line-height: 1; letter-spacing: -0.016em;\">23</div>\n    </div>\n    <!-- Event info -->\n    <div style=\"flex: 1; min-width: 0;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; font-weight: 500; color: var(--color-obsidian); letter-spacing: -0.016em; margin-bottom: 4px;\">Summer Party at Ocean Beach</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-graphite); letter-spacing: -0.016em; margin-bottom: 6px;\">10:00 AM – 8:00 PM PDT · Ocean Beach, San Francisco</div>\n      <div style=\"display: flex; align-items: center; gap: 6px;\">\n        <div style=\"display: flex;\">\n          <div style=\"width: 20px; height: 20px; border-radius: 50%; background: #ffb3c6; border: 2px solid #fff;\"></div>\n          <div style=\"width: 20px; height: 20px; border-radius: 50%; background: #b3d9ff; border: 2px solid #fff; margin-left: -6px;\"></div>\n          <div style=\"width: 20px; height: 20px; border-radius: 50%; background: #c8f7c5; border: 2px solid #fff; margin-left: -6px;\"></div>\n        </div>\n        <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; color: var(--color-graphite); letter-spacing: -0.016em;\">45 Guests</span>\n      </div>\n    </div>\n    <!-- Arrow -->\n    <div style=\"display: flex; align-items: center; padding-top: 4px;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M6 3l5 5-5 5\" stroke=\"#a5a6a8\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </div>\n  </div>\n\n  <!-- Card 2 -->\n  <div style=\"background: var(--color-pure-white); border-radius: 15px; padding: 16px; margin-bottom: 12px; display: flex; align-items: flex-start; gap: 14px;\">\n    <div style=\"min-width: 44px; text-align: center; background: #f5f5f7; border-radius: 8px; padding: 6px 8px;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 11px; font-weight: 500; color: var(--color-flamingo); letter-spacing: 0.04em; text-transform: uppercase;\">AUG</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 20px; font-weight: 400; color: var(--color-obsidian); line-height: 1; letter-spacing: -0.016em;\">5</div>\n    </div>\n    <div style=\"flex: 1; min-width: 0;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; font-weight: 500; color: var(--color-obsidian); letter-spacing: -0.016em; margin-bottom: 4px;\">Rooftop Networking Mixer</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-graphite); letter-spacing: -0.016em; margin-bottom: 6px;\">6:00 PM – 9:00 PM PDT · SoMa, San Francisco</div>\n      <div style=\"display: flex; align-items: center; gap: 6px;\">\n        <div style=\"display: flex;\">\n          <div style=\"width: 20px; height: 20px; border-radius: 50%; background: #d4b3ff; border: 2px solid #fff;\"></div>\n          <div style=\"width: 20px; height: 20px; border-radius: 50%; background: #ffd3b3; border: 2px solid #fff; margin-left: -6px;\"></div>\n        </div>\n        <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; color: var(--color-graphite); letter-spacing: -0.016em;\">120 Guests</span>\n      </div>\n    </div>\n    <div style=\"display: flex; align-items: center; padding-top: 4px;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M6 3l5 5-5 5\" stroke=\"#a5a6a8\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </div>\n  </div>\n\n  <!-- Card 3 -->\n  <div style=\"background: var(--color-pure-white); border-radius: 15px; padding: 16px; display: flex; align-items: flex-start; gap: 14px;\">\n    <div style=\"min-width: 44px; text-align: center; background: #f5f5f7; border-radius: 8px; padding: 6px 8px;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 11px; font-weight: 500; color: var(--color-flamingo); letter-spacing: 0.04em; text-transform: uppercase;\">SEP</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 20px; font-weight: 400; color: var(--color-obsidian); line-height: 1; letter-spacing: -0.016em;\">12</div>\n    </div>\n    <div style=\"flex: 1; min-width: 0;\">\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; font-weight: 500; color: var(--color-obsidian); letter-spacing: -0.016em; margin-bottom: 4px;\">Design Systems Workshop</div>\n      <div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-graphite); letter-spacing: -0.016em; margin-bottom: 6px;\">9:00 AM – 5:00 PM PDT · Online</div>\n      <div style=\"display: inline-block; background: #f0fdf4; border-radius: 8px; padding: 2px 8px;\">\n        <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 12px; font-weight: 500; color: #16a34a; letter-spacing: -0.016em;\">Free</span>\n      </div>\n    </div>\n    <div style=\"display: flex; align-items: center; padding-top: 4px;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M6 3l5 5-5 5\" stroke=\"#a5a6a8\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </div>\n  </div>\n</div>",
