      "components": [
        {
          "html": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #ffffff; padding: 48px 40px; max-width: 600px; box-sizing: border-box;\">\n  <style>\n    :root {\n      --color-obsidian: #131517;\n      --color-graphite: #656768;\n      --color-ash: #a5a6a8;\n      --color-charcoal: #333537;\n      --color-pure-white: #ffffff;\n      --color-flamingo: #f31a7c;\n      --font-apple-system-blinkmacsystemfont-segoe-ui-sans-serif: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    }\n  </style>\n\n  <!-- Luma wordmark -->\n  <div style=\"display: flex; align-items: center; gap: 2px; margin-bottom: 32px;\">\n    <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 18px; font-weight: 500; color: var(--color-obsidian); letter-spacing: -0.016em;\">luma</span>\n    <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" style=\"margin-top: -6px;\">\n      <defs>\n        <radialGradient id=\"logoGrad\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"scale(12)\">\n          <stop offset=\"0%\" stop-color=\"#099ef1\"/>\n          <stop offset=\"18.82%\" stop-color=\"#6863f8\"/>\n          <stop offset=\"32.6%\" stop-color=\"#d84ffa\"/>\n          <stop offset=\"52.83%\" stop-color=\"#f058c5\"/>\n          <stop offset=\"68.03%\" stop-color=\"#ff4f90\"/>\n          <stop offset=\"87.66%\" stop-color=\"#ff6558\"/>\n          <stop offset=\"100%\" stop-color=\"#ff891f\"/>\n        </radialGradient>\n      </defs>\n      <path d=\"M6 0.5L7.08 4.42L11 5.5L7.08 6.58L6 10.5L4.92 6.58L1 5.5L4.92 4.42L6 0.5Z\" fill=\"url(#logoGrad)\"/>\n    </svg>\n  </div>\n\n  <!-- Headline -->\n  <div style=\"margin-bottom: 24px;\">\n    <h1 style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 64px; font-weight: 400; line-height: 1.03; letter-spacing: -1.02px; color: var(--color-obsidian); margin: 0; padding: 0;\">\n      Delightful<br>events<br><span style=\"color: var(--color-flamingo);\">start here.</span>\n    </h1>\n  </div>\n\n  <!-- Body copy -->\n  <p style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; font-weight: 400; line-height: 1.5; color: var(--color-graphite); letter-spacing: -0.016em; margin: 0 0 32px 0; max-width: 320px;\">\n    Set up an event page, invite friends and sell tickets. Host a memorable event today.\n  </p>\n\n  <!-- CTA Button -->\n  <button style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; font-weight: 500; color: var(--color-pure-white); background: var(--color-charcoal); border: none; border-radius: 15px; padding: 14px 24px; cursor: pointer; letter-spacing: -0.016em; display: inline-block;\">Create Your First Event</button>\n</div>",
