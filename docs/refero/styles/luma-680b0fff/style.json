          "html": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #ffffff; padding: 24px 32px; max-width: 600px; box-sizing: border-box; border-top: 1px solid #f0f0f0;\">\n  <style>\n    :root {\n      --color-obsidian: #131517;\n      --color-graphite: #656768;\n      --color-ash: #a5a6a8;\n      --color-charcoal: #333537;\n      --color-pure-white: #ffffff;\n      --color-flamingo: #f31a7c;\n    }\n    .footer-link {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      font-size: 14px;\n      font-weight: 400;\n      color: #656768;\n      text-decoration: none;\n      letter-spacing: -0.016em;\n    }\n    .footer-link:hover {\n      color: #131517;\n    }\n  </style>\n\n  <!-- Top row: logo + nav links -->\n  <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;\">\n    <!-- Logo wordmark -->\n    <div style=\"display: flex; align-items: center; gap: 2px;\">\n      <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 14px; font-weight: 500; color: var(--color-obsidian); letter-spacing: -0.016em;\">luma</span>\n      <svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\" style=\"margin-top: -5px;\">\n        <defs>\n          <radialGradient id=\"logoGrad2\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"scale(10)\">\n            <stop offset=\"0%\" stop-color=\"#099ef1\"/>\n            <stop offset=\"18.82%\" stop-color=\"#6863f8\"/>\n            <stop offset=\"32.6%\" stop-color=\"#d84ffa\"/>\n            <stop offset=\"52.83%\" stop-color=\"#f058c5\"/>\n            <stop offset=\"68.03%\" stop-color=\"#ff4f90\"/>\n            <stop offset=\"87.66%\" stop-color=\"#ff6558\"/>\n            <stop offset=\"100%\" stop-color=\"#ff891f\"/>\n          </radialGradient>\n        </defs>\n        <path d=\"M5 0.5L5.9 3.6L9 4.5L5.9 5.4L5 8.5L4.1 5.4L1 4.5L4.1 3.6L5 0.5Z\" fill=\"url(#logoGrad2)\"/>\n      </svg>\n    </div>\n\n    <!-- Nav links -->\n    <nav style=\"display: flex; align-items: center; gap: 20px;\">\n      <a href=\"#\" class=\"footer-link\">Discover</a>\n      <a href=\"#\" class=\"footer-link\">Pricing</a>\n      <a href=\"#\" class=\"footer-link\">Help</a>\n    </nav>\n\n    <!-- Social icons -->\n    <div style=\"display: flex; align-items: center; gap: 14px;\">\n      <!-- Email -->\n      <a href=\"#\" style=\"color: var(--color-graphite); display: flex;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <rect x=\"1\" y=\"3\" width=\"14\" height=\"10\" rx=\"2\" stroke=\"#656768\" stroke-width=\"1.3\" fill=\"none\"/>\n          <path d=\"M1.5 4L8 9.5L14.5 4\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </a>\n      <!-- App Store A -->\n      <a href=\"#\" style=\"color: var(--color-graphite); display: flex;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M8 2L10.5 9H5.5L8 2Z\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linejoin=\"round\" fill=\"none\"/>\n          <path d=\"M4.5 9h7\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n          <path d=\"M3 13l2-4\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n          <path d=\"M13 13l-2-4\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n        </svg>\n      </a>\n      <!-- Play -->\n      <a href=\"#\" style=\"color: var(--color-graphite); display: flex;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M5 3l9 5-9 5V3Z\" stroke=\"#656768\" stroke-width=\"1.3\" stroke-linejoin=\"round\" fill=\"none\"/>\n        </svg>\n      </a>\n      <!-- X -->\n      <a href=\"#\" style=\"color: var(--color-graphite); display: flex;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M2.5 2.5l11 11M13.5 2.5l-11 11\" stroke=\"#656768\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n        </svg>\n      </a>\n      <!-- Instagram -->\n      <a href=\"#\" style=\"color: var(--color-graphite); display: flex;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <rect x=\"2\" y=\"2\" width=\"12\" height=\"12\" rx=\"3.5\" stroke=\"#656768\" stroke-width=\"1.3\" fill=\"none\"/>\n          <circle cx=\"8\" cy=\"8\" r=\"2.8\" stroke=\"#656768\" stroke-width=\"1.3\" fill=\"none\"/>\n          <circle cx=\"11.5\" cy=\"4.5\" r=\"0.8\" fill=\"#656768\"/>\n        </svg>\n      </a>\n    </div>\n  </div>\n\n  <!-- Bottom row: legal links -->\n  <div style=\"display: flex; align-items: center; gap: 16px;\">\n    <a href=\"#\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-ash); text-decoration: none; letter-spacing: -0.016em;\">Terms</a>\n    <a href=\"#\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-ash); text-decoration: none; letter-spacing: -0.016em;\">Privacy</a>\n    <a href=\"#\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-ash); text-decoration: none; letter-spacing: -0.016em;\">Security</a>\n    <span style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-ash); letter-spacing: -0.016em; margin-left: auto;\">3:25 PM EDT</span>\n  </div>\n</div>",
