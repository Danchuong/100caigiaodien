      "components": [
        {
          "html": "<style>\n  :root {\n    --color-canvas: #f1f0ee;\n    --color-inkwell: #252525;\n    --color-pitch-black: #000000;\n    --color-stone-wall: #dbdad9;\n    --color-accent-blue: #0000ee;\n    --font-mono: 'Space Mono', monospace;\n    --font-sans: system-ui, sans-serif;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-canvas);border-top:1px solid var(--color-stone-wall);border-bottom:1px solid var(--color-stone-wall);padding:12px 20px;box-sizing:border-box;display:flex;align-items:flex-start;justify-content:space-between;gap:16px;\">\n  <div style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;line-height:1.15;\">DUTIES&nbsp;<span style=\"display:inline-block;width:6px;height:6px;background:var(--color-inkwell);border-radius:50%;vertical-align:middle;margin-bottom:1px;\"></span>&nbsp;(DESIGN STUDIO AND VENTURE PARTNER)</div>\n  <div style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);letter-spacing:0.04em;text-transform:uppercase;line-height:1.5;text-align:left;\">\n    <div style=\"margin-bottom:2px;\">WE HELP YOU:</div>\n    <div>&ndash;&nbsp;DEFINE YOUR BRAND STRATEGY</div>\n    <div>&ndash;&nbsp;DESIGN YOUR VISUAL IDENTITY</div>\n    <div>&ndash;&nbsp;DEPLOY YOUR BRAND ONLINE</div>\n  </div>\n  <div style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;text-align:right;line-height:1.5;\">\n    <div>CURRENTLY:&nbsp;<span style=\"display:inline-block;width:7px;height:7px;background:#e63c2f;border-radius:50%;vertical-align:middle;margin-bottom:1px;\"></span>&nbsp;OFF-DUTY</div>\n    <div>18:52, OSLO</div>\n  </div>\n</div>",
          "name": "Status Bar — Duties Info Strip",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-canvas: #f1f0ee;\n    --color-inkwell: #252525;\n    --color-stone-wall: #dbdad9;\n    --color-accent-blue: #0000ee;\n    --font-body: 'Inter', system-ui, sans-serif;\n    --font-mono: 'Space Mono', monospace;\n    --font-sans: system-ui, sans-serif;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-canvas);padding:48px 40px;box-sizing:border-box;font-family:var(--font-body);\">\n  <div style=\"display:flex;gap:40px;align-items:flex-start;\">\n    <div style=\"min-width:80px;\">\n      <span style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);letter-spacing:0.04em;text-transform:uppercase;line-height:1.0;\">ABOUT</span>\n    </div>\n    <div style=\"flex:1;\">\n      <p style=\"font-family:'Inter',system-ui,sans-serif;font-size:18px;font-weight:600;color:var(--color-inkwell);line-height:1.2;margin:0 0 28px 0;font-feature-settings:'zero';\">\n        We're a two-person studio in Oslo specialising in brand identity and Framer websites. We work directly with founders and marketing leads. No account managers, no layers. You get senior designers from day one to launch.\n      </p>\n      <a href=\"#\" style=\"display:inline-flex;align-items:center;gap:8px;background:var(--color-inkwell);color:var(--color-accent-blue);font-family:var(--font-sans);font-size:12px;font-weight:400;letter-spacing:0.05em;text-transform:uppercase;text-decoration:none;padding:10px 20px;border-radius:32px;line-height:1;\">\n        VIEW SERVICES&nbsp;&rarr;\n      </a>\n    </div>\n  </div>\n</div>",
          "name": "About Section — Body + CTA Button",
          "role": "",
          "description": ""
        },
        {
          "html": "<style>\n  :root {\n    --color-canvas: #f1f0ee;\n    --color-inkwell: #252525;\n    --color-stone-wall: #dbdad9;\n    --color-pitch-black: #000000;\n    --font-mono: 'Space Mono', monospace;\n    --font-sans: system-ui, sans-serif;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-canvas);padding:40px 32px;box-sizing:border-box;\">\n  <div style=\"display:flex;gap:16px;\">\n    <!-- Card 1 -->\n    <div style=\"flex:0 0 260px;\">\n      <div style=\"width:100%;height:200px;border-radius:8px;overflow:hidden;background:#1a1a2e;display:flex;align-items:center;justify-content:center;position:relative;\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(135deg,#2d1b69 0%,#1a1a3e 50%,#0d0d1a 100%);\"></div>\n        <div style=\"position:relative;z-index:1;text-align:center;\">\n          <div style=\"font-family:'Bebas Neue','Impact',sans-serif;font-size:42px;color:#fff;letter-spacing:-0.02em;line-height:0.9;opacity:0.9;\">AUTORIA</div>\n          <div style=\"width:60px;height:2px;background:rgba(255,255,255,0.3);margin:8px auto;\"></div>\n        </div>\n        <!-- Decorative squiggle lines -->\n        <svg style=\"position:absolute;inset:0;width:100%;height:100%;opacity:0.15;\" viewBox=\"0 0 260 200\" fill=\"none\">\n          <path d=\"M0 100 Q65 60 130 100 Q195 140 260 100\" stroke=\"white\" stroke-width=\"6\" fill=\"none\"/>\n          <path d=\"M0 130 Q65 90 130 130 Q195 170 260 130\" stroke=\"white\" stroke-width=\"4\" fill=\"none\"/>\n        </svg>\n      </div>\n      <div style=\"margin-top:10px;display:flex;align-items:center;gap:8px;\">\n        <span style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);text-transform:uppercase;letter-spacing:0.04em;\">AUTORIA</span>\n        <span style=\"display:inline-block;width:5px;height:5px;background:var(--color-inkwell);border-radius:50%;vertical-align:middle;\"></span>\n        <span style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);text-transform:uppercase;letter-spacing:0.04em;\">SCOPE (BRAND, DIGITAL)</span>\n      </div>\n    </div>\n    <!-- Card 2 -->\n    <div style=\"flex:0 0 auto;flex:1;\">\n      <div style=\"width:100%;height:200px;border-radius:8px;overflow:hidden;background:#2c2a28;display:flex;align-items:center;justify-content:center;position:relative;\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#3a3530 0%,#1e1c1a 100%);\"></div>\n        <div style=\"position:relative;z-index:1;text-align:center;padding:16px;\">\n          <div style=\"font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;\">Strategy</div>\n          <div style=\"font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;\">Branding</div>\n          <div style=\"font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;\">UI/UX</div>\n          <div style=\"font-family:'Inter',system-ui,sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:0.08em;text-transform:uppercase;\">Content</div>\n        </div>\n      </div>\n      <div style=\"margin-top:10px;display:flex;align-items:center;gap:8px;\">\n        <span style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);text-transform:uppercase;letter-spacing:0.04em;\">SERVICES</span>\n        <span style=\"display:inline-block;width:5px;height:5px;background:var(--color-inkwell);border-radius:50%;vertical-align:middle;\"></span>\n        <span style=\"font-family:var(--font-mono);font-size:11px;color:var(--color-inkwell);text-transform:uppercase;letter-spacing:0.04em;\">SCOPE (STRATEGY, BRAND)</span>\n      </div>\n    </div>\n  </div>\n  <!-- Booking ticker -->\n  <div style=\"margin-top:32px;background:var(--color-pitch-black);padding:10px 0;border-radius:4px;overflow:hidden;white-space:nowrap;\">\n    <span style=\"font-family:var(--font-mono);font-size:11px;color:#fff;letter-spacing:0.08em;text-transform:uppercase;padding:0 24px;\">CURRENTLY BOOKING PROJECTS FOR SPRING / SUMMER 2026&nbsp;&bull;&nbsp;CURRENTLY BOOKING PROJECTS FOR SPRING / SUMMER 2026&nbsp;&bull;&nbsp;CURRENTLY BOOKING PROJECTS FOR SPRING / SUMMER 2026</span>\n  </div>\n</div>",
