        {
          "html": "<style>:root{--color-midnight-ink:#000000;--color-canvas-white:#ffffff;--color-studio-gray:#eeeeee;--color-electric-violet:#0000ff;--color-melody-red:#ff8389;--color-synth-teal:#00d2be;--font-futura-pt:'Futura PT','Futura',sans-serif;}</style><div style=\"background:var(--color-canvas-white);padding:40px;font-family:var(--font-futura-pt);max-width:600px;box-sizing:border-box;border-top:2px solid var(--color-midnight-ink);\"><p style=\"font-family:var(--font-futura-pt);font-size:14px;font-weight:700;color:var(--color-midnight-ink);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px 0;\">Stay up to date</p><h2 style=\"font-family:var(--font-futura-pt);font-size:30px;font-weight:700;color:var(--color-midnight-ink);margin:0 0 8px 0;line-height:1.2;\">Get the latest from Ableton</h2><p style=\"font-family:var(--font-futura-pt);font-size:16px;color:var(--color-midnight-ink);margin:0 0 24px 0;line-height:1.5;font-weight:400;\">Exclusive offers, the latest from our blog, and more — straight to your inbox.</p><div style=\"display:flex;gap:0;\"><input type=\"email\" placeholder=\"Enter your email address\" style=\"flex:1;background:var(--color-studio-gray);color:var(--color-midnight-ink);font-family:var(--font-futura-pt);font-size:16px;padding:8px 15px;border:none;outline:none;border-radius:0;box-sizing:border-box;\" /><button style=\"background:var(--color-electric-violet);color:var(--color-canvas-white);font-family:var(--font-futura-pt);font-size:16px;font-weight:400;padding:8px 30px;border:none;border-radius:0;cursor:pointer;white-space:nowrap;\">Sign up</button></div><p style=\"font-family:var(--font-futura-pt);font-size:12px;color:var(--color-midnight-ink);margin:12px 0 0 0;line-height:1.4;opacity:0.6;\">By submitting your email address, you agree to receive marketing emails from Ableton. We can help you remove yourself from our list at any time.</p><div style=\"margin-top:30px;padding-top:20px;border-top:1px solid var(--color-studio-gray);display:flex;gap:20px;align-items:center;\"><a href=\"#\" style=\"font-family:var(--font-futura-pt);font-size:16px;color:var(--color-electric-violet);text-decoration:none;font-weight:400;\">Try Live 12 for free <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" style=\"display:inline;vertical-align:middle;\"><path d=\"M2 6h8M6 2l4 4-4 4\" stroke=\"#0000ff\" stroke-width=\"1.5\" stroke-linecap=\"square\"/></svg></a><a href=\"#\" style=\"font-family:var(--font-futura-pt);font-size:16px;color:var(--color-midnight-ink);text-decoration:none;font-weight:400;\">Learn more <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" style=\"display:inline;vertical-align:middle;\"><path d=\"M2 6h8M6 2l4 4-4 4\" stroke=\"#000000\" stroke-width=\"1.5\" stroke-linecap=\"square\"/></svg></a></div></div>",
