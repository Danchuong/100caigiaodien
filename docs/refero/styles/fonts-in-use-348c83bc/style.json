        {
          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Oswald:wght@400;700&display=swap');\n  :root {\n    --color-inkwell: #000000;\n    --color-canvas: #ffffff;\n    --color-mist: #f0f0f0;\n    --color-pewter: #dddddd;\n    --color-stone: #cccccc;\n    --color-ash: #999999;\n    --font-benton-sans-re: 'Inter', sans-serif;\n    --font-relay-cond: 'Oswald', sans-serif;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-canvas);font-family:var(--font-benton-sans-re);padding:20px 20px 24px;box-sizing:border-box;\">\n\n  <!-- Search input row -->\n  <div style=\"display:flex;align-items:stretch;gap:0;margin-bottom:20px;\">\n    <input\n      type=\"text\"\n      placeholder=\"Enter a word, typeface, tag ...\"\n      style=\"flex:1;font-family:var(--font-benton-sans-re);font-size:14px;color:var(--color-inkwell);background:var(--color-canvas);border:1px solid var(--color-pewter);border-right:none;border-radius:2px 0 0 2px;padding:7px 10px;outline:none;box-sizing:border-box;\"\n    />\n    <button style=\"background:var(--color-ash);color:var(--color-canvas);border:1px solid var(--color-ash);border-radius:0 2px 2px 0;padding:7px 12px;font-family:var(--font-benton-sans-re);font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:4px;\">\n      <svg width=\"13\" height=\"13\" viewBox=\"0 0 13 13\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"5.5\" cy=\"5.5\" r=\"4\" stroke=\"white\" stroke-width=\"1.5\"/><line x1=\"8.7\" y1=\"8.7\" x2=\"12\" y2=\"12\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n  </div>\n  <div style=\"font-family:var(--font-benton-sans-re);font-size:12px;color:var(--color-ash);margin-bottom:20px;\">or combine terms with <a href=\"#\" style=\"color:var(--color-inkwell);text-decoration:underline;\">Advanced Search</a></div>\n\n  <!-- Divider -->\n  <div style=\"border-top:2px solid var(--color-inkwell);margin-bottom:14px;\"></div>\n\n  <!-- Filter bar -->\n  <div style=\"display:flex;align-items:center;gap:0;\">\n    <button style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:14px;color:var(--color-inkwell);background:var(--color-canvas);border:none;padding:5px 10px 5px 0;cursor:pointer;display:flex;align-items:center;gap:4px;\">\n      Topics\n      <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\"><path d=\"M1 1L4 5L7 1\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n    <div style=\"width:1px;height:16px;background:var(--color-stone);margin:0 10px;\"></div>\n    <button style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:14px;color:var(--color-inkwell);background:var(--color-canvas);border:none;padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:4px;\">\n      Formats\n      <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\"><path d=\"M1 1L4 5L7 1\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n    <div style=\"width:1px;height:16px;background:var(--color-stone);margin:0 10px;\"></div>\n    <button style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:14px;color:var(--color-inkwell);background:var(--color-canvas);border:none;padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:4px;\">\n      Typefaces\n      <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\"><path d=\"M1 1L4 5L7 1\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n  </div>\n\n  <!-- Divider -->\n  <div style=\"border-top:1px solid var(--color-pewter);margin-top:14px;margin-bottom:16px;\"></div>\n\n  <!-- Sort / Show row -->\n  <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n    <div style=\"font-family:var(--font-benton-sans-re);font-size:13px;color:var(--color-inkwell);\">\n      Show: <strong>All (33217)</strong>\n      <span style=\"color:var(--color-ash);\"> / </span>\n      <a href=\"#\" style=\"color:var(--color-inkwell);text-decoration:none;\">Staff Picks (6195)</a>\n      <span style=\"color:var(--color-ash);\"> / </span>\n      <a href=\"#\" style=\"color:var(--color-inkwell);text-decoration:none;\">Blog (170)</a>\n    </div>\n    <div style=\"display:flex;align-items:center;gap:8px;\">\n      <span style=\"font-family:var(--font-benton-sans-re);font-size:13px;color:var(--color-inkwell);\">Sort:</span>\n      <button style=\"font-family:var(--font-benton-sans-re);font-weight:700;font-size:13px;color:var(--color-inkwell);background:var(--color-canvas);border:none;cursor:pointer;display:flex;align-items:center;gap:3px;padding:0;\">\n        Contribution Date\n        <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\"><path d=\"M1 1L4 5L7 1\" stroke=\"#000\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n      </button>\n      <div style=\"display:flex;gap:2px;margin-left:4px;\">\n        <button style=\"background:var(--color-mist);border:1px solid var(--color-pewter);border-radius:2px;padding:4px 6px;cursor:pointer;\">\n          <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><rect x=\"0\" y=\"0\" width=\"5\" height=\"5\" fill=\"#000\"/><rect x=\"7\" y=\"0\" width=\"5\" height=\"5\" fill=\"#000\"/><rect x=\"0\" y=\"7\" width=\"5\" height=\"5\" fill=\"#000\"/><rect x=\"7\" y=\"7\" width=\"5\" height=\"5\" fill=\"#000\"/></svg>\n        </button>\n        <button style=\"background:var(--color-canvas);border:1px solid var(--color-pewter);border-radius:2px;padding:4px 6px;cursor:pointer;\">\n          <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><rect x=\"0\" y=\"0\" width=\"12\" height=\"2\" fill=\"#999\"/><rect x=\"0\" y=\"5\" width=\"12\" height=\"2\" fill=\"#999\"/><rect x=\"0\" y=\"10\" width=\"12\" height=\"2\" fill=\"#999\"/></svg>\n        </button>\n      </div>\n    </div>\n  </div>\n</div>",
