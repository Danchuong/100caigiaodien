      "components": [
        {
          "html": "<style>\n  :root {\n    --color-inkwell: #000000;\n    --color-canvas: #ffffff;\n    --color-mist: #f0f0f0;\n    --color-pewter: #dddddd;\n    --color-stone: #cccccc;\n    --color-ash: #999999;\n    --font-benton-sans-re: 'Inter', sans-serif;\n    --font-relay-cond: 'Oswald', sans-serif;\n  }\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Oswald:wght@400;700&display=swap');\n</style>\n<div style=\"width:600px;background:var(--color-canvas);font-family:var(--font-benton-sans-re);padding:20px;box-sizing:border-box;\">\n  <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;\">\n\n    <!-- Card 1 -->\n    <div style=\"display:flex;flex-direction:column;gap:8px;\">\n      <div style=\"width:100%;height:170px;background:#1a1a2e;border-radius:0;overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center;\">\n        <div style=\"text-align:center;padding:10px;\">\n          <div style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:22px;color:#fff;line-height:1.1;\">SUPER<br>STIMOLO</div>\n          <div style=\"font-family:var(--font-benton-sans-re);font-weight:400;font-size:9px;color:#ccc;margin-top:6px;line-height:1.4;\">Come il cervello percepisce<br>attraverso i sensi</div>\n        </div>\n        <div style=\"position:absolute;top:0;right:0;background:var(--color-inkwell);color:var(--color-canvas);font-family:var(--font-relay-cond);font-weight:700;font-size:10px;padding:4px 6px;transform:rotate(0deg);\">\n          <div style=\"transform:rotate(45deg);transform-origin:center;position:absolute;top:-8px;right:-8px;background:var(--color-canvas);color:var(--color-inkwell);font-size:9px;font-weight:700;padding:12px 4px 4px 4px;white-space:nowrap;\">Staff<br>Pick</div>\n        </div>\n        <div style=\"position:absolute;top:0;right:0;width:0;height:0;border-style:solid;border-width:0 55px 55px 0;border-color:transparent var(--color-canvas) transparent transparent;\"></div>\n        <div style=\"position:absolute;top:4px;right:4px;font-family:var(--font-relay-cond);font-weight:700;font-size:9px;color:var(--color-inkwell);text-align:right;line-height:1.1;\">Staff<br>Pick</div>\n      </div>\n      <div style=\"font-family:var(--font-benton-sans-re);font-weight:700;font-size:16px;color:var(--color-inkwell);line-height:1.2;\">Proxima Nova</div>\n      <div style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:18px;color:var(--color-inkwell);line-height:1;\">Swear</div>\n    </div>\n\n    <!-- Card 2 -->\n    <div style=\"display:flex;flex-direction:column;gap:8px;\">\n      <div style=\"width:100%;height:170px;background:#111;border-radius:0;overflow:hidden;display:flex;align-items:center;justify-content:center;\">\n        <div style=\"background:var(--color-canvas);padding:14px 18px;width:70%;text-align:center;\">\n          <div style=\"font-family:var(--font-benton-sans-re);font-weight:400;font-size:8px;color:var(--color-inkwell);line-height:1.6;\">Hannes Famira.<br>The Practically,<br>Light, Extra-bold,<br>Cursive, Retraction,<br>Oboe and<br>Sharp and The Soft</div>\n        </div>\n      </div>\n      <div style=\"font-family:var(--font-relay-cond);font-weight:400;font-size:20px;color:var(--color-inkwell);line-height:1;\">JN Messenger</div>\n      <div style=\"font-family:var(--font-benton-sans-re);font-weight:400;font-size:18px;color:var(--color-inkwell);line-height:1;\">Univers</div>\n    </div>\n\n    <!-- Card 3 -->\n    <div style=\"display:flex;flex-direction:column;gap:8px;\">\n      <div style=\"width:100%;height:170px;background:#5c1f1f;border-radius:0;overflow:hidden;display:flex;align-items:center;justify-content:center;\">\n        <div style=\"text-align:center;padding:12px;\">\n          <div style=\"font-family:Georgia,serif;font-weight:400;font-size:18px;color:#e8d5b0;line-height:1.2;\">MATHILDE<br>MARTEAU</div>\n          <div style=\"width:80px;height:1px;background:#e8d5b0;margin:8px auto;\"></div>\n          <div style=\"font-family:Georgia,serif;font-weight:400;font-size:10px;color:#e8d5b0;letter-spacing:2px;\">ATELIER</div>\n        </div>\n      </div>\n      <div style=\"font-family:Georgia,serif;font-weight:400;font-size:18px;color:var(--color-inkwell);line-height:1;\">Aujournuit</div>\n      <div style=\"font-family:var(--font-benton-sans-re);font-weight:700;font-size:16px;color:var(--color-inkwell);\">Zilla Slab</div>\n      <div style=\"font-family:'Gill Sans','Trebuchet MS',sans-serif;font-weight:400;font-size:15px;color:var(--color-inkwell);\">Avenir</div>\n    </div>\n\n  </div>\n</div>",
