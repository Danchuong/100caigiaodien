          "html": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Oswald:wght@400;700&display=swap');\n  :root {\n    --color-inkwell: #000000;\n    --color-canvas: #ffffff;\n    --color-mist: #f0f0f0;\n    --color-pewter: #dddddd;\n    --color-stone: #cccccc;\n    --color-ash: #999999;\n    --font-benton-sans-re: 'Inter', sans-serif;\n    --font-relay-cond: 'Oswald', sans-serif;\n  }\n</style>\n<div style=\"width:600px;background:var(--color-canvas);font-family:var(--font-benton-sans-re);padding:20px;box-sizing:border-box;display:flex;gap:20px;align-items:flex-start;\">\n\n  <!-- Sponsor visual card -->\n  <div style=\"flex:0 0 180px;\">\n    <div style=\"width:180px;height:220px;background:#1a1a1a;border-radius:0;overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center;padding:12px;box-sizing:border-box;\">\n      <div style=\"text-align:center;\">\n        <div style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:28px;line-height:1.0;color:#ffd700;text-transform:uppercase;\">KUHLMAN!</div>\n        <div style=\"font-family:var(--font-benton-sans-re);font-weight:700;font-size:11px;line-height:1.3;color:#00e5ff;margin-top:4px;text-transform:uppercase;\">A TYPEFACE BASED ON<br>THE EXPRESSIVE</div>\n        <div style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:24px;line-height:1.0;color:#fff;margin-top:4px;text-transform:uppercase;\">BOOK COVER<br>LETTERING OF<br>ROY KUHLMAN</div>\n      </div>\n      <!-- Staff Pick corner badge -->\n      <div style=\"position:absolute;top:0;right:0;width:0;height:0;border-style:solid;border-width:0 56px 56px 0;border-color:transparent var(--color-canvas) transparent transparent;\"></div>\n      <div style=\"position:absolute;top:5px;right:3px;font-family:var(--font-relay-cond);font-weight:700;font-size:8px;color:var(--color-inkwell);text-align:right;line-height:1.2;\">Staff<br>Pick</div>\n    </div>\n  </div>\n\n  <!-- Sponsor info -->\n  <div style=\"flex:1;display:flex;flex-direction:column;gap:8px;padding-top:4px;\">\n    <div style=\"font-family:var(--font-benton-sans-re);font-size:10px;font-weight:400;color:var(--color-ash);text-transform:uppercase;letter-spacing:0.5px;\">Sponsor</div>\n    <div style=\"font-family:var(--font-relay-cond);font-weight:700;font-size:22px;color:var(--color-inkwell);line-height:1;\">Kuhlman from DJR</div>\n    <div style=\"width:100%;height:1px;background:var(--color-pewter);margin:2px 0;\"></div>\n    <p style=\"font-family:var(--font-benton-sans-re);font-size:13px;color:var(--color-inkwell);line-height:1.6;margin:0;\">A variable-width tribute to the cut paper lettering of graphic designer Roy Kuhlman</p>\n    <p style=\"font-family:var(--font-benton-sans-re);font-size:13px;color:var(--color-inkwell);line-height:1.6;margin:0;\">Cool, man!</p>\n    <div style=\"margin-top:8px;\">\n      <a href=\"#\" style=\"display:inline-block;font-family:var(--font-benton-sans-re);font-weight:700;font-size:12px;color:var(--color-canvas);background:var(--color-ash);border:1px solid var(--color-ash);border-radius:2px;padding:5px 10px;text-decoration:none;\">Learn More</a>\n    </div>\n  </div>\n\n</div>",
