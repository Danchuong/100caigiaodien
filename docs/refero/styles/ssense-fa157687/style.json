          "html": "<style>\n  :root {\n    --color-ink-black: #000000;\n    --color-charcoal-gray: #333333;\n    --color-silver-thread: #888888;\n    --color-ash-gray: #979797;\n    --color-canvas-white: #ffffff;\n    --color-paper-white: #f4f4f4;\n    --color-alabaster: #e8e8e8;\n    --font-jha-times-now: 'Playfair Display', serif;\n    --font-favorit-ssense-inter: 'Inter', Arial, sans-serif;\n  }\n  .editorial-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 20px;\n    width: 600px;\n    box-sizing: border-box;\n    background: var(--color-canvas-white);\n    padding: 30px 20px;\n  }\n  .editorial-card {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .editorial-card-image {\n    width: 100%;\n    height: 140px;\n    background: var(--color-paper-white);\n    border-radius: 0;\n    overflow: hidden;\n  }\n  .editorial-card-meta {\n    display: flex;\n    flex-direction: column;\n    gap: 5px;\n  }\n  .editorial-card-tag {\n    font-family: var(--font-favorit-ssense-inter);\n    font-size: 11px;\n    font-weight: 400;\n    color: var(--color-silver-thread);\n    line-height: 1.36;\n    letter-spacing: 0;\n    text-transform: uppercase;\n  }\n  .editorial-card-title {\n    font-family: var(--font-favorit-ssense-inter);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--color-ink-black);\n    line-height: 1.37;\n    letter-spacing: -0.462px;\n    margin: 0;\n  }\n  .editorial-card-sub {\n    font-family: var(--font-favorit-ssense-inter);\n    font-size: 11px;\n    font-weight: 400;\n    color: var(--color-silver-thread);\n    line-height: 1.36;\n  }\n</style>\n<div class=\"editorial-grid\">\n  <div class=\"editorial-card\">\n    <div class=\"editorial-card-image\" style=\"background:#c9c3bc;\"></div>\n    <div class=\"editorial-card-meta\">\n      <span class=\"editorial-card-tag\">RECENT</span>\n      <p class=\"editorial-card-title\">APRIL FOOLS</p>\n      <span class=\"editorial-card-sub\">Culture &