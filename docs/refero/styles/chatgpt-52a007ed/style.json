      "components": [
        {
          "html": "<style>:root{--color-carbon:#0d0d0d;--color-snow:#ffffff;--color-fog:#f9f9f9;--color-pewter:#5d5d5d;--color-stone:#8f8f8f;--color-arctic-mist:#ececec;--color-link-blue:#007aff;--font-ui-sans-serif:system-ui,sans-serif;--font-openai-sans:system-ui,sans-serif;}</style><div style=\"width:600px;background:var(--color-snow);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;box-sizing:border-box;font-family:var(--font-ui-sans-serif);\"><h1 style=\"font-family:var(--font-openai-sans);font-size:28px;font-weight:600;color:var(--color-carbon);letter-spacing:-0.015em;line-height:1.56;margin:0 0 28px 0;text-align:center;\">Where should we begin?</h1><div style=\"width:100%;max-width:560px;display:flex;align-items:center;background:var(--color-snow);border:1.5px solid var(--color-arctic-mist);border-radius:28px;padding:10px 12px 10px 16px;box-sizing:border-box;box-shadow:0 1px 4px rgba(0,0,0,0.06);\"><button style=\"background:none;border:none;cursor:pointer;padding:0;margin-right:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><line x1=\"9\" y1=\"2\" x2=\"9\" y2=\"16\" stroke=\"#8f8f8f\" stroke-width=\"1.8\" stroke-linecap=\"round\"/><line x1=\"2\" y1=\"9\" x2=\"16\" y2=\"9\" stroke=\"#8f8f8f\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg></button><input type=\"text\" placeholder=\"Ask anything\" style=\"flex:1;border:none;outline:none;background:transparent;font-family:var(--font-ui-sans-serif);font-size:16px;color:var(--color-carbon);line-height:1.5;caret-color:var(--color-carbon);\" /><button style=\"display:flex;align-items:center;gap:6px;background:var(--color-snow);border:1.5px solid var(--color-arctic-mist);border-radius:16px;padding:6px 12px;cursor:pointer;font-family:var(--font-ui-sans-serif);font-size:13px;font-weight:500;color:var(--color-carbon);white-space:nowrap;flex-shrink:0;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"2\" y=\"6\" width=\"2\" height=\"5\" rx=\"1\" fill=\"#0d0d0d\"/><rect x=\"6\" y=\"3\" width=\"2\" height=\"8\" rx=\"1\" fill=\"#0d0d0d\"/><rect x=\"10\" y=\"5\" width=\"2\" height=\"4\" rx=\"1\" fill=\"#0d0d0d\"/></svg>Voice</button></div></div>",
